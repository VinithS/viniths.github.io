  /* --- Sweep rule (shared across MRZ head and status) ---------------
     Thin rule with an amber glow riding across it. Default (non-
     paired) mode: each sweep runs an independent LTR transit. Paired
     overrides below phase them so in the /about passport the glow
     reads as one light cycling around the panel. */
  .flip-sweep {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--flip-rule) 15%,
      var(--flip-rule) 85%,
      transparent 100%
    );
    position: relative;
    overflow: hidden;
  }
  .flip-sweep::after {
    content: "";
    position: absolute;
    top: -3px;
    left: 0;
    width: 20%;
    height: 7px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--flip-amber) 50%,
      transparent 100%
    );
    opacity: 0.6;
    /* Glow is 20% of the rail wide; translating by multiples of 100%
       of its own width moves it by multiples of 20% of the rail.
       -100% = rail's left edge at -20%, 500% = rail's left edge at
       100%. Transform is compositor-only — the old `left:` animation
       was re-running layout on every frame. */
    transform: translateX(-100%);
    animation: flipSweep 4.2s linear infinite;
    will-change: transform;
  }
  @keyframes flipSweep {
    from { transform: translateX(-100%); }
    to   { transform: translateX(500%);  }
