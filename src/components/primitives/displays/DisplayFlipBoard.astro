---
/*
  DisplayFlipBoard — two flavors of the same instrument panel.

  STANDALONE (blog/display-prototypes): solari split-flap tiles with
  heavy black cells, hinge-line seam, cream pixel glyphs. This is the
  "mechanical departure board" showcase the blog post is about.

  FUSED (/about passport): the whole dark strip reads as one typed
  telegram. The bezel is a sweep rail on top, a multi-line MRZ block
  in the middle, and a status footer at the bottom. Rows of the MRZ
  are joined edge-to-edge by dot-leader runs; cipher segments render
  [encrypted] in the served HTML and decode client-side on reveal.

  Stack order inside the bezel (top → bottom):

     1. .flip-bezel-rail — Top sweep rail (amber glow travelling the
                            bezel's width when paired with the status).
     2. .flip-mrz        — Multi-row typewriter MRZ block. Each row is
                            a flex line of segments separated by dot
                            leaders that flex-fill remaining width.
     3. .flip-status     — Footer bar: left pod = pulsing dot + LINK
                            status; sweep rule in the middle; right
                            pod = signal bars + live local clock.

  When `mrz` is present (`flip-bezel--paired`), both sweep rules
  (status middle + top rail) share a 5s clock: link runs L→R during
  the first half, then the top rail runs R→L during the second half.
  Reads as one amber glow cycling around the panel perimeter.

  `fused` prop collapses the module into the host card: no outer
  border, no side shadow, no screws — just a 2px top rule that acts as
  a continuous seam with the card's own border, and horizontal
  negative margin equal to the FoilCard's padding so the dark panel
  runs edge-to-edge.

  Hovering the MRZ block re-plays the scramble on every character at
  once. A data-animating flag on the block blocks re-entry until the
  current run settles, so repeated hovers can't pile up staggered
  copies of the animation.

  Email is decoded client-side from an XOR'd hex cipher; the raw
  address never appears in the served HTML.
*/

import { encodeContact } from "../../../lib/obfuscate";

interface Field {
  label: string;
  value: string;
  href?: string;
}

type MrzSegment =
  | { kind: "text"; value: string }
  /* Cipher segment: `label` renders as static prefix text, `display`
     is the placeholder shown until scramble-settle decodes to `email`.
     Email stays XOR-encoded in the served HTML (data-cfe). */
  | { kind: "cipher"; label?: string; display: string; email: string };

interface Props {
  fields?: Field[];
  email?: string;
  /* When true, the module removes its own border/shadow/screws and
     bleeds to the parent's edges so it reads as part of the card
     itself, joined by a single 2px seam. Also switches internal
     typography to the typewriter style. */
  fused?: boolean;
  /* MRZ rows for fused mode. Each row is an array of segments
     joined by dot leaders. Rendered as one typewriter block with a
     single hover-triggered scramble across all characters. */
  mrz?: MrzSegment[][];
  /* IANA timezone identifier (e.g. "America/Los_Angeles"). When set,
     the status footer renders a live HH:MM:SS clock in that
     timezone. This is what makes the passport feel "alive" —
     seconds tick where the subject lives. */
  timezone?: string;
}

const {
  fields = [],
  email,
  fused = false,
  mrz,
  timezone,
} = Astro.props;

const standaloneCipher = email ? encodeContact(email) : "";
const hasMrz = fused && !!mrz && mrz.length > 0;
const hasTelemetry = !!timezone;
---

<div class:list={["flip-board", fused && "flip-board--fused"]} data-flip-board>
  <div
    class:list={[
      "flip-bezel",
      hasMrz && "flip-bezel--paired",
    ]}
  >
    {
      !fused && (
        <>
          <div class="flip-screw" style="top:8px;left:8px" />
          <div class="flip-screw" style="top:8px;right:8px" />
          <div class="flip-screw" style="bottom:8px;left:8px" />
          <div class="flip-screw" style="bottom:8px;right:8px" />
        </>
      )
    }

    {
      hasMrz && (
        <div class="flip-bezel-rail">
          <span class="flip-sweep flip-sweep--mrz" />
        </div>
      )
    }

    {
      hasMrz && (
        <div class="flip-mrz" data-mrz>
          {mrz!.map((row) => (
            <div class="flip-mrz-row">
              {row.map((seg, i) => (
                <>
                  {i > 0 && <span class="flip-stamp-leader" />}
                  {seg.kind === "text" ? (
                    <span class="flip-mrz-seg" data-flip data-text={seg.value}>
                      {seg.value.split("").map((ch) => (
                        <span class="flap">{ch === " " ? " " : ch}</span>
                      ))}
                    </span>
                  ) : (
                    <span class="flip-mrz-seg flip-mrz-seg--cipher">
                      {seg.label && (
                        <span class="flip-mrz-label">{seg.label}</span>
                      )}
                      <a
                        class="flip-mrz-cipher"
                        href="#"
                        data-flip
                        data-cfe={encodeContact(seg.email)}
                      >
                        {seg.display.split("").map((ch) => (
                          <span class="flap">{ch}</span>
                        ))}
                      </a>
                    </span>
                  )}
                </>
              ))}
            </div>
          ))}
        </div>
      )
    }

    {
      !fused && (
        <div class="flip-grid">
          {fields.map((f) => (
            <div class="flip-col">
              <div class="flip-label">{f.label}</div>
              {f.href ? (
                <a
                  class="flip-value"
                  href={f.href}
                  data-flip
                  data-text={f.value}
                >
                  {f.value.split("").map((ch) => (
                    <span class="flap">{ch === " " ? " " : ch}</span>
                  ))}
                </a>
              ) : (
                <span class="flip-value" data-flip data-text={f.value}>
                  {f.value.split("").map((ch) => (
                    <span class="flap">{ch === " " ? " " : ch}</span>
                  ))}
                </span>
              )}
            </div>
          ))}

          <div class="flip-col flip-col--email">
            <div class="flip-label">Transmit</div>
            <a
              class="flip-value flip-value--email"
              href="#"
              data-flip
              data-cfe={standaloneCipher}
            >
              {"[encrypted]".split("").map((ch) => (
                <span class="flap">{ch}</span>
              ))}
            </a>
          </div>
        </div>
      )
    }

    <!-- Footer bar. Left pod: pulsing dot + LINK · 1200 BAUD · LOCKED.
         Middle: amber sweep rule. Right pod: signal bars + live local
         clock, rendered only when the `timezone` prop is passed. The
         clock is the "alive signal" — proves the document is being
         actively received, not stamped once and shelved. -->
    <div class="flip-status">
      <span class="flip-pod flip-pod--left">
        <span class="flip-dot" />
        <span class="flip-status-text">LINK · 1200 BAUD · LOCKED</span>
      </span>
      <span class="flip-sweep flip-sweep--link" />
      {
        hasTelemetry && (
          <span class="flip-pod flip-pod--right">
            <span class="flip-bars" aria-hidden="true">
              <span /><span /><span /><span />
            </span>
            <span class="flip-clock" data-flip-clock data-tz={timezone}>
              --:--:--
            </span>
          </span>
        )
      }
    </div>
  </div>
</div>

<script>
  function decodeCfe(hex: string): string {
    try {
      const k = parseInt(hex.substring(0, 2), 16);
      let out = "";
      for (let i = 2; i < hex.length; i += 2) {
        out += String.fromCharCode(parseInt(hex.substring(i, i + 2), 16) ^ k);
      }
      return out;
    } catch (_) {
      return "";
    }
  }

  // Mixed-case alphanumeric + punctuation that actually appears in our
  // targets. Avoids e.g. uppercase glyphs leaking into lowercase cells
  // and looking like visual noise.
  const CHARSET =
    "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789/.@·,-";

  function renderTo(el: HTMLElement, text: string) {
    el.innerHTML = "";
    for (const ch of text) {
      const span = document.createElement("span");
      span.className = "flap";
      span.textContent = ch === " " ? " " : ch;
      el.appendChild(span);
    }
  }

  function scrambleSettle(el: HTMLElement, target: string, speed = 38) {
    renderTo(el, target);
    const flaps = Array.from(el.querySelectorAll<HTMLElement>(".flap"));
    const targetChars = target.split("");
    const starts: number[] = flaps.map((_, i) => i * 4);
    const durations: number[] = flaps.map((_, i) => 14 + i * 2);
    let tick = 0;

    flaps.forEach((f) => f.classList.add("flap--flipping"));

    const iv = window.setInterval(() => {
      let settled = 0;
      flaps.forEach((flap, i) => {
        const local = tick - starts[i];
        if (local < 0) return;
        if (local >= durations[i]) {
          flap.textContent =
            targetChars[i] === " " ? " " : targetChars[i];
          flap.classList.remove("flap--flipping");
          settled++;
          return;
        }
        flap.textContent =
          CHARSET[Math.floor(Math.random() * CHARSET.length)];
      });
      tick++;
      if (settled === flaps.length) {
        window.clearInterval(iv);
      }
    }, speed);
  }

  /* Promise-returning wrapper — resolves when the scramble settles so
     the MRZ block-hover handler can await a full cycle before
     accepting another hover. */
  function scrambleSettleAsync(el: HTMLElement, target: string, speed = 38) {
    return new Promise<void>((resolve) => {
      renderTo(el, target);
      const flaps = Array.from(el.querySelectorAll<HTMLElement>(".flap"));
      const targetChars = target.split("");
      const starts: number[] = flaps.map((_, i) => i * 4);
      const durations: number[] = flaps.map((_, i) => 14 + i * 2);
      let tick = 0;

      flaps.forEach((f) => f.classList.add("flap--flipping"));

      const iv = window.setInterval(() => {
        let settled = 0;
        flaps.forEach((flap, i) => {
          const local = tick - starts[i];
          if (local < 0) return;
          if (local >= durations[i]) {
            flap.textContent =
              targetChars[i] === " " ? " " : targetChars[i];
            flap.classList.remove("flap--flipping");
            settled++;
            return;
          }
          flap.textContent =
            CHARSET[Math.floor(Math.random() * CHARSET.length)];
        });
        tick++;
        if (settled === flaps.length) {
          window.clearInterval(iv);
          resolve();
        }
      }, speed);
    });
  }

  function resolveCellTarget(cell: HTMLElement): string {
    const cipher = cell.getAttribute("data-cfe");
    if (cipher) return decodeCfe(cipher);
    return cell.getAttribute("data-text") || cell.textContent || "";
  }

  /* Kick off every cell at the same tick and resolve once all have
     settled. Used for whole-MRZ-block hover and reveal. */
  function scrambleCellsInParallel(cells: HTMLElement[]): Promise<void> {
    return Promise.all(
      cells.map((cell) => {
        const cipher = cell.getAttribute("data-cfe");
        const target = resolveCellTarget(cell);
        if (cipher && cell.tagName === "A") {
          cell.setAttribute("href", "mailto:" + target);
        }
        return scrambleSettleAsync(cell, target);
      }),
    ).then(() => undefined);
  }

  const boards = document.querySelectorAll<HTMLElement>("[data-flip-board]");

  boards.forEach((board) => {
    const mrzBlock = board.querySelector<HTMLElement>("[data-mrz]");
    /* In fused/MRZ mode the whole block is a single hover unit:
       all characters scramble in parallel and a data-animating flag
       blocks re-entry until the run completes. Standalone mode keeps
       per-cell hover for the original "each tile flips independently"
       feel. */
    if (mrzBlock) {
      const mrzCells = Array.from(
        mrzBlock.querySelectorAll<HTMLElement>("[data-flip]"),
      );
      mrzCells.forEach((cell) => {
        const cipher = cell.getAttribute("data-cfe");
        if (cipher && cell.tagName === "A") {
          cell.setAttribute("href", "mailto:" + decodeCfe(cipher));
        }
      });
      mrzBlock.addEventListener("pointerenter", async () => {
        if (mrzBlock.dataset.animating === "1") return;
        mrzBlock.dataset.animating = "1";
        await scrambleCellsInParallel(mrzCells);
        delete mrzBlock.dataset.animating;
      });
    } else {
      const cells = board.querySelectorAll<HTMLElement>("[data-flip]");
      cells.forEach((cell) => {
        const cipher = cell.getAttribute("data-cfe");
        const target = resolveCellTarget(cell);
        if (cipher && cell.tagName === "A") {
          cell.setAttribute("href", "mailto:" + target);
        }
        cell.addEventListener("pointerenter", () => {
          scrambleSettle(cell, target);
        });
      });
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            if (mrzBlock) {
              /* Initial reveal runs once, in parallel, under the same
                 lockout as hover. */
              if (mrzBlock.dataset.animating !== "1") {
                mrzBlock.dataset.animating = "1";
                const cells = Array.from(
                  mrzBlock.querySelectorAll<HTMLElement>("[data-flip]"),
                );
                scrambleCellsInParallel(cells).then(() => {
                  delete mrzBlock.dataset.animating;
                });
              }
            } else {
              entry.target
                .querySelectorAll<HTMLElement>("[data-flip]")
                .forEach((cell, i) => {
                  const cipher = cell.getAttribute("data-cfe");
                  const target = cipher
                    ? decodeCfe(cipher)
                    : cell.getAttribute("data-text") || "";
                  window.setTimeout(() => scrambleSettle(cell, target), i * 140);
                });
            }
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.4 },
    );
    io.observe(board);

    /* Live local clock in the status-bar right pod. One setInterval
       per clock element; the component currently renders at most one
       per page, but keeping the handler per-element keeps the code
       general and cheap. */
    const clocks = board.querySelectorAll<HTMLElement>("[data-flip-clock]");
    clocks.forEach((clock) => {
      const tz = clock.getAttribute("data-tz") || undefined;
      const fmt = new Intl.DateTimeFormat("en-GB", {
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit",
        hour12: false,
        timeZone: tz,
      });
      const tick = () => {
        clock.textContent = fmt.format(new Date());
      };
      tick();
      window.setInterval(tick, 1000);
    });
  });
</script>

<style>
  .flip-board {
    --flip-bg: #1a160f;
    --flip-ink: #f3e8c8;
    --flip-ink-dim: rgba(243, 232, 200, 0.55);
    --flip-ink-faint: rgba(243, 232, 200, 0.32);
    --flip-tile: #0f0c08;
    --flip-rule: rgba(243, 232, 200, 0.18);
    --flip-rule-soft: rgba(243, 232, 200, 0.08);
    --flip-amber: #f5b712;
    /* Per-character slot width. In standalone mode this is the flap
       tile width; in fused mode where flaps go chrome-less, it just
       sets the gap between OCR glyphs so scramble/settle never shifts
       alignment. */
    --flip-slot: 14px;

    margin-top: 32px;
  }

  .flip-bezel {
    position: relative;
    background: var(--flip-bg);
    border: 2px solid var(--rule);
    padding: 22px 24px 18px;
    box-shadow:
      3px 3px 0 var(--rule),
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      inset 0 -1px 0 rgba(0, 0, 0, 0.6);
  }

  /* Fused mode — the module becomes the card's bottom strip. Negative
     horizontal margin pulls the panel out to the card's border, then
     a 2px top rule (same weight as FoilCard's border) acts as the
     seam between paper and display. An inner hairline amber glow
     hugs the top rule so the strip reads as "powered" — a cold dark
     surface with a warm instrument glow leaking along the seam. */
  .flip-board--fused {
    margin: 32px calc(var(--foil-pad-x, 44px) * -1)
      calc(var(--foil-pad-b, 32px) * -1);
  }
  .flip-board--fused .flip-bezel {
    border: none;
    border-top: 2px solid var(--rule);
    box-shadow:
      inset 0 1px 0 rgba(245, 183, 18, 0.18),
      inset 0 -1px 0 rgba(0, 0, 0, 0.6);
    padding: 22px var(--foil-pad-x, 44px) 18px;
  }
  /* Subtle scanline wash ties the whole console together — one
     texture across MRZ, grid, and status rather than three bands.
     Kept very low contrast so it reads as a backlit screen, not a
     CRT filter. */
  .flip-board--fused .flip-bezel::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 2px,
      rgba(243, 232, 200, 0.015) 2px,
      rgba(243, 232, 200, 0.015) 3px
    );
    mix-blend-mode: screen;
  }
  .flip-board--fused .flip-bezel > * {
    position: relative;
  }

  .flip-screw {
    position: absolute;
    width: 6px;
    height: 6px;
    background: radial-gradient(
      circle at 30% 30%,
      #6d6353 0%,
      #2a241c 70%
    );
    border-radius: 50%;
    box-shadow:
      inset 0 0 0 1px rgba(0, 0, 0, 0.6),
      0 1px 0 rgba(255, 255, 255, 0.05);
  }
  .flip-screw::before {
    content: "";
    position: absolute;
    inset: 1px;
    background: linear-gradient(
      45deg,
      transparent 42%,
      rgba(0, 0, 0, 0.8) 42%,
      rgba(0, 0, 0, 0.8) 58%,
      transparent 58%
    );
  }

  /* --- Top sweep rail (fused mode) ---------------------------------
     Thin bare rule above the MRZ block. Carries only the travelling
     amber glow (no static gradient) so the rail looks empty until a
     sweep crosses it. Phased with the status-row sweep in paired
     mode so the glow reads as one light circling the panel.

     Negative margins pull the rail closer to the bezel edges —
     half the bezel's top (22px) and side (var(--foil-pad-x)) pads,
     so the rail hugs the seam and runs further out toward the
     corners without changing the bezel's own padding. */
  .flip-bezel-rail {
    position: relative;
    height: 1px;
    margin: -11px calc(var(--foil-pad-x, 44px) * -0.5) 22px;
  }
  .flip-bezel-rail .flip-sweep {
    position: absolute;
    inset: 0;
    flex: none;
    background: none;
  }

  /* --- MRZ block (fused mode) --------------------------------------
     Multi-row typewriter block. Each row is a flex line of segments
     joined by dot leaders that flex-fill remaining width. Whole block
     scrambles-in-parallel on hover under a lockout flag.

     Typewriter feel is built from four moves:
       1. Courier (not the site's JetBrains Mono) — wider, rounder,
          less "screen", more "ribbon-on-paper".
       2. Light ribbon-ink horizontal shadow — the faint halo left by
          a typed character impressing twice as the carriage advances.
       3. Slight letter-spacing — typewriters don't kern; each slug
          claims a fixed cell.
       4. The dot leaders themselves — that distinctive dot-dot-dot
          run between typed fields on forms/ledgers. */
  .flip-mrz {
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-family: "Courier New", Courier, monospace;
    font-weight: 500;
    font-size: clamp(11px, 1.3vw, 13px);
    letter-spacing: 0.08em;
    color: var(--flip-ink);
    line-height: 1;
    text-shadow: 0.3px 0 0 currentColor;
    cursor: default;
  }
  .flip-mrz-row {
    display: flex;
    align-items: center;
    gap: 10px;
    white-space: nowrap;
  }
  .flip-mrz-seg {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .flip-mrz-seg--cipher {
    gap: 6px;
  }
  /* Tiny label prefix for cipher segments ("XMIT", "COORD") — reads
     as the form-field name while the cipher is the typed value. */
  .flip-mrz-label {
    font-family: var(--font-pixel);
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--flip-ink-dim);
    /* Strip the ribbon halo from pixel label text; it only helps
       Courier glyphs. */
    text-shadow: none;
  }
  .flip-mrz-cipher {
    display: inline-flex;
    gap: 0;
    color: var(--flip-ink);
    text-decoration: none;
    /* Explicitly match the .flip-mrz Courier voice so <a>'s UA
       defaults don't drop the typewriter typography. */
    font-family: inherit;
    font-size: inherit;
    letter-spacing: inherit;
    text-shadow: inherit;
    font-variant-numeric: tabular-nums;
    cursor: pointer;
  }
  .flip-mrz-cipher:hover {
    color: var(--flip-amber);
  }
  /* Dot-leader run. Uses a repeating dot pattern via background-image
     so its density stays constant regardless of container width —
     a character-based approach would need a fixed font-size and
     would shift visually as the line reflows. */
  .flip-stamp-leader {
    flex: 1;
    min-width: 20px;
    height: 1em;
    background-image: radial-gradient(
      circle,
      var(--flip-ink-faint) 0.8px,
      transparent 1.2px
    );
    background-size: 0.6em 0.6em;
    background-position: center;
    background-repeat: repeat-x;
    align-self: center;
  }

  /* --- Grid (middle block) ------------------------------------------
     In fused mode this block carries the telemetry readouts: coord
     pair on the left, encrypted email on the right, nothing else
     fighting for room. */
  .flip-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 14px 40px;
    padding: 22px 0 14px;
  }

  .flip-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-width: 0;
  }
  @media (max-width: 520px) {
    .flip-col--email {
      grid-column: 1 / -1;
    }
  }

  .flip-label {
    font-family: var(--font-pixel);
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--flip-ink-dim);
  }

  .flip-value {
    display: inline-flex;
    gap: 2px;
    color: var(--flip-ink);
    text-decoration: none;
    font-family: var(--font-pixel);
    font-size: 13px;
    letter-spacing: 0.02em;
    line-height: 1;
    white-space: nowrap;
  }

  /* --- Flap cell base (standalone mode) ------------------------------
     Black tile with a horizontal hinge line. On fused mode we override
     to strip the chrome and let OCR glyphs breathe. */
  .flap {
    flex: 0 0 var(--flip-slot);
    position: relative;
    display: inline-grid;
    place-items: center;
    padding: 5px 0 4px;
    background: var(--flip-tile);
    color: inherit;
    border: 1px solid rgba(0, 0, 0, 0.9);
    box-shadow:
      inset 0 -1px 0 rgba(0, 0, 0, 0.7),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    background-image: linear-gradient(
      to bottom,
      transparent 0%,
      transparent calc(50% - 1px),
      rgba(0, 0, 0, 0.65) calc(50% - 1px),
      rgba(0, 0, 0, 0.65) 50%,
      rgba(255, 255, 255, 0.03) 50%,
      rgba(255, 255, 255, 0.03) calc(50% + 1px),
      transparent calc(50% + 1px)
    );
    transform-origin: center;
    transition: color 0.15s ease;
  }

  /* In fused/typewriter mode the "flaps" become clean ribbon-typed
     glyphs — no tile background, no border, no hinge line. The
     scramble-settle rotateX still plays but now reads as keys
     striking, not cards turning. Same Courier + light ink-bleed
     treatment as the stamp line, so the whole console speaks one
     typewriter voice. */
  .flip-board--fused .flip-value {
    font-family: "Courier New", Courier, monospace;
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.08em;
    gap: 0;
    /* Tabular digits so settled values don't shimmy by 0.5px. */
    font-variant-numeric: tabular-nums;
