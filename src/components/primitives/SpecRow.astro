---
/*
  SpecRow - a single dt/dd pair inside a SpecList.

  The label prop renders the dt column. Everything in the default slot
  becomes the dd value — keeping the slot lets rows contain rich content
  like <em>, <a>, etc. without a separate "rich" variant.
*/

interface Props {
  label: string;
  class?: string;
}

const { label, class: className = "" } = Astro.props;
---

<div class:list={["spec-row", className]}>
  <dt>{label}</dt>
  <dd><slot /></dd>
</div>

<style>
  .spec-row {
    display: grid;
    grid-template-columns: 90px 1fr;
    align-items: baseline;
    gap: 20px;
    padding: 14px 0;
    border-top: 1px solid var(--rule-soft);
  }
  .spec-row:first-child {
    border-top: none;
    padding-top: 0;
  }
  .spec-row:last-child {
    padding-bottom: 0;
  }
  dt {
    font-family: var(--font-pixel);
    font-size: 10px;
    color: var(--ink-muted);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  dd {
    margin: 0;
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 20,
      "SOFT" 60,
      "wght" 500;
    font-size: 18px;
    color: var(--ink);
    line-height: 1.35;
  }
  dd :global(em) {
    font-style: italic;
    color: var(--em);
  }
</style>
