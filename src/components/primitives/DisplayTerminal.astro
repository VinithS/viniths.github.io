---
/*
  DisplayTerminal — vintage CRT console line at the bottom of the card.

  A single-window amber-on-black terminal that types its prompts line
  by line on mount, then sits with a blinking caret. The email is
  decrypted only when the user hovers the TRANSMIT line — before that
  it shows a string of ciphertext characters in a dim foreground.

  Small CRT theatrics: scanlines, a barely-perceptible sync roll
  (translateY on a ::before overlay), slight chromatic bloom on lit
  text, a noise dither on the glass. Everything is CSS except the
  type-in, caret, and decrypt — which need JS anyway.
*/

import { encodeContact } from "../../lib/obfuscate";

interface Field {
  label: string;
  value: string;
  href?: string;
}

interface Props {
  // Kept for interface-parity with the other Display* prototypes even
  // though this one composes its own lines. Makes sandbox swaps trivial.
  fields: Field[];
  email: string;
}

const { email } = Astro.props;
const emailCipher = encodeContact(email);

// Cipher shown before decrypt — a deterministic stand-in sized from
// the ciphertext so the terminal shows something stable on mount and
// avoids layout jump when the real text lands.
const emailPreview = "░".repeat(
  Math.max(8, Math.min(22, Math.floor(emailCipher.length / 4))),
);
---

<div class="term-board" data-term-board>
  <div class="term-chrome">
    <div class="term-chrome-left">
      <span class="term-dot term-dot--red"></span>
      <span class="term-dot term-dot--yellow"></span>
      <span class="term-dot term-dot--green"></span>
      <span class="term-title">observer@cosmos:~$</span>
    </div>
    <div class="term-chrome-right">
      <span>SIG ██▇▅▂</span>
      <span class="term-sep">·</span>
      <span>ENC AES-128</span>
      <span class="term-sep">·</span>
      <span>REC ●</span>
    </div>
  </div>

  <div class="term-screen" data-term-screen>
    <div class="term-glare"></div>
    <div class="term-scan"></div>
    <div class="term-roll"></div>

    <div class="term-body" data-term-body>
      <div class="term-line" data-term-line data-type="VINITH REGISTRY · CH-01 · 2026">
        <span class="term-prompt">$</span>
        <span class="term-text"></span>
      </div>
      <div class="term-line" data-term-line data-type="———————————————————————">
        <span class="term-text term-text--muted"></span>
      </div>

      {
        [
          { prompt: "get", key: "writing",  href: "/blog",   slug: "/WRITING" },
          { prompt: "get", key: "photos",   href: "/photos", slug: "/PHOTOS" },
          { prompt: "get", key: "notes",    href: "/tweets", slug: "/NOTES"  },
        ].map((l) => (
          <div
            class="term-line term-line--link"
            data-term-line
            data-type={`${l.prompt} ${l.key.padEnd(8, " ")} --> `}
            data-link={l.href}
            data-link-text={l.slug}
          >
            <span class="term-prompt">$</span>
            <span class="term-text"></span>
            <a class="term-link" href={l.href} tabindex="-1"></a>
          </div>
        ))
      }

      <div
        class="term-line term-line--link term-line--email"
        data-term-line
        data-type={`pgp transmit --decrypt `}
        data-cfe={emailCipher}
        data-preview={emailPreview}
      >
        <span class="term-prompt">$</span>
        <span class="term-text"></span>
        <a class="term-link" href="#" tabindex="-1"></a>
      </div>

      <div class="term-line term-line--idle" data-term-idle>
        <span class="term-prompt">$</span>
        <span class="term-text"></span>
        <span class="term-caret"></span>
      </div>
    </div>
  </div>
</div>

<script>
  function decodeCfe(hex: string): string {
    try {
      const k = parseInt(hex.substring(0, 2), 16);
      let out = "";
      for (let i = 2; i < hex.length; i += 2) {
        out += String.fromCharCode(parseInt(hex.substring(i, i + 2), 16) ^ k);
      }
      return out;
    } catch (_) {
      return "";
    }
  }

  async function typeInto(
    el: HTMLElement,
    text: string,
    speed = 22,
  ): Promise<void> {
    return new Promise((resolve) => {
      let i = 0;
      const iv = window.setInterval(() => {
        el.textContent = text.substring(0, i + 1);
        i++;
        if (i >= text.length) {
          window.clearInterval(iv);
          resolve();
        }
      }, speed);
    });
  }

  const boards = document.querySelectorAll<HTMLElement>("[data-term-board]");

  boards.forEach((board) => {
    const lines = Array.from(
      board.querySelectorAll<HTMLElement>("[data-term-line]"),
    );
    const idle = board.querySelector<HTMLElement>("[data-term-idle]");

    const reduce = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    const runLine = async (line: HTMLElement) => {
      const head = line.getAttribute("data-type") || "";
      const textEl = line.querySelector<HTMLElement>(".term-text")!;
      if (reduce) {
        textEl.textContent = head;
      } else {
        await typeInto(textEl, head, 18);
      }

      const linkHref = line.getAttribute("data-link");
      const linkText = line.getAttribute("data-link-text");
      const anchor = line.querySelector<HTMLAnchorElement>(".term-link");
      if (anchor && linkHref && linkText) {
        if (reduce) {
          anchor.textContent = linkText;
        } else {
          await typeInto(anchor, linkText, 14);
        }
        anchor.href = linkHref;
      }

      const cfe = line.getAttribute("data-cfe");
      if (anchor && cfe) {
        const preview = line.getAttribute("data-preview") || "";
        anchor.textContent = preview;
        anchor.dataset.cfe = cfe;
        anchor.addEventListener("pointerenter", () => {
          if (anchor.dataset.decrypted) return;
          const real = decodeCfe(cfe);
          anchor.dataset.decrypted = "1";
          // Scramble-decrypt effect: random glyphs → real char
          const chars = "@#%&/<>*+░▒▓█?".split("");
          const steps = 10;
          let step = 0;
          const total = real.length;
          const iv = window.setInterval(() => {
            step++;
            let out = "";
            for (let i = 0; i < total; i++) {
              if (i < (step / steps) * total) {
                out += real[i];
              } else {
                out += chars[Math.floor(Math.random() * chars.length)];
              }
            }
            anchor.textContent = out;
            if (step >= steps) {
              window.clearInterval(iv);
              anchor.textContent = real;
              anchor.href = "mailto:" + real;
            }
          }, 40);
        });
      }
    };

    const io = new IntersectionObserver(
      async (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          io.unobserve(entry.target);
          if (idle) idle.style.opacity = "0";
          for (const line of lines) {
            await runLine(line);
            if (!reduce) {
              await new Promise((r) => window.setTimeout(r, 60));
            }
          }
          if (idle) idle.style.opacity = "1";
        }
      },
      { threshold: 0.4 },
    );
    io.observe(board);
  });
</script>

<style>
  .term-board {
    --term-bg: #09070a;
    --term-screen: #0c0a08;
    --term-amber: #ffb347;
    --term-amber-soft: rgba(255, 179, 71, 0.75);
    --term-amber-dim: rgba(255, 179, 71, 0.35);
    --term-glow: 0 0 2px rgba(255, 179, 71, 0.8),
      0 0 6px rgba(255, 140, 0, 0.35);

    margin-top: 32px;
  }

  .term-chrome {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #161210;
    border: 2px solid var(--rule);
    border-bottom: none;
    padding: 8px 12px;
    font-family: var(--font-pixel);
    font-size: 9px;
    letter-spacing: 0.18em;
    color: rgba(255, 179, 71, 0.6);
    text-transform: uppercase;
  }
  .term-chrome-left,
  .term-chrome-right {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .term-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    box-shadow: inset 0 1px 1px rgba(0, 0, 0, 0.6);
  }
  .term-dot--red    { background: #e06b4a; }
  .term-dot--yellow { background: #e0a94a; }
  .term-dot--green  { background: #7aa95a; }
  .term-title { margin-left: 10px; color: var(--term-amber-soft); }
  .term-sep { opacity: 0.4; }

  .term-screen {
    position: relative;
    background: var(--term-screen);
    border: 2px solid var(--rule);
    padding: 16px 20px 20px;
    box-shadow:
      3px 3px 0 var(--rule),
      inset 0 0 0 1px rgba(255, 179, 71, 0.05),
      inset 0 0 40px rgba(0, 0, 0, 0.9);
    overflow: hidden;
    isolation: isolate;
  }

  /* CRT phosphor glare: soft radial highlight, top-left */
  .term-glare {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 3;
    background: radial-gradient(
      ellipse 60% 40% at 20% 10%,
      rgba(255, 179, 71, 0.09) 0%,
      transparent 60%
    );
    mix-blend-mode: screen;
  }

  /* Scanlines */
  .term-scan {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    background: repeating-linear-gradient(
      0deg,
      transparent 0px,
      transparent 2px,
      rgba(0, 0, 0, 0.35) 2px,
      rgba(0, 0, 0, 0.35) 3px
    );
    mix-blend-mode: multiply;
  }

  /* Sync roll — a rare slow drift that hints at a bad sync signal */
  .term-roll {
    position: absolute;
    left: 0;
    right: 0;
    top: -20%;
    height: 40%;
    pointer-events: none;
    z-index: 4;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(255, 179, 71, 0.02) 40%,
      rgba(255, 179, 71, 0.06) 50%,
      rgba(255, 179, 71, 0.02) 60%,
      transparent 100%
    );
    mix-blend-mode: screen;
    animation: termRoll 9s linear infinite;
  }
  @keyframes termRoll {
    0%, 70%, 100% { transform: translateY(200%); opacity: 0; }
    72%          { opacity: 1; }
    99%          { transform: translateY(-120%); opacity: 0; }
  }

  .term-body {
    position: relative;
    z-index: 1;
    font-family: var(--font-pixel);
    font-size: 12px;
    line-height: 1.9;
    letter-spacing: 0.06em;
    color: var(--term-amber-soft);
    text-shadow: var(--term-glow);
    min-height: 180px;
  }

  .term-line {
    display: flex;
    align-items: baseline;
    gap: 10px;
    white-space: pre;
  }
  .term-prompt {
    color: var(--term-amber);
    text-shadow: 0 0 3px rgba(255, 140, 0, 0.6);
    flex-shrink: 0;
  }
  .term-text {
    color: var(--term-amber-soft);
    white-space: pre;
  }
  .term-text--muted {
    color: var(--term-amber-dim);
  }

  .term-link {
    color: var(--term-amber);
    text-decoration: none;
    text-shadow: var(--term-glow);
    position: relative;
    cursor: pointer;
  }
  .term-line--link .term-link::before {
    content: "";
    position: absolute;
    left: 0; right: 0;
    bottom: -1px;
    height: 1px;
    background: currentColor;
    opacity: 0.3;
    transform: scaleX(0.5);
    transform-origin: left;
    transition: opacity 0.2s, transform 0.2s;
  }
  .term-line--link:hover .term-link::before {
    opacity: 1;
    transform: scaleX(1);
  }
  .term-line--link:hover .term-link {
    color: #ffd28a;
  }

  .term-line--idle {
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .term-caret {
    display: inline-block;
    width: 8px;
    height: 14px;
    background: var(--term-amber);
    box-shadow: 0 0 5px rgba(255, 140, 0, 0.8);
    animation: termCaret 1s steps(2, end) infinite;
    vertical-align: middle;
  }
  @keyframes termCaret {
    50% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .term-roll,
    .term-caret {
      animation: none !important;
    }
  }
</style>
