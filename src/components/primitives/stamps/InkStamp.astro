---
/*
  InkStamp - a rubber-stamped icon. Uses an external SVG as an alpha
  mask so the stamp takes on a single ink color (`accent`), ignoring
  the SVG's own fills. The shared #rubber-ink filter (defined in
  Layout.astro) jitters edges and erases speckles so it reads as
  pressed rubber, not printed icon.

  For multi-color stamps (e.g. a stylized scene with colored parts),
  use a dedicated SVG component instead — masks are single-channel.

  Props:
    - src         URL of the source SVG to mask
    - accent      one of the palette colors (default red)
    - size        px size of the stamp
    - rotate      degrees of rotation, for that hand-pressed look
    - label       accessible text (also exposed as title)
    - class       forwarded to the root element
*/

interface Props {
  src: string;
  accent?: "red" | "yellow" | "blue" | "green";
  size?: number;
  rotate?: number;
  label?: string;
  class?: string;
}

const {
  src,
  accent = "red",
  size = 96,
  rotate = 0,
  label,
  class: className = "",
} = Astro.props;
---

<span
  class:list={["ink-stamp", `ink-stamp--${accent}`, className]}
  style={`--ink-stamp-size: ${size}px; --ink-stamp-rotate: ${rotate}deg; --ink-stamp-src: url("${src}");`}
  role={label ? "img" : undefined}
  aria-label={label}
  aria-hidden={label ? undefined : "true"}
  title={label}
></span>

<style>
  .ink-stamp {
    display: inline-block;
    width: var(--ink-stamp-size);
    height: var(--ink-stamp-size);
    background: var(--stamp-color);
    -webkit-mask: var(--ink-stamp-src) no-repeat center / contain;
    mask: var(--ink-stamp-src) no-repeat center / contain;
    transform: rotate(var(--ink-stamp-rotate));
    transform-origin: center;
    user-select: none;
    pointer-events: none;
    /* Rubber-ink filter jitters/erodes the silhouette; drop-shadow on
       top gives the bleed halo. Chaining them in one `filter` value
       makes the shadow respect the filtered shape. */
    filter: url(#rubber-ink)
      drop-shadow(0 0 0.6px color-mix(in oklab, var(--stamp-color) 60%, transparent));
  }

  .ink-stamp--red {
    --stamp-color: var(--red);
  }
  .ink-stamp--yellow {
    --stamp-color: var(--yellow);
  }
  .ink-stamp--blue {
    --stamp-color: var(--blue);
  }
  .ink-stamp--green {
    --stamp-color: var(--green);
  }
</style>
