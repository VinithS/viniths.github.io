---
/*
  FoilCard - a document pressed on holographic foil stock.

  The shell handles everything pointer-reactive:
    .stamp    shaped foil watermark (SVG-masked conic gradient)
    .foil     static diagonal hairline grain (paper stock, always visible)
    .holo     subtle full-card iridescent wash, cursor shifts the hue
    .gloss    specular cursor highlight, overlay blend

  A small inline script tracks the pointer and drives CSS custom
  properties. Unitless companions (--mxn, --myn, 0..100) are emitted
  alongside the %-suffixed --mx/--my so gradient angles can be
  computed as calc(var(--mxn) * 3.6deg).

  Slots:
    - default: content "printed" on top of the foil
    - corner:  absolutely-positioned decoration at the top-right
               (stamps, seals, ribbons)

  Props:
    - ticks       render corner viewfinder L-brackets (default true)
    - tilt        enable pointer-driven 3D rotation (default true)
    - maxWidth    card max-width, number (px) or CSS value
    - stampSrc    URL of an SVG to use as the foil-stamp shape.
                  If unset, no stamp layer is rendered.
    - class       forwarded to the outer article
*/

interface Props {
  ticks?: boolean;
  tilt?: boolean;
  maxWidth?: number | string;
  stampSrc?: string;
  class?: string;
}

const {
  ticks = true,
  tilt = true,
  maxWidth = 880,
  stampSrc,
  class: className = "",
} = Astro.props;

const styleMaxWidth =
  typeof maxWidth === "number" ? `${maxWidth}px` : maxWidth;

const inlineStyle = stampSrc
  ? `--foil-max-width: ${styleMaxWidth}; --stamp-src: url("${stampSrc}");`
  : `--foil-max-width: ${styleMaxWidth};`;
---

<article
  class:list={["foil-card", className]}
  data-foil-card
  data-tilt={tilt ? "" : undefined}
  style={inlineStyle}
>
  <span class="foil" aria-hidden="true"></span>
  {stampSrc && <span class="stamp" aria-hidden="true" />}
  <span class="holo" aria-hidden="true"></span>
  <span class="gloss" aria-hidden="true"></span>

  {
    ticks && (
      <>
        <span class="tick tick--tl" aria-hidden="true" />
        <span class="tick tick--tr" aria-hidden="true" />
        <span class="tick tick--bl" aria-hidden="true" />
        <span class="tick tick--br" aria-hidden="true" />
      </>
    )
  }

  <div class="foil-content">
    <slot name="corner" />
    <slot />
  </div>
</article>

<script>
  // Pointer-tracked foil glint. One handler per .foil-card element on the
  // page so multiple cards can coexist. The rect is recomputed on enter
  // / resize / scroll to stay accurate during layout shifts.
  const cards = document.querySelectorAll<HTMLElement>("[data-foil-card]");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  cards.forEach((card) => {
    let raf = 0;
    let rect: DOMRect | null = null;
    const tilt = card.hasAttribute("data-tilt");

    const recompute = () => {
      rect = card.getBoundingClientRect();
    };
    recompute();
    window.addEventListener("resize", recompute);
    window.addEventListener("scroll", recompute, { passive: true });

    const onMove = (e: PointerEvent) => {
      if (!rect) return;
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => {
        const x = e.clientX - rect!.left;
        const y = e.clientY - rect!.top;
        const px = Math.max(0, Math.min(100, (x / rect!.width) * 100));
        const py = Math.max(0, Math.min(100, (y / rect!.height) * 100));
        card.style.setProperty("--mx", `${px}%`);
        card.style.setProperty("--my", `${py}%`);
        // Unitless companions so calc() can multiply by deg/px.
        card.style.setProperty("--mxn", `${px}`);
        card.style.setProperty("--myn", `${py}`);
        card.style.setProperty("--active", "1");
        if (tilt && !reduce) {
          const rx = (0.5 - y / rect!.height) * 8;
          const ry = (x / rect!.width - 0.5) * 10;
          card.style.setProperty("--rx", `${rx}deg`);
          card.style.setProperty("--ry", `${ry}deg`);
        }
      });
    };

    const onLeave = () => {
      card.style.setProperty("--active", "0");
      card.style.setProperty("--rx", "0deg");
      card.style.setProperty("--ry", "0deg");
    };

    card.addEventListener("pointerenter", recompute);
    card.addEventListener("pointermove", onMove);
    card.addEventListener("pointerleave", onLeave);
  });
</script>

<style>
  .foil-card {
    --mx: 50%;
    --my: 50%;
    --mxn: 50;
    --myn: 50;
    --active: 0;
    --rx: 0deg;
    --ry: 0deg;

    position: relative;
    width: 100%;
    max-width: var(--foil-max-width);
    background: var(--bg-card);
    border: 2px solid var(--rule);
    box-shadow:
      8px 8px 0 var(--rule),
      0 30px 60px -30px rgba(0, 0, 0, 0.35);
    padding: 0;
    overflow: hidden;
    isolation: isolate;
    transform: rotateX(var(--rx)) rotateY(var(--ry));
    transform-style: preserve-3d;
    transition:
      transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 0.4s ease;
    will-change: transform;
  }
  .foil-card:hover {
    box-shadow:
      10px 10px 0 var(--rule),
      0 40px 80px -30px rgba(0, 0, 0, 0.55);
  }
  .foil,
  .stamp,
  .holo,
  .gloss {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .foil {
    z-index: 0;
    opacity: 0.55;
    background:
      repeating-linear-gradient(
        115deg,
        transparent 0px,
        transparent 2px,
        var(--rule-xsoft) 2px,
        var(--rule-xsoft) 3px
      ),
      repeating-linear-gradient(
        25deg,
        transparent 0px,
        transparent 7px,
        var(--rule-xsoft) 7px,
        var(--rule-xsoft) 8px
      );
    mix-blend-mode: multiply;
  }

  /* Shaped foil stamp — an SVG masks a conic iridescent gradient so
     only the stamp's silhouette takes on the foil, like real hot-stamp
     foil pressed into paper. Cursor rotates the gradient's hue axis. */
  .stamp {
    z-index: 1;
    /* Gently brighter when the cursor is over the card, but always
       visible so it reads as a printed watermark, not a screen effect. */
    opacity: calc(0.55 + var(--active) * 0.35);
    transition: opacity 0.45s cubic-bezier(0.2, 0.8, 0.2, 1);
    mix-blend-mode: screen;
    background: conic-gradient(
      from calc(var(--mxn) * 3.6deg) at 50% 50%,
      var(--red) 0deg,
      var(--yellow) 72deg,
      var(--green) 144deg,
      var(--blue) 216deg,
      var(--red) 288deg,
      var(--red) 360deg
    );
    /* Size the stamp shape to ~62% of the card, centered. */
    -webkit-mask: var(--stamp-src) no-repeat center / 62% auto;
    mask: var(--stamp-src) no-repeat center / 62% auto;
  }

  /* Continuous iridescent wash across the whole card — the "foil
     backing" of the paper. Cursor shifts the hue axis so it breathes
     without a hard hotspot. */
  .holo {
    z-index: 2;
    opacity: calc(0.18 + var(--active) * 0.22);
    transition: opacity 0.45s cubic-bezier(0.2, 0.8, 0.2, 1);
    mix-blend-mode: screen;
    background: conic-gradient(
      from calc(var(--mxn) * 3.6deg) at var(--mx) var(--my),
      var(--red) 0deg,
      var(--yellow) 90deg,
      var(--green) 180deg,
      var(--blue) 270deg,
      var(--red) 360deg
    );
    filter: blur(40px) saturate(1.2);
  }

  .gloss {
    z-index: 3;
    opacity: calc(var(--active) * 1);
    transition: opacity 0.45s cubic-bezier(0.2, 0.8, 0.2, 1);
    mix-blend-mode: overlay;
    background: radial-gradient(
      ellipse 55% 65% at var(--mx) var(--my),
      rgba(255, 245, 220, 0.38) 0%,
      rgba(255, 245, 220, 0) 45%
    );
  }

  /* Corner viewfinder ticks sit above foil/hologram but below content. */
  .tick {
    position: absolute;
    width: 14px;
    height: 14px;
    z-index: 4;
    pointer-events: none;
  }
  .tick--tl {
    top: 14px;
    left: 14px;
    border-top: 2px solid var(--rule);
    border-left: 2px solid var(--rule);
  }
  .tick--tr {
    top: 14px;
    right: 14px;
    border-top: 2px solid var(--rule);
    border-right: 2px solid var(--rule);
  }
  .tick--bl {
    bottom: 14px;
    left: 14px;
    border-bottom: 2px solid var(--rule);
    border-left: 2px solid var(--rule);
  }
  .tick--br {
    bottom: 14px;
    right: 14px;
    border-bottom: 2px solid var(--rule);
    border-right: 2px solid var(--rule);
  }

  .foil-content {
    position: relative;
    z-index: 5;
    padding: 44px 44px 32px;
  }

  /* Theme tuning: dark dusk paper swallows color, push foil harder.
     Light cream burns out faster, ease it off. */
  :global(:root[data-theme="dark"]) .stamp {
    opacity: calc(0.7 + var(--active) * 0.3);
    mix-blend-mode: color-dodge;
  }
  :global(:root[data-theme="dark"]) .holo {
    opacity: calc(0.22 + var(--active) * 0.25);
    mix-blend-mode: color-dodge;
  }
  :global(:root[data-theme="dark"]) .gloss {
    mix-blend-mode: soft-light;
  }
  :global(:root[data-theme="light"]) .stamp {
    opacity: calc(0.45 + var(--active) * 0.3);
  }
  :global(:root[data-theme="light"]) .holo {
    opacity: calc(0.14 + var(--active) * 0.18);
  }

  @media (prefers-reduced-motion: reduce) {
    .foil-card {
      transition: none;
      transform: none !important;
    }
  }

  @media (max-width: 860px) {
    .foil-content {
      padding: 36px 28px 26px;
    }
  }
  @media (max-width: 720px) {
    .foil-content {
      padding: 30px 22px 22px;
    }
    .tick {
      width: 10px;
      height: 10px;
    }
    .tick--tl,
    .tick--tr {
      top: 10px;
    }
    .tick--bl,
    .tick--br {
      bottom: 10px;
    }
    .tick--tl,
    .tick--bl {
      left: 10px;
    }
    .tick--tr,
    .tick--br {
      right: 10px;
    }
  }
</style>
