---
/*
  FoilCard — a document pressed on holographic foil stock.

  Layer stack (bottom → top), all pointer-events: none:

    .mark-shine  wide rainbow band masked by the stamp SVG. The band
                 itself is a fixed linear gradient; the cursor only
                 drives its transform, so paint stays compositor-only.
                 In dark mode the mask is dropped so the rainbow
                 floods the whole card.

  Prior versions used conic gradients with `from calc(var(--mxn)*deg)`
  on two layers plus a 40px blur. Every pointermove invalidated the
  gradient caches and re-ran the blur pass — the main source of card-
  hover stutter. The current design touches only transforms, so cost
  is dominated by the one-time gradient rasterization at mount.

  Slots:
    - default: content "printed" on top of the foil
    - corner:  absolutely-positioned decoration at the top-right

  Props:
    - ticks     render corner viewfinder L-brackets (default true)
    - tilt      enable pointer-driven 3D rotation (default true)
    - maxWidth  card max-width, number (px) or CSS value
    - stampSrc  URL of an SVG to use as the foil-stamp silhouette.
                Without it, the card is just paper + tilt.
    - class     forwarded to the outer article
*/

interface Props {
  ticks?: boolean;
  tilt?: boolean;
  maxWidth?: number | string;
  stampSrc?: string;
  class?: string;
}

const {
  ticks = true,
  tilt = true,
  maxWidth = 880,
  stampSrc,
  class: className = "",
} = Astro.props;

const styleMaxWidth =
  typeof maxWidth === "number" ? `${maxWidth}px` : maxWidth;

const inlineStyle = stampSrc
  ? `--foil-max-width: ${styleMaxWidth}; --stamp-src: url("${stampSrc}");`
  : `--foil-max-width: ${styleMaxWidth};`;
---

<article
  class:list={["foil-card", className]}
  data-foil-card
  data-tilt={tilt ? "" : undefined}
  style={inlineStyle}
>
  {
    stampSrc && (
      <span class="mark-shine" aria-hidden="true">
        <span class="shine-band" />
      </span>
    )
  }

  {
    ticks && (
      <>
        <span class="tick tick--tl" aria-hidden="true" />
        <span class="tick tick--tr" aria-hidden="true" />
        <span class="tick tick--bl" aria-hidden="true" />
        <span class="tick tick--br" aria-hidden="true" />
      </>
    )
  }

  <div class="foil-content">
    <slot name="corner" />
    <slot />
  </div>
</article>

<script>
  // Pointer-tracked foil glint. One handler per .foil-card element on the
  // page so multiple cards can coexist. The rect is recomputed on enter
  // / resize / scroll to stay accurate during layout shifts.
  const cards = document.querySelectorAll<HTMLElement>("[data-foil-card]");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  cards.forEach((card) => {
    let raf = 0;
    let rect: DOMRect | null = null;
    const tilt = card.hasAttribute("data-tilt");

    const recompute = () => {
      rect = card.getBoundingClientRect();
    };
    recompute();
    window.addEventListener("resize", recompute);
    window.addEventListener("scroll", recompute, { passive: true });

    const onMove = (e: PointerEvent) => {
      // While a stamp is armed, the card should stay inert. The CSS
      // also pins --rx/--ry/--active to 0 via [data-stamp-armed], but
      // returning here skips the rect math + style writes on every
      // trackpad pointermove while aiming a stamp.
      if (document.documentElement.hasAttribute("data-stamp-armed")) return;
      if (!rect) return;
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => {
        const x = e.clientX - rect!.left;
        const y = e.clientY - rect!.top;
        const px = Math.max(0, Math.min(100, (x / rect!.width) * 100));
        const py = Math.max(0, Math.min(100, (y / rect!.height) * 100));
        // Unitless so calc() can multiply by % in the shine-band
        // transform without unit-juggling.
        card.style.setProperty("--mxn", `${px}`);
        card.style.setProperty("--myn", `${py}`);
        card.style.setProperty("--active", "1");
        if (tilt && !reduce) {
          const rx = (0.5 - y / rect!.height) * 8;
          const ry = (x / rect!.width - 0.5) * 10;
          card.style.setProperty("--rx", `${rx}deg`);
          card.style.setProperty("--ry", `${ry}deg`);
        }
      });
    };

    const onLeave = () => {
      card.style.setProperty("--active", "0");
      card.style.setProperty("--rx", "0deg");
      card.style.setProperty("--ry", "0deg");
    };

    card.addEventListener("pointerenter", recompute);
    card.addEventListener("pointermove", onMove);
    card.addEventListener("pointerleave", onLeave);
  });
</script>

<style>
  .foil-card {
    --mxn: 50;
    --myn: 50;
    --active: 0;
    --rx: 0deg;
    --ry: 0deg;

    /* Per-theme knobs for the wisteria shine. Light defaults here;
       the dark override block redefines them further down. Keeping
       the knobs on .foil-card means component rules read one set of
       vars and don't have to fork by theme. */
    --wisteria-shine-mask:      var(--stamp-src) no-repeat 50% 180% / 62% auto;
    --wisteria-shine-opacity:   0.1;
    --wisteria-shine-blend:     multiply;
    --wisteria-shine-saturate:  1.5;

    position: relative;
    width: 100%;
    max-width: var(--foil-max-width);
    background: var(--bg-card);
    border: 2px solid var(--rule);
    box-shadow:
      8px 8px 0 var(--rule),
      0 30px 60px -30px rgba(0, 0, 0, 0.35);
    padding: 0;
    overflow: hidden;
    isolation: isolate;
    transform: rotateX(var(--rx)) rotateY(var(--ry));
    transform-style: preserve-3d;
    transition:
      transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 0.4s ease;
    will-change: transform;
    /* Keep repaints on descendants (ObserverStatus spinner, flipboard
       animations) from leaking up to parent layers. */
    contain: layout paint;
  }
  .foil-card:hover {
    box-shadow:
      10px 10px 0 var(--rule),
      0 40px 80px -30px rgba(0, 0, 0, 0.55);
  }

  /* Rainbow wash. In light mode it's clipped to the wisteria
     silhouette (shine lives inside the leaves). In dark mode the
     mask is `none`, so the rainbow floods the whole card. */
  .mark-shine {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
    -webkit-mask: var(--wisteria-shine-mask);
    mask: var(--wisteria-shine-mask);
    opacity: calc(var(--wisteria-shine-opacity) * (0.78 + var(--active) * 0.22));
    mix-blend-mode: var(--wisteria-shine-blend);
    transition: opacity 0.45s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  /* The rainbow. Oversized so transform can pan it without exposing
     an edge. Gradient is *static* — the browser rasterizes it once and
     the cursor only shifts the transform. That's the whole point of
     this rewrite: no gradient interpolation on the hot path.

     Horizontal buffer is -100% on each side (band is 3x the card's
     width). With the pan math below capped at ±25% of the band's own
     width, the card never reaches the edge of the gradient at any
     cursor position. */
  .shine-band {
    position: absolute;
    inset: -30% -100%;
    background: linear-gradient(
      100deg,
      var(--red)    0%,
      var(--yellow) 18%,
      var(--green)  36%,
      var(--blue)   54%,
      var(--red)    72%,
      var(--yellow) 90%,
      var(--red)   100%
    );
    /* --mxn/--myn are 0..100 unitless. (mxn - 50) * -0.5% gives ±25%
       of the band's own width (which, at 3x card width, equals ±75%
       of the card width) — plenty of pan without ever exposing a band
       edge. Vertical pan is smaller so the band mostly slides
       left/right as the pointer traverses the card. */
    transform: translate3d(
      calc((var(--mxn) - 50) * -0.5%),
      calc((var(--myn) - 50) * -0.3%),
      0
    );
    will-change: transform;
    filter: saturate(var(--wisteria-shine-saturate));
  }

  /* Corner viewfinder ticks — above the foil, below content. */
  .tick {
    position: absolute;
    width: 14px;
    height: 14px;
    z-index: 4;
    pointer-events: none;
  }
  .tick--tl {
    top: 14px;
    left: 14px;
    border-top: 2px solid var(--rule);
    border-left: 2px solid var(--rule);
  }
  .tick--tr {
    top: 14px;
    right: 14px;
    border-top: 2px solid var(--rule);
    border-right: 2px solid var(--rule);
  }
  .tick--bl {
    bottom: 14px;
    left: 14px;
    border-bottom: 2px solid var(--rule);
    border-left: 2px solid var(--rule);
  }
  .tick--br {
    bottom: 14px;
    right: 14px;
    border-bottom: 2px solid var(--rule);
    border-right: 2px solid var(--rule);
  }

  .foil-content {
    /* Expose padding as vars so slotted content (like a fused digital
       display that bleeds to the card's edges) can negative-margin by
       the exact right amount without duplicating these media queries. */
    --foil-pad-x: 44px;
    --foil-pad-t: 44px;
    --foil-pad-b: 32px;

    position: relative;
    z-index: 5;
    padding: var(--foil-pad-t) var(--foil-pad-x) var(--foil-pad-b);
  }

  /* Dark-mode knobs. Drop the shine mask so the rainbow paints the
     whole card. Saturation is pulled way down so the rainbow reads
     as a warm iridescent wash, not a crayon-box flood that fights
     with the passport content sitting on top of it. */
  :global(:root[data-theme="dark"]) .foil-card {
    --wisteria-shine-mask:     var(--stamp-src) no-repeat 50% 180% / 62% auto;
    --wisteria-shine-opacity:  0.35;
    --wisteria-shine-blend:    normal;
    --wisteria-shine-saturate: 1.5;
  }

  /* While a stamp is armed on the page, freeze the card flat. Keeps
     the card from tilting or glinting under the stamping ghost cursor.
     Inherited transform transition on .foil-card makes this a smooth
     "lock/wake" between armed and disarmed. */
  :global(:root[data-stamp-armed]) .foil-card {
    --rx: 0deg;
    --ry: 0deg;
    --active: 0;
  }
  :global(:root[data-stamp-armed]) .foil-card:hover {
    box-shadow:
      8px 8px 0 var(--rule),
      0 30px 60px -30px rgba(0, 0, 0, 0.35);
  }

  @media (prefers-reduced-motion: reduce) {
    .foil-card {
      transition: none;
      transform: none !important;
    }
    .shine-band {
      transform: none !important;
    }
  }

  @media (max-width: 860px) {
    .foil-content {
      --foil-pad-x: 28px;
      --foil-pad-t: 36px;
      --foil-pad-b: 26px;
    }
  }
  @media (max-width: 720px) {
    .foil-content {
      --foil-pad-x: 22px;
      --foil-pad-t: 30px;
      --foil-pad-b: 22px;
    }
    .tick {
      width: 10px;
      height: 10px;
    }
    .tick--tl,
    .tick--tr {
      top: 10px;
    }
    .tick--bl,
    .tick--br {
      bottom: 10px;
    }
    .tick--tl,
    .tick--bl {
      left: 10px;
    }
    .tick--tr,
    .tick--br {
      right: 10px;
    }
  }
</style>
