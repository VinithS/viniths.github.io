---
/*
  HoloShine — the iridescent-foil paint, decoupled from layout.

  Renders three absolutely-positioned layers (two conic gradients +
  a faint engraved grid) inside a relatively-positioned host. The
  host opts in by carrying `data-holo-host`; the Shine's script finds
  all hosts on the page and attaches rAF-throttled pointer handlers
  that write --mx / --my to the host. CSS vars inherit into the
  child layers, so panning the gradients is pure compositor work.

  Performance notes (same lessons from FoilCard's rewrite):
    - Gradients are static. Browser rasterizes them once at mount;
      no calc()-in-stops means the gradient cache never invalidates.
    - No filter:blur on the hot path.
    - pointermove is rAF-coalesced and the rect is cached per-enter.

  Host requirements:
    - position: relative (so absolute shine layers nest inside)
    - overflow: hidden (so oversized gradient doesn't spill)
    - isolation: isolate is recommended to keep shine's blend modes
      from reaching into siblings

  Prop:
    intensity — "subtle" (default) for in-context accents like a
                serial pill, or "full" for decorative patches where
                the foil is the point.
*/

interface Props {
  intensity?: "subtle" | "full";
}

const { intensity = "subtle" } = Astro.props;
---

<span
  class:list={["holo-shine-stack", `holo-shine-stack--${intensity}`]}
  aria-hidden="true"
>
  <span class="holo-shine-a"></span>
  <span class="holo-shine-b"></span>
  <span class="holo-shine-grid"></span>
</span>

<script>
  /*
    One attach pass for the whole page. Every [data-holo-host] gets
    the same rAF-throttled handler. Rect is cached on pointerenter
    and invalidated lazily (next enter re-measures) on scroll/resize.
  */
  const hosts = document.querySelectorAll<HTMLElement>("[data-holo-host]");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  hosts.forEach((host) => {
    if (reduce) return;

    let raf = 0;
    let rect: DOMRect | null = null;

    const invalidate = () => {
      rect = null;
    };
    const recompute = () => {
      rect = host.getBoundingClientRect();
    };

    host.addEventListener("pointerenter", recompute);
    host.addEventListener("pointermove", (e: PointerEvent) => {
      if (!rect) recompute();
      if (!rect) return;
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => {
        const mx = ((e.clientX - rect!.left) / rect!.width) * 2 - 1;
        const my = ((e.clientY - rect!.top) / rect!.height) * 2 - 1;
        const cx = Math.max(-1, Math.min(1, mx));
        const cy = Math.max(-1, Math.min(1, my));
        host.style.setProperty("--mx", cx.toFixed(3));
        host.style.setProperty("--my", cy.toFixed(3));
      });
    });
    host.addEventListener("pointerleave", () => {
      cancelAnimationFrame(raf);
      host.style.setProperty("--mx", "0");
      host.style.setProperty("--my", "0");
    });
    window.addEventListener("resize", invalidate);
    window.addEventListener("scroll", invalidate, { passive: true });
  });
</script>

<style>
  /* Host reads these from inherited vars. Defaults here so the
     Shine renders sensibly even before the first pointermove. */
  .holo-shine-stack {
    --mx: 0;
    --my: 0;
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .holo-shine-a,
  .holo-shine-b {
    position: absolute;
    inset: -60%;
    background: conic-gradient(
      from 10deg,
      #ff4a7d,
      #ffa64a,
      #f5d93a,
      #3ad48a,
      #4ab0ff,
      #a64aff,
      #ff4a7d
    );
    transform: translate3d(
      calc(var(--mx) * 6px),
      calc(var(--my) * 6px),
      0
    );
    mix-blend-mode: multiply;
    will-change: transform;
  }
  .holo-shine-b {
    background: conic-gradient(
      from 150deg,
      #4ab0ff,
      #a64aff,
      #ff4a7d,
      #ffa64a,
      #f5d93a,
      #3ad48a,
      #4ab0ff
    );
    transform: translate3d(
      calc(var(--mx) * -10px),
      calc(var(--my) * -10px),
      0
    );
    mix-blend-mode: screen;
  }

  /* Guilloché-ish ruling so the shine isn't pure rainbow —
     gives the surface texture at small sizes where the conic
     stops would otherwise read as washed-out peach. */
  .holo-shine-grid {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        90deg,
        var(--rule-soft) 0 1px,
        transparent 1px 4px
      ),
      repeating-linear-gradient(
        0deg,
        var(--rule-soft) 0 1px,
        transparent 1px 4px
      );
    mix-blend-mode: multiply;
  }

  /* Intensity knobs — "subtle" for in-context accents (serial pill),
     "full" for decorative patches. The same tokens drive both
     themes; per-theme blend-mode overrides live below. */
  .holo-shine-stack--subtle .holo-shine-a { opacity: 0.18; }
  .holo-shine-stack--subtle .holo-shine-b { opacity: 0.12; }
  .holo-shine-stack--subtle .holo-shine-grid { opacity: 0.12; }

  .holo-shine-stack--full .holo-shine-a { opacity: 0.55; }
  .holo-shine-stack--full .holo-shine-b { opacity: 0.35; }
  .holo-shine-stack--full .holo-shine-grid { opacity: 0.25; }

  /* Dark theme — multiply on dusk paper eats color; switch
     blend modes so the rainbow still reads. Per-theme override
     stays next to the component it affects (FoilCard precedent). */
  :root[data-theme="dark"] .holo-shine-a { mix-blend-mode: screen; }
  :root[data-theme="dark"] .holo-shine-b { mix-blend-mode: overlay; }
  :root[data-theme="dark"] .holo-shine-grid { mix-blend-mode: screen; }

  :root[data-theme="dark"] .holo-shine-stack--subtle .holo-shine-a { opacity: 0.2; }
  :root[data-theme="dark"] .holo-shine-stack--subtle .holo-shine-b { opacity: 0.13; }
  :root[data-theme="dark"] .holo-shine-stack--subtle .holo-shine-grid { opacity: 0.08; }

  :root[data-theme="dark"] .holo-shine-stack--full .holo-shine-a { opacity: 0.65; }
  :root[data-theme="dark"] .holo-shine-stack--full .holo-shine-b { opacity: 0.45; }
  :root[data-theme="dark"] .holo-shine-stack--full .holo-shine-grid { opacity: 0.18; }
</style>
