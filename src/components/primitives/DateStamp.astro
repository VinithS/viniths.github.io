---
/*
  DateStamp - a circular postal cancellation stamp with a ring of
  curved text + the current date in the middle + cancellation bars.
  Multicolor: ring/bars in one accent, date in another.

  The date is rendered at build time via `new Date()` in frontmatter.
  For "last updated" this is usually what you want — it says when the
  page was last published, not when the visitor is viewing.

  Props:
    - ringText    text that curves around the ring (will be repeated
                  to fill). Default "RECEIVED · OBSERVABLE UNIVERSE · "
    - ringAccent  color for ring + bars
    - dateAccent  color for the centered date
    - size        px size of the stamp
    - rotate      degrees of rotation
*/

interface Props {
  ringText?: string;
  ringAccent?: "red" | "yellow" | "blue" | "green";
  dateAccent?: "red" | "yellow" | "blue" | "green";
  size?: number;
  rotate?: number;
  class?: string;
}

const {
  ringText = "RECEIVED · OBSERVABLE UNIVERSE · ",
  ringAccent = "red",
  dateAccent = "green",
  size = 120,
  rotate = 0,
  class: className = "",
} = Astro.props;

const now = new Date();
const months = ["JAN", "FEB", "MAR", "APR", "MAY", "JUN", "JUL", "AUG", "SEP", "OCT", "NOV", "DEC"];
const dd = String(now.getDate()).padStart(2, "0");
const mmm = months[now.getMonth()];
const yyyy = now.getFullYear();

// Repeat the ring text enough to wrap the circle fully.
const fullRing = (ringText.repeat(3)).slice(0, 72);
---

<span
  class:list={["date-stamp", `date-stamp--ring-${ringAccent}`, `date-stamp--date-${dateAccent}`, className]}
  style={`--date-stamp-size: ${size}px; --date-stamp-rotate: ${rotate}deg;`}
  aria-label={`Received ${dd} ${mmm} ${yyyy}`}
  role="img"
>
  <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <defs>
      <!-- Ring path for the curved text. Slightly inset so letters sit
           just inside the outer circle. -->
      <path
        id="date-stamp-ring"
        d="M 50 50 m -38, 0 a 38,38 0 1,1 76,0 a 38,38 0 1,1 -76,0"
      />
    </defs>

    <!-- Outer + inner rings -->
    <circle cx="50" cy="50" r="46" class="ring"/>
    <circle cx="50" cy="50" r="43" class="ring ring--thin"/>

    <!-- Curved ring text -->
    <text class="ring-text">
      <textPath href="#date-stamp-ring" startOffset="0">{fullRing}</textPath>
    </text>

    <!-- Horizontal bars above + below the date, like a postmark -->
    <line x1="16" y1="38" x2="84" y2="38" class="bar"/>
    <line x1="16" y1="62" x2="84" y2="62" class="bar"/>

    <!-- Date block, centered -->
    <text x="50" y="53" class="date-day">{dd}</text>
    <text x="50" y="46" class="date-mmm">{mmm}</text>
    <text x="50" y="60" class="date-yyyy">{yyyy}</text>
  </svg>
</span>

<style>
  .date-stamp {
    display: inline-block;
    width: var(--date-stamp-size);
    height: var(--date-stamp-size);
    transform: rotate(var(--date-stamp-rotate));
    transform-origin: center;
    filter: url(#rubber-ink)
      drop-shadow(0 0 0.6px color-mix(in oklab, var(--ring-color) 50%, transparent));
    user-select: none;
    pointer-events: none;
  }

  .date-stamp svg {
    display: block;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .ring,
  .bar {
    fill: none;
    stroke: var(--ring-color);
  }
  .ring {
    stroke-width: 1.6;
  }
  .ring--thin {
    stroke-width: 0.5;
  }
  .bar {
    stroke-width: 0.8;
  }

  .ring-text {
    fill: var(--ring-color);
    font-family: var(--font-pixel);
    font-size: 6.2px;
    letter-spacing: 0.22em;
  }

  .date-day,
  .date-mmm,
  .date-yyyy {
    fill: var(--date-color);
    font-family: var(--font-pixel);
    text-anchor: middle;
  }
  .date-day {
    font-size: 11px;
    letter-spacing: 0.04em;
  }
  .date-mmm {
    font-size: 5px;
    letter-spacing: 0.22em;
  }
  .date-yyyy {
    font-size: 5px;
    letter-spacing: 0.22em;
  }

  .date-stamp--ring-red { --ring-color: var(--red); }
  .date-stamp--ring-yellow { --ring-color: var(--yellow); }
  .date-stamp--ring-blue { --ring-color: var(--blue); }
  .date-stamp--ring-green { --ring-color: var(--green); }

  .date-stamp--date-red { --date-color: var(--red); }
  .date-stamp--date-yellow { --date-color: var(--yellow); }
  .date-stamp--date-blue { --date-color: var(--blue); }
  .date-stamp--date-green { --date-color: var(--green); }
</style>
