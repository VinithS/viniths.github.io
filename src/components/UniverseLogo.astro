---
/*
  Dithered three-tone black hole.
  - Event horizon (central shadow) uses --ink.
  - Accretion disk uses the accent color (defaults to yellow — hot plasma).
  - Dither halo is the same accent at lower opacity — a pixel falloff glow.

  Rendered as SVG rects with shape-rendering: crispEdges so it stays
  pixel-sharp at any size.
*/

interface Props {
  size?: number;
  accent?: "red" | "yellow" | "blue" | "green";
  class?: string;
}

const {
  size = 56,
  accent = "yellow",
  class: className = "",
} = Astro.props;
---

<div
  class:list={["universe-logo", `universe-logo--${accent}`, className]}
  style={`--logo-size: ${size}px;`}
  aria-hidden="true"
>
  <svg
    viewBox="0 0 40 24"
    shape-rendering="crispEdges"
    xmlns="http://www.w3.org/2000/svg"
  >
    <g class="dither">
      <rect x="16" y="2"  width="8" height="2" />
      <rect x="8"  y="6"  width="4" height="2" />
      <rect x="28" y="6"  width="4" height="2" />
      <rect x="0"  y="8"  width="2" height="2" />
      <rect x="38" y="8"  width="2" height="2" />
      <rect x="0"  y="14" width="2" height="2" />
      <rect x="38" y="14" width="2" height="2" />
      <rect x="8"  y="16" width="4" height="2" />
      <rect x="28" y="16" width="4" height="2" />
      <rect x="16" y="20" width="8" height="2" />
    </g>

    <g class="disk">
      <rect x="2"  y="8"  width="10" height="2" />
      <rect x="28" y="8"  width="10" height="2" />
      <rect x="0"  y="10" width="12" height="4" />
      <rect x="28" y="10" width="12" height="4" />
      <rect x="2"  y="14" width="10" height="2" />
      <rect x="28" y="14" width="10" height="2" />
    </g>

    <g class="horizon">
      <rect x="16" y="4"  width="8"  height="2" />
      <rect x="14" y="6"  width="12" height="2" />
      <rect x="12" y="8"  width="16" height="8" />
      <rect x="14" y="16" width="12" height="2" />
      <rect x="16" y="18" width="8"  height="2" />
    </g>
  </svg>
</div>

<style>
  .universe-logo {
    display: inline-block;
    width: var(--logo-size);
    line-height: 0;
    flex-shrink: 0;
  }
  .universe-logo svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .universe-logo--red    { --logo-accent: var(--red); }
  .universe-logo--yellow { --logo-accent: var(--yellow); }
  .universe-logo--blue   { --logo-accent: var(--blue); }
  .universe-logo--green  { --logo-accent: var(--green); }

  .disk    { fill: var(--logo-accent); }
  .dither  { fill: var(--logo-accent); opacity: 0.5; }
  .horizon { fill: var(--ink); }
</style>
