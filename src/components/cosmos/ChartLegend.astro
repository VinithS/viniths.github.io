---
/*
  Pinned paper-card legend at the chart's lower-left.
*/
---

<div class="legend">
  <div class="row"><b>SIZE</b> &middot; POST COUNT</div>
  <div class="row"><b>HALO</b> &middot; RECENT ACTIVITY</div>
  <div class="row"><b>LINE</b> &middot; SHARED POSTS</div>
  <div class="rule"></div>
  <div class="row swatches">
    <span class="sw" style="background: var(--type-essay);"></span>ESSAY
    <span class="sw" style="background: var(--type-prototype);"></span>PROTO
    <span class="sw" style="background: var(--type-note);"></span>NOTE
  </div>
</div>

<style>
  .legend {
    position: absolute;
    bottom: 30px; left: 30px;
    background: var(--bg-raised);
    border: 1px solid var(--rule);
    box-shadow: 2px 2px 0 var(--rule);
    padding: 9px 12px 8px;
    font-family: var(--font-pixel);
    font-size: 8px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ink-muted);
    display: grid; gap: 4px;
    z-index: 6;
    transform: rotate(-1.2deg);
  }
  .legend::before {
    content: "";
    position: absolute;
    top: -3px; left: -3px;
    width: 6px; height: 6px;
    background: var(--yellow);
    border: 1px solid var(--rule);
  }
  .row { display: flex; align-items: center; gap: 8px; }
  .row b { color: var(--ink); font-weight: 400; }
  .rule { height: 1px; background: var(--rule-soft); margin: 3px 0 1px; }
  .swatches { gap: 6px; }
  .sw { display: inline-block; width: 9px; height: 9px; box-shadow: 0 0 0 1px var(--rule); }
</style>
