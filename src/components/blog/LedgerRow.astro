---
/*
  LedgerRow — single ledger entry.

  Layout (grid 3-col):
    [stamp 92px] [kicker / title / desc — column 2 stacks them] [date · tags — column 3]
  The stamp is wrapped in a focusable anchor with [data-atlas-anchor=...]
  so AtlasCard.svelte can hook hover/focus events to it.

  rotation is derived from the slug so adjacent rows don't tilt the
  same way without manual fiddling.
*/

import ConstellationStamp from "./ConstellationStamp.astro";
import AtlasCard from "./AtlasCard.svelte";
import { POST_TYPE_LABEL, type PostType } from "../../lib/post-types";
import { skyFor } from "../../lib/sky";

interface Props {
  href: string;
  title: string;
  description: string;
  tags?: string[];
  date: Date;
  type: PostType;
  slug: string;
}

const { href, title, description, tags = [], date, type, slug } = Astro.props;
const sky = skyFor(slug, date);
const anchorId = `atlas-${slug}`;

// rotation: hash slug to ±3deg
let h = 0;
for (let i = 0; i < slug.length; i++) h = (h * 31 + slug.charCodeAt(i)) >>> 0;
const rotation = (((h % 60) - 30) / 10).toFixed(1); // -3.0 .. +2.9 deg

const dateLabel = date
  .toLocaleDateString("en-US", { year: "numeric", month: "2-digit", day: "2-digit" })
  .replace(/\//g, "·");
---

<li class="row">
  <a class="anchor" href={href} data-atlas-anchor={anchorId} aria-label={`${title} — ${POST_TYPE_LABEL[type]}`}>
    <div class="stamp" style={`transform: rotate(${rotation}deg);`}>
      <ConstellationStamp sky={sky} variant="mark" type={type} ariaLabel={sky.named ? sky.name : sky.designation} />
    </div>
  </a>
  <div class="content">
    <span class={`kicker kicker--${type}`}>
      <span class="pip"></span>{POST_TYPE_LABEL[type]}
    </span>
    <a class="title" href={href}>{title}</a>
    <span class="desc">{description}</span>
  </div>
  <div class="aside">
    <span class="date">{dateLabel}</span>
    {tags.length > 0 && (
      <div class="tags">
        {tags.map((t) => <span class="tag-pixel">{t}</span>)}
      </div>
    )}
  </div>
</li>

<AtlasCard sky={sky} anchorId={anchorId} type={type} client:idle />

<style>
  .row {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 92px 1fr 140px;
    gap: 22px;
    align-items: start;
    padding: 18px 4px;
    list-style: none;
  }
  /* Engraved separator: shadow line + highlight line stacked, fading
     out toward each end. Lives on the row's top edge so every entry
     carries one; :first-child is suppressed so the first row doesn't
     pick up a separator at the top. The :last-of-type rule mirrors
     the same crease at the bottom of the final row. */
  .row::before,
  .row::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    height: 1px;
    pointer-events: none;
  }
  .row::before {
    top: 0;
    background: linear-gradient(
      to right,
      transparent 0%,
      var(--crease-shadow) 12%,
      var(--crease-shadow) 88%,
      transparent 100%
    );
  }
  .row::after {
    top: 1px;
    background: linear-gradient(
      to right,
      transparent 0%,
      var(--crease-highlight) 12%,
      var(--crease-highlight) 88%,
      transparent 100%
    );
  }
  .row:first-child::before,
  .row:first-child::after {
    display: none;
  }

  .anchor {
    display: block;
    width: 78px;
    aspect-ratio: 1 / 1;
    text-decoration: none;
    margin-top: 4px;
  }
  .stamp { width: 100%; height: 100%; display: block; transition: transform 0.2s ease; }
  .anchor:hover .stamp,
  .anchor:focus-visible .stamp {
    transform: rotate(0deg) !important;
  }

  .content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .kicker {
    display: flex; align-items: center; gap: 8px;
    width: fit-content;
    font-family: var(--font-pixel); font-size: 9px;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 8px;
  }
  .kicker .pip {
    width: 8px; height: 8px;
    box-shadow: 0 0 0 1px var(--rule);
  }
  .kicker--essay     .pip { background: var(--type-essay); }
  .kicker--prototype .pip { background: var(--type-prototype); }
  .kicker--note      .pip { background: var(--type-note); }
  .kicker--photo     .pip { background: var(--type-photo); }

  .title {
    display: block;
    font-family: var(--font-serif);
    font-variation-settings: "opsz" 32, "SOFT" 60, "wght" 500;
    font-size: 22px;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.015em;
    line-height: 1.15;
  }
  .title:hover { color: var(--link-hover); }

  .desc {
    display: block;
    font-family: var(--font-serif);
    font-variation-settings: "opsz" 14, "SOFT" 70, "wght" 380;
    font-size: 14px;
    color: var(--ink-muted);
    margin-top: 4px;
    max-width: 58ch;
  }

  .aside {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
    margin-top: 4px;
  }

  .date {
    font-family: var(--font-pixel);
    font-size: 11px;
    color: var(--ink-muted);
    letter-spacing: 0.1em;
    text-align: right;
  }

  .tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: flex-end;
    max-width: 140px;
  }

  @media (max-width: 720px) {
    .row { grid-template-columns: 78px 1fr; gap: 14px; }
    .aside { grid-column: 2; align-items: flex-start; flex-direction: row; flex-wrap: wrap; gap: 10px; margin-top: 8px; }
    .tags { justify-content: flex-start; max-width: none; }
  }
</style>
