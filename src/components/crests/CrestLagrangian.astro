---
/*
  CrestLagrangian — three-body triangle of Lagrangian points.
  Three vertex nodes (ink) connected by dotted orbital lines
  (accent @ 0.5) around a small central sun (accent). The
  geometry reads as L1/L4/L5 — the gravitational meeting points.
*/

interface Props {
  size?: number;
  accent?: "red" | "yellow" | "blue" | "green";
  class?: string;
}

const {
  size = 52,
  accent = "yellow",
  class: className = "",
} = Astro.props;
---

<div
  class:list={["crest", `crest--${accent}`, className]}
  style={`--crest-size: ${size}px;`}
  aria-hidden="true"
>
  <svg
    viewBox="0 0 40 40"
    shape-rendering="crispEdges"
    xmlns="http://www.w3.org/2000/svg"
  >
    <g class="orbit">
      <rect x="14" y="14" width="2" height="2"/>
      <rect x="18" y="14" width="2" height="2"/>
      <rect x="22" y="14" width="2" height="2"/>
      <rect x="10" y="18" width="2" height="2"/>
      <rect x="12" y="22" width="2" height="2"/>
      <rect x="14" y="26" width="2" height="2"/>
      <rect x="16" y="30" width="2" height="2"/>
      <rect x="28" y="18" width="2" height="2"/>
      <rect x="26" y="22" width="2" height="2"/>
      <rect x="24" y="26" width="2" height="2"/>
      <rect x="22" y="30" width="2" height="2"/>
    </g>

    <g class="node">
      <rect x="4"  y="10" width="6" height="6"/>
      <rect x="30" y="10" width="6" height="6"/>
      <rect x="17" y="30" width="6" height="6"/>
    </g>

    <g class="node-ring">
      <rect x="2"  y="12" width="2" height="2"/>
      <rect x="10" y="12" width="2" height="2"/>
      <rect x="28" y="12" width="2" height="2"/>
      <rect x="36" y="12" width="2" height="2"/>
      <rect x="15" y="32" width="2" height="2"/>
      <rect x="23" y="32" width="2" height="2"/>
    </g>

    <g class="sun">
      <rect x="18" y="20" width="4" height="4"/>
    </g>

    <g class="sun-halo">
      <rect x="20" y="18" width="2" height="2"/>
      <rect x="18" y="18" width="2" height="2"/>
      <rect x="18" y="24" width="4" height="2"/>
      <rect x="16" y="20" width="2" height="4"/>
      <rect x="22" y="20" width="2" height="4"/>
    </g>
  </svg>
</div>

<style>
  .crest {
    display: inline-block;
    width: var(--crest-size);
    line-height: 0;
    flex-shrink: 0;
  }
  .crest svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .crest--red    { --crest-accent: var(--red); }
  .crest--yellow { --crest-accent: var(--yellow); }
  .crest--blue   { --crest-accent: var(--blue); }
  .crest--green  { --crest-accent: var(--green); }

  .node      { fill: var(--ink); }
  .node-ring { fill: var(--ink); opacity: 0.35; }
  .orbit     { fill: var(--crest-accent); opacity: 0.7; }
  .sun       { fill: var(--crest-accent); }
  .sun-halo  { fill: var(--crest-accent); opacity: 0.4; }
</style>
