---
/*
  CrestHeliocentric — sun at center, pixel-stepped orbit, a single
  marked planet at the 2-o'clock position. The local cosmic
  authority: our sun, our witnesses.
*/

interface Props {
  size?: number;
  accent?: "red" | "yellow" | "blue" | "green";
  class?: string;
}

const {
  size = 52,
  accent = "yellow",
  class: className = "",
} = Astro.props;
---

<div
  class:list={["crest", `crest--${accent}`, className]}
  style={`--crest-size: ${size}px;`}
  aria-hidden="true"
>
  <svg
    viewBox="0 0 40 40"
    shape-rendering="crispEdges"
    xmlns="http://www.w3.org/2000/svg"
  >
    <g class="orbit">
      <rect x="14" y="6"  width="12" height="2"/>
      <rect x="10" y="8"  width="4"  height="2"/>
      <rect x="26" y="8"  width="4"  height="2"/>
      <rect x="8"  y="10" width="2"  height="2"/>
      <rect x="30" y="10" width="2"  height="2"/>
      <rect x="6"  y="12" width="2"  height="2"/>
      <rect x="32" y="12" width="2"  height="2"/>
      <rect x="4"  y="14" width="2"  height="12"/>
      <rect x="34" y="14" width="2"  height="12"/>
      <rect x="6"  y="26" width="2"  height="2"/>
      <rect x="32" y="26" width="2"  height="2"/>
      <rect x="8"  y="28" width="2"  height="2"/>
      <rect x="30" y="28" width="2"  height="2"/>
      <rect x="10" y="30" width="4"  height="2"/>
      <rect x="26" y="30" width="4"  height="2"/>
      <rect x="14" y="32" width="12" height="2"/>
    </g>

    <g class="ray">
      <rect x="19" y="10" width="2" height="2"/>
      <rect x="19" y="28" width="2" height="2"/>
      <rect x="10" y="19" width="2" height="2"/>
      <rect x="28" y="19" width="2" height="2"/>
    </g>

    <g class="sun">
      <rect x="17" y="14" width="6" height="2"/>
      <rect x="15" y="16" width="10" height="8"/>
      <rect x="17" y="24" width="6" height="2"/>
    </g>

    <g class="sun-core">
      <rect x="17" y="18" width="6" height="4"/>
    </g>

    <g class="planet">
      <rect x="28" y="8" width="4" height="4"/>
    </g>

    <g class="planet-ring">
      <rect x="26" y="10" width="2" height="2"/>
      <rect x="32" y="10" width="2" height="2"/>
    </g>
  </svg>
</div>

<style>
  .crest {
    display: inline-block;
    width: var(--crest-size);
    line-height: 0;
    flex-shrink: 0;
  }
  .crest svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .crest--red    { --crest-accent: var(--red); }
  .crest--yellow { --crest-accent: var(--yellow); }
  .crest--blue   { --crest-accent: var(--blue); }
  .crest--green  { --crest-accent: var(--green); }

  .orbit       { fill: var(--ink); opacity: 0.35; }
  .ray         { fill: var(--crest-accent); opacity: 0.6; }
  .sun         { fill: var(--crest-accent); }
  .sun-core    { fill: var(--ink); opacity: 0.3; }
  .planet      { fill: var(--ink); }
  .planet-ring { fill: var(--ink); opacity: 0.4; }
</style>
