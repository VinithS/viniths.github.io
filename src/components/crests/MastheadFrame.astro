---
/*
  MastheadFrame — typographic wrapper for the about-card header.
  Tri-column: crest | text | serial. The serial pill carries an
  optional barcode-masked rainbow watermark that pans with the
  parent FoilCard's cursor vars, matching the wisteria stamp's
  shine language.
*/

interface SerialItem {
  k: string;
  v: string;
}

interface Props {
  institution: string;
  department?: string;
  /* Tiny all-caps eyebrow above the institution — optional. */
  kicker?: string;
  /* Italic serif tagline under the institution — optional. */
  tagline?: string;
  serial?: SerialItem[];
  /* Paints a barcode-masked rainbow behind the serial pill. Reads
     --mxn/--myn from an ancestor FoilCard so the shine pans with
     the cursor without this component wiring its own handler. */
  holo?: boolean;
  /* Thin rule under the whole masthead. Default true. */
  rule?: boolean;
}

const {
  institution,
  department,
  kicker,
  tagline,
  serial,
  holo = false,
  rule = true,
} = Astro.props;
---

<header class:list={["masthead", rule && "masthead--ruled"]}>
  <div class="crest-slot">
    <slot name="crest" />
  </div>

  <div class="text">
    {kicker && <div class="kicker">{kicker}</div>}
    <div class="institution">{institution}</div>
    {department && <div class="department">{department}</div>}
    {tagline && (
      <div class="tagline">
        <em>{tagline}</em>
      </div>
    )}
  </div>

  {
    serial && serial.length > 0 && (
      <div class:list={["serial", holo && "serial--holo"]}>
        {holo && (
          <span class="serial-barcode" aria-hidden="true">
            <span class="serial-barcode-band" />
          </span>
        )}
        <span class="serial-text">
          {serial.map((s, i) => (
            <>
              {i > 0 && <span class="serial-sep">·</span>}
              <span class="serial-k">{s.k}</span>
              <span class="serial-v">{s.v}</span>
            </>
          ))}
        </span>
      </div>
    )
  }
</header>

<style>
  .masthead {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 18px;
    padding-bottom: 20px;
    margin-bottom: 28px;
  }
  .masthead--ruled {
    border-bottom: 1px solid var(--rule-soft);
  }
  .crest-slot {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .text {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  /* Bureau register: stentorian, wide opsz, uppercase — reads like
     a carved lintel. The only masthead shape the site uses; variants
     for other registers were dropped in favor of inlining anything
     experimental in its own prototype page. */
  .institution {
    font-family: var(--font-serif);
    color: var(--ink);
    line-height: 1.02;
    font-variation-settings: "opsz" 96, "SOFT" 20, "wght" 500;
    font-size: 22px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  /* Kicker gets structural "document header" chrome: bullet pip +
     dashed leader. Pairs with the editorial-italic department line
     below so the two meta rows flank the title in different
     registers (structural vs. editorial). */
  .kicker {
    font-family: var(--font-pixel);
    font-size: 9px;
    color: var(--ink-muted);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }
  .kicker::before {
    content: "";
    flex: 0 0 auto;
    width: 5px;
    height: 5px;
    background: var(--yellow);
    box-shadow: 0 0 0 1px var(--rule);
  }
  .kicker::after {
    content: "";
    flex: 1 1 auto;
    min-width: 32px;
    max-width: 180px;
    height: 1px;
    background-image: linear-gradient(
      to right,
      var(--rule-soft) 0 50%,
      transparent 50% 100%
    );
    background-size: 4px 1px;
    background-repeat: repeat-x;
  }

  .department {
    font-family: var(--font-serif);
    font-variation-settings: "opsz" 18, "SOFT" 80, "wght" 400;
    font-style: italic;
    font-size: 14px;
    letter-spacing: 0.005em;
    color: var(--ink-soft);
    margin-top: 4px;
  }

  .tagline {
    margin-top: 4px;
    font-family: var(--font-serif);
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.2;
  }
  .tagline :global(em) {
    font-style: italic;
    color: var(--em);
    font-variation-settings: "opsz" 18, "SOFT" 80, "wght" 400;
  }

  .serial {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 6px 10px;
    background: var(--bg-inset);
    border: 1px solid var(--rule-soft);
    font-family: var(--font-pixel);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink);
    white-space: nowrap;
  }
  /* Holographic serial: barcode-masked rainbow behind the text,
     dashed perforation rails top & bottom (security thread), and a
     paper halo on the glyphs so they stay legible on peak chroma. */
  .serial--holo {
    border: 0;
    overflow: hidden;
    isolation: isolate;
    padding: 8px 12px;
    box-shadow:
      inset 0 0 0 1px var(--rule-soft),
      inset 0 1px 0 0 color-mix(in oklab, var(--bg-card), transparent 40%);
  }
  .serial--holo::before,
  .serial--holo::after {
    content: "";
    position: absolute;
    left: 6px;
    right: 6px;
    height: 1px;
    z-index: 1;
    background-image: linear-gradient(
      to right,
      var(--ink) 0 50%,
      transparent 50% 100%
    );
    background-size: 3px 1px;
    background-repeat: repeat-x;
    opacity: 0.28;
    mix-blend-mode: multiply;
    pointer-events: none;
  }
  .serial--holo::before { top: 3px; }
  .serial--holo::after  { bottom: 3px; }
  :root[data-theme="dark"] .serial--holo::before,
  :root[data-theme="dark"] .serial--holo::after {
    mix-blend-mode: screen;
    opacity: 0.35;
  }

  .serial-text {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    z-index: 2;
  }
  .serial-k { color: var(--ink-muted); }
  .serial-v { color: var(--ink); }
  .serial-sep {
    color: var(--ink-muted);
    opacity: 0.6;
  }
  /* Inside the holo pill, the `·` bullet becomes a vertical rule so
     the pill reads as a multi-field document strip (ticket stub). */
  .serial--holo .serial-sep {
    width: 1px;
    height: 10px;
    font-size: 0;
    line-height: 0;
    background: var(--ink);
    opacity: 0.35;
    align-self: center;
    margin: 0 2px;
  }
  /* Paper halo on the text so small pixel glyphs keep their edges
     on top of the rainbow's peak chroma. */
  .serial--holo .serial-text {
    text-shadow:
      0 0 3px var(--bg-card),
      0 0 6px color-mix(in oklab, var(--bg-card), transparent 40%);
  }

  /* Barcode watermark. A rainbow band (same stops as the wisteria
     shine in FoilCard) masked by an irregular barcode SVG tile.
     --mxn/--myn are inherited from the parent FoilCard, so one
     cursor drives both the wisteria stamp shine and this pill —
     no extra pointer handlers on the page. */
  .serial-barcode {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
    -webkit-mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 40 20' preserveAspectRatio='none'><g fill='%23000'><rect x='0' width='2' height='20'/><rect x='3' width='3' height='20'/><rect x='7' width='2' height='20'/><rect x='10' width='4' height='20'/><rect x='15' width='2' height='20'/><rect x='18' width='3' height='20'/><rect x='22' width='5' height='20'/><rect x='28' width='2' height='20'/><rect x='31' width='3' height='20'/><rect x='35' width='4' height='20'/></g></svg>") repeat-x center / 40px 100%;
            mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 40 20' preserveAspectRatio='none'><g fill='%23000'><rect x='0' width='2' height='20'/><rect x='3' width='3' height='20'/><rect x='7' width='2' height='20'/><rect x='10' width='4' height='20'/><rect x='15' width='2' height='20'/><rect x='18' width='3' height='20'/><rect x='22' width='5' height='20'/><rect x='28' width='2' height='20'/><rect x='31' width='3' height='20'/><rect x='35' width='4' height='20'/></g></svg>") repeat-x center / 40px 100%;
    opacity: 0.3;
    mix-blend-mode: multiply;
  }
  .serial-barcode-band {
    position: absolute;
    inset: -30% -100%;
    background: linear-gradient(
      100deg,
      var(--red) 0%,
      var(--yellow) 18%,
      var(--green) 36%,
      var(--blue) 54%,
      var(--red) 72%,
      var(--yellow) 90%,
      var(--red) 100%
    );
    transform: translate3d(
      calc((var(--mxn, 50) - 50) * -0.5%),
      calc((var(--myn, 50) - 50) * -0.3%),
      0
    );
    filter: saturate(1.4);
    will-change: transform;
  }
  :root[data-theme="dark"] .serial-barcode {
    mix-blend-mode: screen;
    opacity: 0.55;
  }

  /* Responsive: collapse serial under text on medium, stack on small. */
  @media (max-width: 860px) {
    .masthead {
      grid-template-columns: auto 1fr;
      row-gap: 12px;
    }
    .serial {
      grid-column: 1 / -1;
      justify-self: start;
    }
  }
  @media (max-width: 520px) {
    .masthead {
      grid-template-columns: 1fr;
      justify-items: start;
    }
    .crest-slot {
      justify-content: flex-start;
    }
  }
</style>
