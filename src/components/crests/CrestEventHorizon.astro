---
/*
  CrestEventHorizon — refined dithered black hole.
  The dummy UniverseLogo done right: central event horizon (ink),
  accretion disk wings (accent), scattered dither halo (accent @ 0.5),
  and a tiny photon-ring highlight at the horizon edges.
*/

interface Props {
  size?: number;
  accent?: "red" | "yellow" | "blue" | "green";
  class?: string;
}

const {
  size = 52,
  accent = "yellow",
  class: className = "",
} = Astro.props;
---

<div
  class:list={["crest", `crest--${accent}`, className]}
  style={`--crest-size: ${size}px;`}
  aria-hidden="true"
>
  <svg
    viewBox="0 0 40 40"
    shape-rendering="crispEdges"
    xmlns="http://www.w3.org/2000/svg"
  >
    <g class="dither">
      <rect x="18" y="2"  width="4" height="2"/>
      <rect x="10" y="6"  width="2" height="2"/>
      <rect x="28" y="6"  width="2" height="2"/>
      <rect x="4"  y="10" width="2" height="2"/>
      <rect x="34" y="10" width="2" height="2"/>
      <rect x="2"  y="18" width="2" height="4"/>
      <rect x="36" y="18" width="2" height="4"/>
      <rect x="4"  y="28" width="2" height="2"/>
      <rect x="34" y="28" width="2" height="2"/>
      <rect x="10" y="32" width="2" height="2"/>
      <rect x="28" y="32" width="2" height="2"/>
      <rect x="18" y="36" width="4" height="2"/>
    </g>
    <g class="disk">
      <rect x="4"  y="18" width="10" height="4"/>
      <rect x="8"  y="16" width="6"  height="2"/>
      <rect x="8"  y="22" width="6"  height="2"/>
      <rect x="26" y="18" width="10" height="4"/>
      <rect x="26" y="16" width="6"  height="2"/>
      <rect x="26" y="22" width="6"  height="2"/>
    </g>
    <g class="horizon">
      <rect x="16" y="10" width="8"  height="2"/>
      <rect x="14" y="12" width="12" height="2"/>
      <rect x="12" y="14" width="16" height="2"/>
      <rect x="10" y="16" width="20" height="8"/>
      <rect x="12" y="24" width="16" height="2"/>
      <rect x="14" y="26" width="12" height="2"/>
      <rect x="16" y="28" width="8"  height="2"/>
    </g>
    <g class="photon">
      <rect x="10" y="18" width="2" height="4"/>
      <rect x="28" y="18" width="2" height="4"/>
    </g>
  </svg>
</div>

<style>
  .crest {
    display: inline-block;
    width: var(--crest-size);
    line-height: 0;
    flex-shrink: 0;
  }
  .crest svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .crest--red    { --crest-accent: var(--red); }
  .crest--yellow { --crest-accent: var(--yellow); }
  .crest--blue   { --crest-accent: var(--blue); }
  .crest--green  { --crest-accent: var(--green); }

  .horizon { fill: var(--ink); }
  .disk    { fill: var(--crest-accent); }
  .dither  { fill: var(--crest-accent); opacity: 0.5; }
  .photon  { fill: var(--crest-accent); opacity: 0.95; }
</style>
