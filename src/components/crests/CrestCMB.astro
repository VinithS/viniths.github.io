---
/*
  CrestCMB — Mollweide projection of the Cosmic Microwave
  Background. Ellipse frame (ink) holds a dithered field of
  temperature-fluctuation pixels (accent + accent @ 0.5) — the
  oldest map in the universe, each pixel a 10⁻⁵ deviation from
  the mean temperature at the moment of first light.
*/

interface Props {
  size?: number;
  accent?: "red" | "yellow" | "blue" | "green";
  class?: string;
}

const {
  size = 52,
  accent = "yellow",
  class: className = "",
} = Astro.props;
---

<div
  class:list={["crest", `crest--${accent}`, className]}
  style={`--crest-size: ${size}px;`}
  aria-hidden="true"
>
  <svg
    viewBox="0 0 40 40"
    shape-rendering="crispEdges"
    xmlns="http://www.w3.org/2000/svg"
  >
    <g class="flux-cool">
      <rect x="10" y="14" width="4" height="2"/>
      <rect x="18" y="14" width="2" height="2"/>
      <rect x="26" y="14" width="4" height="2"/>
      <rect x="8"  y="18" width="2" height="2"/>
      <rect x="16" y="18" width="4" height="2"/>
      <rect x="24" y="18" width="2" height="2"/>
      <rect x="12" y="22" width="2" height="2"/>
      <rect x="22" y="22" width="4" height="2"/>
      <rect x="30" y="22" width="2" height="2"/>
      <rect x="10" y="26" width="4" height="2"/>
      <rect x="20" y="26" width="2" height="2"/>
      <rect x="26" y="26" width="4" height="2"/>
    </g>

    <g class="flux-hot">
      <rect x="14" y="16" width="2" height="2"/>
      <rect x="22" y="16" width="4" height="2"/>
      <rect x="12" y="20" width="4" height="2"/>
      <rect x="28" y="20" width="2" height="2"/>
      <rect x="18" y="24" width="4" height="2"/>
      <rect x="14" y="28" width="4" height="2"/>
      <rect x="24" y="28" width="2" height="2"/>
    </g>

    <g class="frame">
      <rect x="10" y="10" width="20" height="2"/>
      <rect x="10" y="30" width="20" height="2"/>
      <rect x="8"  y="12" width="2"  height="2"/>
      <rect x="30" y="12" width="2"  height="2"/>
      <rect x="8"  y="28" width="2"  height="2"/>
      <rect x="30" y="28" width="2"  height="2"/>
      <rect x="6"  y="14" width="2"  height="2"/>
      <rect x="32" y="14" width="2"  height="2"/>
      <rect x="6"  y="26" width="2"  height="2"/>
      <rect x="32" y="26" width="2"  height="2"/>
      <rect x="4"  y="16" width="2"  height="10"/>
      <rect x="34" y="16" width="2"  height="10"/>
    </g>

    <g class="meridian">
      <rect x="20" y="12" width="2" height="2"/>
      <rect x="20" y="28" width="2" height="2"/>
      <rect x="12" y="20" width="2" height="2"/>
      <rect x="26" y="20" width="2" height="2"/>
    </g>

    <g class="label">
      <rect x="2"  y="4"  width="6" height="2"/>
      <rect x="32" y="34" width="6" height="2"/>
    </g>
  </svg>
</div>

<style>
  .crest {
    display: inline-block;
    width: var(--crest-size);
    line-height: 0;
    flex-shrink: 0;
  }
  .crest svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .crest--red    { --crest-accent: var(--red); }
  .crest--yellow { --crest-accent: var(--yellow); }
  .crest--blue   { --crest-accent: var(--blue); }
  .crest--green  { --crest-accent: var(--green); }

  .frame     { fill: var(--ink); }
  .meridian  { fill: var(--ink); opacity: 0.4; }
  .flux-hot  { fill: var(--crest-accent); }
  .flux-cool { fill: var(--crest-accent); opacity: 0.45; }
  .label     { fill: var(--ink); opacity: 0.5; }
</style>
