---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<Layout title="Writing - Vinith">
  <section class="band">
    <header class="section-head">
      <div class="section-tag">
        <span class="sq"></span>
        [ 01 ] &nbsp; Writing
      </div>
      <h1>Recent posts.</h1>
    </header>

    <ul class="writing-list">
      {
        posts.map((post) => (
          <li>
            <span class="writing-date">
              {post.data.date
                .toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "2-digit",
                  day: "2-digit",
                })
                .replace(/\//g, "·")}
            </span>
            <div>
              <a href={`/blog/${post.id}`} class="writing-title">
                {post.data.title}
              </a>
              <span class="writing-desc">{post.data.description}</span>
            </div>
            {post.data.tags && (
              <div class="writing-tags">
                {post.data.tags.map((tag) => (
                  <span class="tag-pixel">{tag}</span>
                ))}
              </div>
            )}
          </li>
        ))
      }
    </ul>
  </section>
</Layout>

<style>
  .band {
    padding: 40px 0 20px;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 36px;
  }
  .section-head h1 {
    font-variation-settings:
      "opsz" 72,
      "SOFT" 60,
      "wght" 500;
    font-size: clamp(32px, 4.5vw, 54px);
    letter-spacing: -0.025em;
    line-height: 1;
  }
  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-pixel);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .section-tag .sq {
    display: inline-block;
    width: 10px;
    height: 10px;
    background: var(--blue);
    box-shadow: 0 0 0 2px var(--rule);
  }

  .writing-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .writing-list li {
    display: grid;
    grid-template-columns: 96px 1fr auto;
    gap: 28px;
    align-items: baseline;
    padding: 22px 0;
    border-top: 1px solid var(--rule-soft);
    position: relative;
    transition: padding 0.2s ease;
  }
  .writing-list li:last-child {
    border-bottom: 1px solid var(--rule-soft);
  }
  .writing-list li::before {
    content: "";
    position: absolute;
    left: -16px;
    top: 50%;
    width: 6px;
    height: 6px;
    background: var(--marker);
    transform: translateY(-50%) scale(0);
    transition: transform 0.2s ease;
  }
  .writing-list li:hover {
    padding-left: 16px;
  }
  .writing-list li:hover::before {
    transform: translateY(-50%) scale(1);
  }

  .writing-date {
    font-family: var(--font-pixel);
    font-size: 11px;
    color: var(--ink-muted);
    letter-spacing: 0.1em;
  }
  .writing-title {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 32,
      "SOFT" 60,
      "wght" 500;
    font-size: 22px;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.015em;
  }
  .writing-title:hover {
    color: var(--link-hover);
  }
  .writing-desc {
    display: block;
    font-variation-settings:
      "opsz" 14,
      "SOFT" 70,
      "wght" 380;
    font-size: 14px;
    color: var(--ink-muted);
    margin-top: 4px;
    max-width: 58ch;
  }
  .writing-tags {
    display: flex;
    gap: 6px;
  }

  @media (max-width: 720px) {
    .writing-list li {
      grid-template-columns: 1fr;
      gap: 6px;
    }
    .writing-tags {
      margin-top: 10px;
    }
  }
</style>
