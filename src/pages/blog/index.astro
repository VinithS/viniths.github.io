---
import Layout from "../../layouts/Layout.astro";
import Ledger from "../../components/blog/Ledger.astro";
import SectionTag from "../../components/SectionTag.astro";
import { getCollection } from "astro:content";
import { featured } from "../../content/_data/featured";

const posts = (await getCollection("blog")).map((p) => ({
  slug: p.id,
  href: `/blog/${p.id}`,
  title: p.data.title,
  description: p.data.description,
  tags: p.data.tags,
  date: p.data.date,
  type: p.data.type,
}));

const entries = [...featured, ...posts].sort(
  (a, b) => b.date.getTime() - a.date.getTime(),
);
---

<Layout title="Blog - Vinith">
  <section class="band">
    <header class="section-head">
      <SectionTag number="01" label="Blog" accent="red" />
      <h1>Recent posts.</h1>
    </header>

    <Ledger entries={entries} />
  </section>
</Layout>

<style>
  .band {
    padding: 40px 0 20px;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 36px;
  }
  .section-head h1 {
    font-variation-settings: "opsz" 72, "SOFT" 60, "wght" 500;
    font-size: clamp(32px, 4.5vw, 54px);
    letter-spacing: -0.025em;
    line-height: 1;
  }
</style>
