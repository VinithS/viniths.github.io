---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} — Vinith`}>
  <article class="post">
    <header>
      <a href="/blog" class="back mono">&larr; back</a>
      <h1>{post.data.title}</h1>
      <div class="meta">
        <time class="mono" datetime={post.data.date.toISOString()}>
          {
            post.data.date.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </time>
        {
          post.data.tags && (
            <div class="tags">
              {post.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )
        }
      </div>
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .post {
    max-width: 680px;
  }

  .back {
    font-size: 13px;
    color: var(--text-muted);
    display: inline-block;
    margin-bottom: 24px;
  }

  .back:hover {
    color: var(--text-secondary);
  }

  header h1 {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 40px;
  }

  .meta time {
    font-size: 13px;
    color: var(--text-muted);
  }

  .tags {
    display: flex;
    gap: 6px;
  }

  /* Prose styles for rendered markdown */
  .prose {
    font-size: 16px;
    line-height: 1.75;
    color: var(--text-secondary);
  }

  .prose :global(h2) {
    font-size: 22px;
    font-weight: 600;
    color: var(--text-primary);
    margin: 32px 0 12px;
  }

  .prose :global(h3) {
    font-size: 18px;
    font-weight: 600;
    color: var(--text-primary);
    margin: 24px 0 8px;
  }

  .prose :global(p) {
    margin-bottom: 16px;
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 14px;
    background: var(--bg-surface);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .prose :global(pre) {
    background: var(--bg-surface);
    border: 1px solid var(--border-default);
    border-radius: var(--radius);
    padding: 16px;
    overflow-x: auto;
    margin-bottom: 16px;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 24px;
    margin-bottom: 16px;
  }

  .prose :global(li) {
    margin-bottom: 4px;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--border-default);
    padding-left: 16px;
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  .prose :global(img) {
    max-width: 100%;
    border-radius: var(--radius);
    margin: 16px 0;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border-default);
    margin: 32px 0;
  }
</style>
