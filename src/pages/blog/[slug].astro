---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} - Vinith`}>
  <article class="post">
    <a href="/blog" class="back">&larr; BACK</a>
    <header>
      <h1>{post.data.title}</h1>
      <div class="meta">
        <span class="writing-date">
          {
            post.data.date.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </span>
        {
          post.data.tags && (
            <div class="tags">
              {post.data.tags.map((tag) => (
                <span class="tag-pixel">{tag}</span>
              ))}
            </div>
          )
        }
      </div>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .post {
    max-width: 680px;
    margin: 0 auto;
    padding: 20px 0;
  }

  .back {
    font-family: var(--font-pixel);
    font-size: 10px;
    letter-spacing: 0.15em;
    color: var(--ink-muted);
    display: inline-block;
    margin-bottom: 32px;
  }
  .back:hover {
    color: var(--ink);
  }

  header h1 {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 72,
      "SOFT" 60,
      "wght" 500;
    font-size: clamp(34px, 5vw, 52px);
    line-height: 1.02;
    letter-spacing: -0.025em;
    margin-bottom: 18px;
  }
  header h1 em {
    font-style: italic;
    color: var(--em);
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 48px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--rule-soft);
  }
  .writing-date {
    font-family: var(--font-pixel);
    font-size: 11px;
    color: var(--ink-muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .tags {
    display: flex;
    gap: 6px;
  }

  .prose {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 18,
      "SOFT" 70,
      "wght" 400;
    font-size: 18px;
    line-height: 1.7;
    color: var(--ink-soft);
  }

  .prose :global(h2) {
    font-variation-settings:
      "opsz" 36,
      "SOFT" 60,
      "wght" 500;
    font-size: 28px;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 40px 0 14px;
  }
  .prose :global(h3) {
    font-variation-settings:
      "opsz" 24,
      "SOFT" 60,
      "wght" 500;
    font-size: 22px;
    color: var(--ink);
    margin: 28px 0 10px;
  }
  .prose :global(p) {
    margin-bottom: 18px;
  }
  .prose :global(em) {
    color: var(--em);
    font-style: italic;
  }
  .prose :global(strong) {
    color: var(--ink);
    font-weight: 600;
  }
  .prose :global(a) {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    text-decoration-color: var(--rule-soft);
  }
  .prose :global(a:hover) {
    color: var(--link-hover);
    text-decoration-color: currentColor;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 14px;
    background: var(--bg-inset);
    border: 1px solid var(--rule-soft);
    padding: 1px 6px;
  }
  .prose :global(pre) {
    background: var(--bg-inset);
    border: 1px solid var(--rule);
    padding: 16px;
    overflow-x: auto;
    margin-bottom: 20px;
  }
  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 13px;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 24px;
    margin-bottom: 18px;
  }
  .prose :global(li) {
    margin-bottom: 6px;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--marker);
    padding: 4px 0 4px 20px;
    color: var(--ink-muted);
    font-style: italic;
    margin: 20px 0;
  }

  .prose :global(img) {
    border: 2px solid var(--rule);
    margin: 20px 0;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--rule-soft);
    margin: 40px 0;
  }
</style>
