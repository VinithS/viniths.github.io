---
/*
  /blog/crest-prototypes — specimen catalog of the seven cosmic crests.

  Each crest is a 40×40 pixel SVG rendered crispEdges, fills pinned to
  theme tokens (--ink / --ink-soft / --ink-muted + an accent slot), so
  they track light/dark without per-theme overrides. This page lays them
  out as passport specimens: masthead in context, enlargement on a grid
  plate, accent-swatch row, single-line blurb.
*/

import Layout from "../../layouts/Layout.astro";
import PrototypeMasthead from "../../components/crests/PrototypeMasthead.astro";
import PostStamp from "../../components/blog/PostStamp.astro";
import type { FeaturedEntry } from "../../content/_data/featured";
import { formatPostDate } from "../../lib/format-date";

import CrestBlackHole from "../../components/crests/CrestBlackHole.astro";
import CrestLagrangian from "../../components/crests/CrestLagrangian.astro";
import CrestObserver from "../../components/crests/CrestObserver.astro";
import CrestSidereal from "../../components/crests/CrestSidereal.astro";

export const meta: FeaturedEntry = {
  slug: "crest-prototypes",
  href: "/blog/crest-prototypes",
  title: "Crest prototypes",
  description:
    "Four cosmic-bureau crests drawn as 40×40 pixel SVGs — black hole, Lagrangian, observer, sidereal — each with a four-accent palette and a specimen plate.",
  date: new Date("2026-04-30"),
  type: "prototype",
  tags: ["design", "svg", "css"],
};

const POST_DATE_LABEL = formatPostDate(meta.date);

const ACCENTS = ["red", "yellow", "blue", "green"] as const;

// Static serial pill — the mechanic lives on a separate page; on this
// one the crest is the focal element.
const DOC = "N-0001";
const ISSUED = "1997";

const crests = [
  {
    id: "blackhole",
    number: "01",
    variant: "panoptic" as const,
    institution: "Bureau of Cosmic Census",
    kicker: "Cosmological Authority",
    department: "Field Office · Orion Arm",
    name: "Black Hole",
    blurb:
      "Full-curve SVG with accretion disk, polar halo, and a traced photon ring. Fills map to three ink tiers plus one yellow so it reads on cream or dusk with no per-theme overrides.",
    accent: null,
  },
  {
    id: "lagrangian",
    number: "02",
    variant: "commission" as const,
    institution: "Council on Lagrangian Stability",
    department: "Three-Body Commission",
    kicker: "Treaty of Gravitational Meeting",
    name: "Lagrangian Points",
    blurb:
      "Three vertex nodes connected by dotted orbital lines around a small sun — the geometry of L1/L4/L5, where competing gravity wells hold something still.",
    accent: "red" as const,
  },
  {
    id: "observer",
    number: "03",
    variant: "panoptic" as const,
    institution: "Office of the Observer",
    department: "Panoptic Field Division",
    kicker: "Witness of Record",
    name: "Observer",
    blurb:
      "All-seeing eye: four cardinal plus four diagonal rays, an iris shell, an ink pupil with a paper-colored glint so it reads as a cutout on either theme.",
    accent: "green" as const,
  },
  {
    id: "sidereal",
    number: "04",
    variant: "commission" as const,
    institution: "Sidereal Reference Bureau",
    department: "Fixed-Star Registry",
    kicker: "Time Against the Background",
    name: "Sidereal",
    blurb:
      "Astrolabe ring with a faint crosshair reticle, four cardinal ticks, and a four-point star at the origin — a fixed point to measure all other motion from.",
    accent: "blue" as const,
  },
];
---

<Layout title="Crest prototypes — Vinith">
  <article class="post">
    <a href="/blog" class="back">&larr; BACK</a>

    <header class="post-head">
      <PostStamp slug={meta.slug} date={meta.date} type={meta.type} />
      <div class="post-kicker">
        <span class="post-kicker-tag">Specimen</span>
        <span class="post-kicker-dot">·</span>
        <span>Four crests</span>
      </div>
      <h1 class="post-title">
        Crest <em>prototypes</em>
      </h1>
      <div class="post-meta">
        <span class="post-date">{POST_DATE_LABEL}</span>
        <span class="tag-pixel">design</span>
        <span class="tag-pixel">svg</span>
        <span class="tag-pixel">css</span>
      </div>
    </header>

    <div class="post-lede">
      <p>
        Four crests for four made-up bureaus. Each is a 40×40 SVG drawn as
        <code>&lt;rect&gt;</code> primitives with <code>shape-rendering:&nbsp;crispEdges</code>,
        every fill pinned to a theme token — three ink tiers (<code>--ink</code>,
        <code>--ink-soft</code>, <code>--ink-muted</code>) plus one accent slot. No per-theme
        overrides: each crest tracks light/dark via the tokens it inherits, and the
        <code>accent</code> prop swaps <code>--red/--yellow/--blue/--green</code> for the
        institution it serves.
      </p>
    </div>

    <nav class="post-nav" aria-label="Crest index">
      {
        crests.map((c) => (
          <a href={`#${c.id}`} class="post-nav-item">
            <span class="post-nav-num">{c.number}</span>
            <span class="post-nav-title">{c.name}</span>
          </a>
        ))
      }
    </nav>

    {
      crests.map((c) => (
        <section
          class="proto"
          id={c.id}
          data-proto-section={c.accent ? c.id : undefined}
          data-accent={c.accent || undefined}
        >
          <header class="proto-head">
            <div class="proto-num">{c.number}</div>
            <h2 class="proto-title">{c.name}</h2>
          </header>
          <p class="proto-blurb">{c.blurb}</p>

          <div class="proto-card">
            <div class="proto-card-stage">
              <PrototypeMasthead
                variant={c.variant}
                institution={c.institution}
                department={c.department}
                kicker={c.kicker}
                tagline={c.tagline}
              >
                {c.id === "blackhole" && <CrestBlackHole slot="crest" size={44} />}
                {c.id === "lagrangian" && (
                  <CrestLagrangian slot="crest" size={44} accent={c.accent!} />
                )}
                {c.id === "observer" && (
                  <CrestObserver slot="crest" size={44} accent={c.accent!} />
                )}
                {c.id === "sidereal" && (
                  <CrestSidereal slot="crest" size={44} accent={c.accent!} />
                )}

                <div class="serial">
                  <span class="serial-k">Doc</span>
                  <span class="serial-v">{DOC}</span>
                  <span class="serial-sep">·</span>
                  <span class="serial-k">Issued</span>
                  <span class="serial-v">{ISSUED}</span>
                </div>
              </PrototypeMasthead>
            </div>

            <div class="specimen">
              <figure class="specimen-hero">
                <div class="specimen-plate">
                  {c.id === "blackhole" && <CrestBlackHole size={96} />}
                  {c.id === "lagrangian" && (
                    <CrestLagrangian size={96} accent={c.accent!} />
                  )}
                  {c.id === "observer" && <CrestObserver size={96} accent={c.accent!} />}
                  {c.id === "sidereal" && <CrestSidereal size={96} accent={c.accent!} />}
                </div>
              </figure>

              {c.accent && (
                <div class="palette" data-palette={c.id}>
                  <div class="palette-label">
                    <span class="palette-label-k">Accent</span>
                    <span class="palette-label-v" data-palette-current>{c.accent}</span>
                  </div>
                  <div class="palette-row">
                    {ACCENTS.map((a) => (
                      <button
                        type="button"
                        class:list={["palette-cell", a === c.accent && "is-current"]}
                        data-set-accent={a}
                        aria-label={`Set accent to ${a}`}
                      >
                        {c.id === "lagrangian" && <CrestLagrangian size={28} accent={a} />}
                        {c.id === "observer" && <CrestObserver size={28} accent={a} />}
                        {c.id === "sidereal" && <CrestSidereal size={28} accent={a} />}
                        <span class="palette-tick">{a.charAt(0).toUpperCase()}</span>
                      </button>
                    ))}
                  </div>
                </div>
              )}

              {!c.accent && (
                <div class="palette">
                  <div class="palette-label">
                    <span class="palette-label-k">Accent</span>
                    <span class="palette-label-v">fixed · yellow/ink</span>
                  </div>
                  <p class="palette-note">
                    Hand-tuned tiers — <code>bh-core</code>, <code>bh-ring</code>,
                    <code>bh-disk</code>, <code>bh-halo</code> — rather than a single
                    accent slot. This is the crest that shipped on the live about card.
                  </p>
                </div>
              )}
            </div>
          </div>
        </section>
      ))
    }

    <footer class="post-foot">
      <a href="/blog" class="post-foot-back">&larr; BACK TO BLOG</a>
    </footer>
  </article>
</Layout>

<script>
  /*
    Accent picker. Each accentable .proto section carries a data-accent
    that mirrors the live accent. Clicking a palette cell:
      - swaps the `.crest--{old}` class for `.crest--{new}` on every
        .crest inside this section (the masthead 44px and the 96px
        specimen plate both pick up the change),
      - updates the section's data-accent so the proto-title color and
        any other parent-driven styles re-derive,
      - retargets `.is-current` to the chosen palette cell and rewrites
        the "Accent" label text.
    Localized to this section — clicking accents in one prototype
    doesn't bleed into the others.
  */
  type Accent = "red" | "yellow" | "blue" | "green";
  const ACCENT_CLASSES = ["crest--red", "crest--yellow", "crest--blue", "crest--green"];

  document
    .querySelectorAll<HTMLElement>("[data-proto-section]")
    .forEach((section) => {
      const cells = Array.from(
        section.querySelectorAll<HTMLButtonElement>("[data-set-accent]"),
      );
      const labelEl = section.querySelector<HTMLElement>(
        "[data-palette-current]",
      );

      // Repaint targets: the masthead crest + the 96px specimen plate
      // only. Swatches inside .palette-row are reference samples and
      // must stay fixed at their own colors.
      const targets = Array.from(
        section.querySelectorAll<HTMLElement>(
          ".proto-card-stage > * .crest, .specimen-plate .crest",
        ),
      );

      const setAccent = (next: Accent) => {
        section.dataset.accent = next;
        targets.forEach((el) => {
          ACCENT_CLASSES.forEach((c) => el.classList.remove(c));
          el.classList.add(`crest--${next}`);
        });
        cells.forEach((c) =>
          c.classList.toggle("is-current", c.dataset.setAccent === next),
        );
        if (labelEl) labelEl.textContent = next;
      };

      cells.forEach((cell) => {
        cell.addEventListener("click", () => {
          const next = cell.dataset.setAccent as Accent | undefined;
          if (next) setAccent(next);
        });
      });
    });
</script>

<style>
  /* =========================================================
     Post chrome — matches the other interactive /blog entries.
     ========================================================= */
  .post {
    max-width: 720px;
    margin: 0 auto;
    padding: 20px 0 40px;
  }
  .back,
  .post-foot-back {
    font-family: var(--font-pixel);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-muted);
    display: inline-block;
    margin-bottom: 32px;
  }
  .back:hover,
  .post-foot-back:hover {
    color: var(--ink);
  }
  .post-head {
    position: relative;
    isolation: isolate;
    margin-bottom: 28px;
  }
  .post-head > .post-kicker,
  .post-head > .post-title,
  .post-head > .post-lede,
  .post-head > .post-meta {
    position: relative;
    z-index: 1;
  }
  .post-kicker {
    font-family: var(--font-pixel);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-muted);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
  }
  .post-kicker-tag {
    background: var(--yellow);
    color: var(--on-yellow);
    padding: 3px 7px 2px;
    letter-spacing: 0.14em;
  }
  .post-kicker-dot {
    color: var(--ink-muted);
    opacity: 0.6;
  }
  .post-title {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 72,
      "SOFT" 60,
      "wght" 500;
    font-size: clamp(34px, 5vw, 52px);
    line-height: 1.02;
    letter-spacing: -0.025em;
    margin-bottom: 18px;
  }
  .post-title em {
    font-style: italic;
    color: var(--em);
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--rule-soft);
  }
  .post-date {
    font-family: var(--font-pixel);
    font-size: 11px;
    color: var(--ink-muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .post-lede {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 18,
      "SOFT" 70,
      "wght" 400;
    font-size: 18px;
    line-height: 1.7;
    color: var(--ink-soft);
    margin: 32px 0 40px;
  }
  .post-lede code {
    font-family: var(--font-pixel);
    font-size: 13px;
    padding: 1px 5px;
    background: var(--bg-inset);
    border: 1px solid var(--rule-soft);
  }
  .post-nav {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    margin-bottom: 48px;
  }
  .post-nav-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 10px 12px;
    background: var(--bg-card);
    border: 1px solid var(--rule);
    color: var(--ink-soft);
    text-decoration: none;
    transition:
      transform 0.08s ease,
      background 0.15s ease;
  }
  .post-nav-item:hover {
    transform: translateY(-2px);
    background: var(--bg-raised);
    color: var(--ink);
  }
  .post-nav-num {
    font-family: var(--font-pixel);
    font-size: 9px;
    letter-spacing: 0.18em;
    color: var(--ink-muted);
  }
  .post-nav-title {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 14,
      "SOFT" 60,
      "wght" 500;
    font-size: 14px;
    line-height: 1.15;
  }
  @media (max-width: 760px) {
    .post-nav {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .proto {
    margin: 56px 0;
    scroll-margin-top: 80px;
  }
  .proto-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 12px;
  }
  .proto-num {
    font-family: var(--font-pixel);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--ink-muted);
  }
  .proto-title {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 32,
      "SOFT" 60,
      "wght" 500;
    font-size: 26px;
    letter-spacing: -0.015em;
    color: var(--ink);
    line-height: 1;
    transition: color 0.18s ease;
  }
  /* When a section has a live accent, the heading takes on that
     color. The accent picker writes data-accent on the section, so
     clicking a swatch repaints the title in the same beat. */
  .proto[data-accent="red"]    .proto-title { color: var(--red); }
  .proto[data-accent="yellow"] .proto-title { color: var(--yellow); }
  .proto[data-accent="blue"]   .proto-title { color: var(--blue); }
  .proto[data-accent="green"]  .proto-title { color: var(--green); }
  .proto-blurb {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 18,
      "SOFT" 70,
      "wght" 400;
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin-bottom: 20px;
    max-width: 62ch;
  }
  .proto-card {
    background: var(--bg-card);
    border: 2px solid var(--rule);
    box-shadow: 4px 4px 0 var(--rule);
    padding: 18px 20px;
  }
  .proto-card-stage {
    padding: 12px 4px 18px;
    border-bottom: 1px dashed var(--rule-soft);
  }

  /* =========================================================
     Specimen block — enlargement on a grid plate + accent
     swatch row. Two columns on wide viewports, stacks narrow.
     ========================================================= */
  .specimen {
    display: grid;
    grid-template-columns: minmax(130px, 160px) 1fr;
    gap: 22px;
    padding-top: 20px;
  }
  @media (max-width: 640px) {
    .specimen {
      grid-template-columns: 1fr;
    }
  }

  .specimen-hero {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .specimen-plate {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1;
    max-width: 160px;
    background: var(--bg-inset);
    border: 1px solid var(--rule-soft);
    /* Faint 16px grid so the pixelation reads as intentional. */
    background-image:
      linear-gradient(to right, var(--rule-xsoft) 1px, transparent 1px),
      linear-gradient(to bottom, var(--rule-xsoft) 1px, transparent 1px);
    background-size: 16px 16px;
  }

  .palette {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .palette-label {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-family: var(--font-pixel);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .palette-label-k {
    color: var(--ink-muted);
  }
  .palette-label-v {
    color: var(--ink);
  }
  .palette-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }
  .palette-cell {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1;
    background: var(--bg-inset);
    border: 1px solid var(--rule-soft);
    /* Reset button defaults — these palette cells used to be <div>s. */
    padding: 0;
    font: inherit;
    color: inherit;
    cursor: pointer;
    transition:
      transform 0.12s ease,
      border-color 0.12s ease;
  }
  .palette-cell:hover {
    transform: translateY(-1px);
    border-color: var(--rule);
  }
  .palette-cell.is-current {
    /* Subtle ring so the shipping accent reads without being loud. */
    border-color: var(--ink);
    box-shadow: 2px 2px 0 var(--rule-soft);
  }
  .palette-tick {
    position: absolute;
    bottom: 3px;
    right: 4px;
    font-family: var(--font-pixel);
    font-size: 8px;
    letter-spacing: 0.14em;
    color: var(--ink-muted);
  }
  .palette-cell.is-current .palette-tick {
    color: var(--ink);
  }
  .palette-note {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-soft);
  }
  .palette-note code {
    font-family: var(--font-pixel);
    font-size: 11px;
    padding: 1px 4px;
    background: var(--bg-inset);
    border: 1px solid var(--rule-soft);
  }

  /* =========================================================
     Serial pill — static on this page; the mechanic lives
     elsewhere. Inherited shape kept so the masthead still
     reads as a passport strip.
     ========================================================= */
  .serial {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 6px 10px;
    background: var(--bg-inset);
    border: 1px solid var(--rule-soft);
    font-family: var(--font-pixel);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink);
    white-space: nowrap;
  }
  .serial-k {
    color: var(--ink-muted);
  }
  .serial-v {
    color: var(--ink);
  }
  .serial-sep {
    color: var(--ink-muted);
    opacity: 0.6;
  }

  .post-foot {
    padding-top: 32px;
    border-top: 1px solid var(--rule-soft);
  }
</style>
