---
/*
  /blog/stamp-prototypes - "Rubber-stamp the card" post.

  Four interactive variations on a stamper island. Each prototype is a
  dummy card + tray. The same Svelte component handles all of them via
  a `mode` prop; the differences live in that one component.
*/

import Layout from "../../layouts/Layout.astro";
import Stamper from "../../components/Stamper.svelte";
import PostStamp from "../../components/blog/PostStamp.astro";
import type { FeaturedEntry } from "../../content/_data/featured";
import { formatPostDate } from "../../lib/format-date";

export const meta: FeaturedEntry = {
  slug: "stamp-prototypes",
  href: "/blog/stamp-prototypes",
  title: "Rubber-stamp prototypes",
  description:
    "Four takes on letting a visitor stamp a card with their cursor — wash-away, wet-ink smear, random surprise, and a permanent archival record that ages over time.",
  date: new Date("2026-04-25"),
  type: "prototype",
  tags: ["design", "svelte", "interaction"],
};

const POST_DATE_LABEL = formatPostDate(meta.date);

// Stamp pool shared across prototypes. "kind" drives which Svelte
// rendering path is used: single-ink mask, native-color img, or the
// inline date-postmark SVG.
const STAMPS = [
  { id: "bee",     kind: "ink",   src: "/assets/bee.svg",    accent: "yellow", label: "Bee" },
  { id: "coffee",  kind: "ink",   src: "/assets/coffee.svg", accent: "red",    label: "Coffee" },
  { id: "galaxy",  kind: "color", src: "/assets/cosmos/galaxy.svg",                    label: "Galaxy" },
  { id: "date",    kind: "date",                                                 label: "Date" },
];

const prototypes = [
  {
    id: "press",
    number: "01",
    title: "Wash-away press",
    blurb:
      "Pick a stamp from the tray, click the card to press. Each stamp fades linearly to zero over seven seconds and is garbage-collected. Press rotation is randomized in a narrow range so repeat presses don't feel mechanical. Esc cancels the armed stamp.",
    mode: "press",
  },
  {
    id: "smear",
    number: "02",
    title: "Wet-ink smear",
    blurb:
      "Same pick-then-press, but pointerdown + drag lays down a trail of stamps at ~90ms intervals. Quick taps still drop a single press. The rubber filter's wobble sells the wet-ink feel as presses overlap and blend via multiply.",
    mode: "smear",
  },
  {
    id: "surprise",
    number: "03",
    title: "Mystery press",
    blurb:
      "Tray collapses to a single Surprise chip. Every press pulls a random stamp from the pool with a random rotation. Good when you don't care which stamp — you just want to fill the card. Also fun to spam.",
    mode: "surprise",
  },
  {
    id: "archive",
    number: "04",
    title: "Permanent record",
    blurb:
      "Stamps never disappear. Instead they age: saturation drops and a slight sepia creeps in over thirty seconds so the newest press is vivid and older ones read as archival. The card accumulates a provenance trail you can't wash off.",
    mode: "archive",
  },
];
---

<Layout title="Rubber-stamp prototypes - Vinith">
  <article class="post">
    <a href="/blog" class="back">&larr; BACK</a>

    <header class="post-head">
      <PostStamp slug={meta.slug} date={meta.date} type={meta.type} />
      <div class="post-kicker">
        <span class="post-kicker-tag">Interactive</span>
        <span class="post-kicker-dot">·</span>
        <span>Four prototypes</span>
      </div>
      <h1 class="post-title">
        Rubber-stamp <em>prototypes</em>
      </h1>
      <p class="post-lede">
        Four takes on letting a visitor stamp a card with their cursor.
        Shared building blocks: the <code>#rubber-ink</code> SVG filter
        that jitters edges and erodes dry patches, a tiny Svelte island
        that tracks pointer state and manages placed-stamp lifecycles,
        and three rendering paths for stamps (single-ink mask,
        native-color SVG, inline circular postmark). Each prototype
        changes how presses behave, not how they look.
      </p>
      <div class="post-meta">
        <span class="post-meta-dot"></span>
        <span>Published {POST_DATE_LABEL}</span>
      </div>
    </header>

    {
      prototypes.map((p) => (
        <section class="proto" id={p.id}>
          <header class="proto-head">
            <div class="proto-number">{p.number}</div>
            <h2 class="proto-title">{p.title}</h2>
          </header>
          <p class="proto-blurb">{p.blurb}</p>

          <div class="proto-stage">
            <Stamper client:load mode={p.mode} stamps={STAMPS} fadeMs={7000} />
          </div>
        </section>
      ))
    }

    <footer class="post-foot">
      <a href="/blog" class="back">&larr; BACK TO BLOG</a>
    </footer>
  </article>
</Layout>

<style>
  .post {
    max-width: 820px;
    margin: 0 auto;
    padding: 24px 0 80px;
  }
  .back {
    display: inline-block;
    font-family: var(--font-pixel);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-muted);
    text-decoration: none;
    margin-bottom: 28px;
  }
  .back:hover {
    color: var(--ink);
  }

  .post-head {
    position: relative;
    isolation: isolate;
    margin-bottom: 48px;
  }
  .post-head > :global(.post-kicker),
  .post-head > .post-title,
  .post-head > .post-lede,
  .post-head > .post-meta {
    position: relative;
    z-index: 1;
  }
  .post-kicker {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-pixel);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 16px;
  }
  .post-kicker-tag {
    padding: 3px 7px 2px;
    background: var(--yellow);
    color: var(--on-yellow);
    letter-spacing: 0.14em;
  }
  .post-kicker-dot {
    color: var(--ink-muted);
  }

  .post-title {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 72,
      "SOFT" 60,
      "wght" 500;
    font-size: clamp(38px, 6vw, 60px);
    line-height: 1;
    letter-spacing: -0.025em;
    margin-bottom: 20px;
  }
  .post-title em {
    font-style: italic;
    font-variation-settings:
      "opsz" 72,
      "SOFT" 60,
      "wght" 400;
    color: var(--em);
  }

  .post-lede {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 22,
      "SOFT" 80,
      "wght" 400;
    font-size: 19px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin-bottom: 18px;
    max-width: 60ch;
  }
  .post-lede code {
    font-family: var(--font-pixel);
    font-size: 13px;
    padding: 1px 5px;
    background: var(--bg-inset);
    border: 1px solid var(--rule-soft);
  }

  .post-meta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-pixel);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .post-meta-dot {
    width: 6px;
    height: 6px;
    background: var(--signal);
    box-shadow: 0 0 0 1px var(--rule);
  }

  .proto {
    margin-bottom: 56px;
    padding-top: 28px;
    border-top: 1px solid var(--rule-soft);
  }
  .proto-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 10px;
  }
  .proto-number {
    font-family: var(--font-pixel);
    font-size: 11px;
    letter-spacing: 0.22em;
    color: var(--ink-muted);
    min-width: 34px;
  }
  .proto-title {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 32,
      "SOFT" 60,
      "wght" 500;
    font-size: 26px;
    letter-spacing: -0.015em;
  }
  .proto-blurb {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0 0 22px 50px;
    max-width: 62ch;
  }
  .proto-stage {
    margin-left: 50px;
  }

  .post-foot {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--rule-soft);
  }

  @media (max-width: 640px) {
    .proto-blurb,
    .proto-stage {
      margin-left: 0;
    }
  }
</style>
