---
import Layout from "../layouts/Layout.astro";
import Ledger from "../components/blog/Ledger.astro";
import TagSky from "../components/cosmos/TagSky.svelte";
import ChartLegend from "../components/cosmos/ChartLegend.astro";
import { getCollection } from "astro:content";
import { featured } from "../content/_data/featured";
import { tagGraphFrom } from "../lib/cosmos";

const posts = (await getCollection("blog")).map((p) => ({
  slug: p.id,
  href: `/blog/${p.id}`,
  title: p.data.title,
  description: p.data.description,
  tags: p.data.tags,
  date: p.data.date,
  type: p.data.type,
}));

const allEntries = [...featured, ...posts].sort(
  (a, b) => b.date.getTime() - a.date.getTime(),
);

const graph = tagGraphFrom(allEntries);
---

<Layout title="Cosmos - Vinith">
  <section class="band">
    <header class="head">
      <div class="left">
        <div class="eyebrow">
          <span class="pip"></span>
          [ 02 ] &nbsp; The Cosmos
        </div>
        <h1 class="display">A sky <em>of tags.</em></h1>
        <p class="lede">
          Every tag is a star. Two stars are connected when a post wears both. Brighter halos
          mean a tag was used recently; bigger discs mean it has more entries. Click a star to
          filter the ledger below.
        </p>
      </div>
      <dl class="stats">
        <div><dt>Tags</dt><dd>{graph.tags.length}</dd></div>
        <div><dt>Posts</dt><dd>{allEntries.length}</dd></div>
        <div><dt>Edges</dt><dd>{graph.edges.length}</dd></div>
      </dl>
    </header>

    <div class="chart-wrap" id="chart-wrap">
      <TagSky graph={graph} client:load />
      <ChartLegend />
    </div>

    <div id="filter-region" class="filter-region">
      <Ledger entries={allEntries} />
    </div>
  </section>
</Layout>

<script>
  /*
    Tag selection handler. The TagSky island dispatches `cosmos:select`
    on document with detail.slug = string | null. We toggle a class on
    the filter region and show/hide ledger rows by reading their
    .tag-pixel children.
  */
  const region = document.getElementById("filter-region");
  if (region) {
    const rows = Array.from(region.querySelectorAll(".ledger > li"));
    document.addEventListener("cosmos:select", (e) => {
      const slug = (e as CustomEvent).detail?.slug ?? null;
      if (!slug) {
        region.classList.remove("filtered");
        rows.forEach((li) => ((li as HTMLElement).style.display = ""));
        return;
      }
      region.classList.add("filtered");
      rows.forEach((li) => {
        const tags = Array.from(li.querySelectorAll(".tag-pixel")).map(
          (t) => t.textContent?.trim().toLowerCase() ?? "",
        );
        (li as HTMLElement).style.display = tags.includes(slug) ? "" : "none";
      });
    });
  }
</script>

<style>
  .band {
    padding: 32px 0 16px;
  }

  .head {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 28px;
    align-items: end;
    margin-bottom: 24px;
  }
  @media (max-width: 980px) { .head { grid-template-columns: 1fr; } }

  .eyebrow {
    font-family: var(--font-pixel); font-size: 11px;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--ink-muted);
    display: inline-flex; align-items: center; gap: 10px;
    margin-bottom: 16px;
  }
  .eyebrow .pip {
    width: 8px; height: 8px;
    background: var(--yellow);
    box-shadow: 0 0 0 2px var(--rule);
  }

  .display {
    font-family: var(--font-serif);
    font-variation-settings: "opsz" 100, "SOFT" 100, "wght" 500;
    font-size: clamp(40px, 5.5vw, 64px);
    line-height: 0.96;
    letter-spacing: -0.025em;
    margin: 0 0 12px;
  }
  .display em {
    font-style: italic;
    color: var(--em);
    font-variation-settings: "opsz" 100, "SOFT" 100, "wght" 400;
  }

  .lede {
    font-family: var(--font-serif);
    font-variation-settings: "opsz" 16, "SOFT" 70, "wght" 380;
    font-size: 16px;
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 48ch;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin: 0;
  }
  .stats > div {
    background: var(--bg-card);
    border: 1px solid var(--rule);
    box-shadow: 3px 3px 0 var(--rule);
    padding: 10px 12px;
  }
  .stats dt {
    font-family: var(--font-pixel); font-size: 8px;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--ink-muted);
  }
  .stats dd {
    margin: 4px 0 0;
    font-family: var(--font-serif);
    font-variation-settings: "opsz" 24, "SOFT" 60, "wght" 500;
    font-size: 22px;
    color: var(--ink);
    font-feature-settings: "tnum" 1, "lnum" 1;
  }

  .chart-wrap {
    position: relative;
    margin-bottom: 24px;
  }
</style>
