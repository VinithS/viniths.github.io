---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Eden's Desktop">
  <div class="xp-window welcome-window">
    <div class="xp-titlebar">
      <div class="xp-titlebar-title">Welcome.exe</div>
      <div class="xp-titlebar-controls">
        <button class="xp-titlebar-btn">_</button>
        <button class="xp-titlebar-btn">□</button>
        <button class="xp-titlebar-btn close">X</button>
      </div>
    </div>
    <div class="xp-content">
      <div class="hero">
        <h1>Welcome to My Space</h1>
        <p>I'm Eden. This is my retro-themed personal platform to share my thoughts, projects, and experiences.</p>
        
        <div class="lcd-screen handheld-vibe">
          <p>> SYSTEM BOOT...</p>
          <p>> Loading memories.dat</p>
          <p>> Ready.</p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .welcome-window {
    width: 100%;
    max-width: 600px;
    height: 400px;
    margin: 50px auto;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -60%);
  }

  .hero {
    display: flex;
    flex-direction: column;
    gap: 20px;
    height: 100%;
  }

  h1 {
    font-size: 24px;
    color: #333;
    border-bottom: 2px solid var(--xp-bg-blue);
    padding-bottom: 5px;
  }

  p {
    line-height: 1.5;
    color: #444;
  }

  .handheld-vibe {
    margin-top: auto;
  }
  
  .handheld-vibe p {
    color: var(--lcd-dark);
    margin: 0;
    line-height: 1.2;
    font-weight: bold;
  }
</style>
