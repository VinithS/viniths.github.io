---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Vinith">
  <section class="hero">
    <div class="hero-text">
      <div class="eyebrow reveal" data-delay="1">
        <span class="pill"></span>
        Personal Site · v0.4
      </div>
      <h1 class="display reveal" data-delay="2">
        Making&nbsp;things<br />
        on the <em>internet,</em><br />
        slowly.
      </h1>
      <p class="lede reveal" data-delay="3">
        I'm <span class="under">Vinith</span> - a software engineer writing about
        what I'm building, the places I wander, and stray thoughts I couldn't fit
        elsewhere.
      </p>
    </div>

    <div class="ornament reveal" data-delay="4" aria-hidden="true">
      <span class="halo"></span>
      <svg viewBox="0 0 32 32" shape-rendering="crispEdges">
        <rect x="4" y="4" width="24" height="24" fill="var(--ink)"></rect>
        <rect x="5" y="5" width="22" height="22" fill="var(--bg-card)"></rect>
        <rect x="9" y="5" width="14" height="8" fill="var(--ink)"></rect>
        <rect x="11" y="6" width="10" height="6" fill="var(--bg-inset)"></rect>
        <rect x="18" y="6" width="3" height="6" fill="var(--ink)"></rect>
        <rect x="8" y="16" width="16" height="10" fill="var(--bg-raised)"
        ></rect>
        <rect x="8" y="16" width="16" height="1" fill="var(--ink)"></rect>
        <rect x="10" y="19" width="12" height="1" fill="var(--red)"></rect>
        <rect x="10" y="21" width="10" height="1" fill="var(--ink-muted)"
        ></rect>
        <rect x="10" y="23" width="8" height="1" fill="var(--ink-muted)"></rect>
        <rect x="24" y="4" width="4" height="4" fill="var(--bg)"></rect>
        <rect x="24" y="4" width="1" height="4" fill="var(--ink)"></rect>
        <rect x="24" y="7" width="4" height="1" fill="var(--ink)"></rect>
      </svg>
    </div>

    <div class="cta-row reveal" data-delay="5">
      <a class="btn btn--red" href="/blog"><span class="pip"></span> Blog</a>
      <a class="btn btn--yellow" href="/photos"
        ><span class="pip"></span> Photos</a
      >
      <a class="btn btn--blue" href="/tweets"><span class="pip"></span> Notes</a
      >
      <a class="btn btn--green" href="/about"><span class="pip"></span> About</a
      >
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 48px;
    align-items: end;
    padding: 64px 0 32px;
  }
  .hero-text {
    grid-column: 1;
  }

  .eyebrow {
    font-family: var(--font-pixel);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-muted);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }
  .eyebrow .pill {
    display: inline-block;
    width: 8px;
    height: 8px;
    background: var(--signal);
    box-shadow: 0 0 0 2px var(--rule);
  }

  h1.display {
    font-variation-settings:
      "opsz" 120,
      "SOFT" 100,
      "wght" 500;
    font-size: clamp(56px, 9.5vw, 124px);
    line-height: 0.92;
    letter-spacing: -0.035em;
    margin-bottom: 18px;
  }
  h1.display em {
    font-style: italic;
    font-variation-settings:
      "opsz" 120,
      "SOFT" 100,
      "wght" 400;
    color: var(--em);
  }

  .lede {
    font-variation-settings:
      "opsz" 18,
      "SOFT" 70,
      "wght" 380;
    font-size: 19px;
    color: var(--ink-soft);
    max-width: 46ch;
    line-height: 1.5;
  }
  .lede .under {
    background-image: linear-gradient(
      to top,
      var(--highlight-bg) 28%,
      transparent 28%
    );
    color: var(--highlight-ink);
    padding: 0 4px;
  }

  .ornament {
    grid-column: 2;
    position: relative;
    aspect-ratio: 1 / 1;
    max-width: 300px;
    justify-self: end;
    animation: float 7s ease-in-out infinite;
  }
  .ornament svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .ornament .halo {
    position: absolute;
    inset: -6%;
    border: 2px dashed var(--rule-soft);
    border-radius: 50%;
    animation: spin 40s linear infinite;
  }
  @keyframes float {
    0%,
    100% {
      transform: translateY(0) rotate(-2deg);
    }
    50% {
      transform: translateY(-8px) rotate(-1deg);
    }
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .cta-row {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 40px;
  }

  @media (prefers-reduced-motion: reduce) {
    .ornament,
    .ornament .halo {
      animation: none !important;
    }
  }

  @media (max-width: 860px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 32px;
      padding: 40px 0 24px;
    }
    .hero-text {
      grid-column: 1;
    }
    .ornament {
      grid-column: 1;
      max-width: 200px;
      justify-self: start;
    }
  }
</style>
