---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Eden">
  <section class="hero">
    <p class="mono greeting">$ hello, universe!</p>
    <h1>I'm Vinith.</h1>
    <p class="subtitle">
      This is a place for my thoughts, projects, and experiences.
    </p>
  </section>

  <section class="sections">
    <a href="/blog" class="card section-card">
      <h2>Blog</h2>
      <p>Writing about things I'm learning and building.</p>
    </a>
    <a href="/photos" class="card section-card">
      <h2>Photos</h2>
      <p>Moments along the way.</p>
    </a>
    <a href="/about" class="card section-card">
      <h2>About</h2>
      <p>A little more about who I am.</p>
    </a>
  </section>

  <style>
    .hero {
      margin-bottom: 64px;
    }

    .greeting {
      font-size: 14px;
      margin-bottom: 16px;
      color: var(--accent);
    }

    h1 {
      font-size: 48px;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 12px;
    }

    .subtitle {
      font-size: 18px;
      color: var(--text-secondary);
      max-width: 480px;
      line-height: 1.6;
    }

    .sections {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 16px;
    }

    .section-card {
      padding: 24px;
      transition:
        border-color 0.15s ease,
        background 0.15s ease;
      text-decoration: none;
      color: inherit;
    }

    .section-card:hover {
      border-color: var(--text-muted);
      background: var(--bg-hover);
      color: inherit;
    }

    .section-card h2 {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 6px;
      color: var(--text-primary);
    }

    .section-card p {
      font-size: 14px;
      color: var(--text-secondary);
      line-height: 1.5;
    }
  </style>
</Layout>
