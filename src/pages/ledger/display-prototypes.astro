---
/*
  /ledger/display-prototypes - "Digital display prototypes" post.

  Four takes on a thin futuristic display I was building for the About
  card footer. Each prototype is a simple card with just the display
  itself - no ID card chrome - so the mechanics read clearly.

  This is an interactive .astro post that lives outside the content
  collection; it's featured on /ledger alongside the markdown entries.
*/

import Layout from "../../layouts/Layout.astro";
import PrototypePostShell from "../../components/ledger/PrototypePostShell.astro";
import type { FeaturedEntry } from "../../content/_data/featured";

import DisplayFlipBoard from "../../components/primitives/displays/DisplayFlipBoard.astro";
import DisplaySegment from "../../components/primitives/displays/DisplaySegment.astro";
import DisplayDotMatrix from "../../components/primitives/displays/DisplayDotMatrix.astro";
import DisplayTerminal from "../../components/primitives/displays/DisplayTerminal.astro";

export const meta: FeaturedEntry = {
  slug: "display-prototypes",
  href: "/ledger/display-prototypes",
  title: "Digital display prototypes",
  description:
    "Four takes on a thin futuristic display strip — split-flap, VFD, LED dot-matrix, CRT terminal — plus a scraper-resistant email treatment.",
  date: new Date("2026-04-25"),
  type: "prototype",
  tags: ["design", "css", "astro"],
};

/* Field hrefs are intentionally absent — the displays on this page
   are inert showcases and don't navigate anywhere. */
const FIELDS = [
  { label: "Frequency", value: "/ledger" },
  { label: "Broadcast", value: "/notes" },
  { label: "Album", value: "/photos" },
  { label: "Coords", value: "Seattle, WA" },
];

const EMAIL = "hello@vinith.dev";

const prototypes = [
  {
    id: "flip",
    number: "01",
    title: "Solari Flip-Board",
    blurb:
      "Mechanical split-flap tiles - the kind you still see in old train stations and a few holdout airport boards. On reveal each value scrambles through random glyphs before settling. Hover any field to re-run the clatter. The horizontal hinge line is a background-image trick, not an overlay, so it stays crisp at any zoom.",
  },
  {
    id: "seg",
    number: "02",
    title: "16-Segment VFD",
    blurb:
      "Vacuum fluorescent display. Every character is 16 SVG polygons; unlit segments stay faintly visible as ghost pixels so you read the unlit grid, not blank space. Amber phosphor flicker, scanlines, soft vignette. The TRANSMIT row shows [ENCRYPTED] until decryption handshakes in ~600ms after mount.",
  },
  {
    id: "dot",
    number: "03",
    title: "LED Dot-Matrix",
    blurb:
      'Airport-FIDS strip - row numbers, a blinking status LED, a live clock, a slow vertical scan beam. Rows boot in with a staggered fade. The email row shows "[ CLICK TO DECRYPT ]"; click or hover and the real address streams in character-by-character.',
  },
  {
    id: "term",
    number: "04",
    title: "CRT Terminal",
    blurb:
      "Amber-on-black console window with a chrome bar, scanlines, and a rare sync-roll that hints at a failing CRT. Lines type in sequentially with a persistent blinking caret. The email is a row of ░ blocks until you hover - then it runs a glyph-scramble decrypt for a PGP-handshake feel.",
  },
];
---

<Layout title="Digital display prototypes - Vinith">
  <PrototypePostShell
    meta={meta}
    kickerTag="Interactive"
    kickerTrail="Four prototypes"
    maxWidth="680px"
    footerText="MORE WRITING"
  >
    <Fragment slot="title">Digital display <em>prototypes</em></Fragment>
    <Fragment slot="lede">
      <p>
        I have been building my <a href="/about"><code>about</code></a> over the last week, and I wanted
        it to be slightly "futuristic" so for the links at the bottom of the card, I wanted kinf of a
        digital display. It had to be a thin narrow strip that flickers to show the card is powered on.
        I wanted to explore few options that would also fit the retro theme going on, so before committing
        to one direction I wanted to try several; so I built four, each with its own mechanical idiom.
      </p>
      <p>
        Every prototype also needs to show my email without getting harvested the second I push this
        site live. The address is XOR-encoded at build time, stored as a hex string in a <code
          >data-cfe</code
        > attribute, and decoded client-side on interaction. The literal <code>user@host</code> never
        appears in the rendered HTML.
      </p>
    </Fragment>

    <nav class="post-nav" aria-label="Prototype index">
      {
        prototypes.map((p) => (
          <a href={`#${p.id}`} class="post-nav-item">
            <span class="post-nav-num">{p.number}</span>
            <span class="post-nav-title">{p.title}</span>
          </a>
        ))
      }
    </nav>

    {
      prototypes.map((p) => (
        <section class="proto" id={p.id}>
          <header class="proto-head">
            <div class="proto-num">{p.number}</div>
            <h2 class="proto-title">{p.title}</h2>
          </header>
          <p class="proto-blurb">{p.blurb}</p>

          <div class="proto-card">
            <div class="proto-card-tab">
              <span class="proto-card-tab-dot" />
              Prototype · {p.number}
            </div>
            <div class="proto-card-stage">
              {p.id === "flip" && <DisplayFlipBoard fields={FIELDS} email={EMAIL} />}
              {p.id === "seg" && <DisplaySegment fields={FIELDS} email={EMAIL} />}
              {p.id === "dot" && <DisplayDotMatrix fields={FIELDS} email={EMAIL} />}
              {p.id === "term" && <DisplayTerminal fields={FIELDS} email={EMAIL} />}
            </div>
          </div>
        </section>
      ))
    }
  </PrototypePostShell>
</Layout>

<style>
  /* Each prototype section - header, blurb, then a simple card */
  .proto {
    margin: 64px 0;
    scroll-margin-top: 80px;
  }
  .proto-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 12px;
  }
  .proto-num {
    font-family: var(--font-pixel);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--ink-muted);
  }
  .proto-title {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 32,
      "SOFT" 60,
      "wght" 500;
    font-size: 28px;
    letter-spacing: -0.015em;
    color: var(--ink);
    line-height: 1;
  }
  .proto-blurb {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 18,
      "SOFT" 70,
      "wght" 400;
    font-size: 17px;
    line-height: 1.65;
    color: var(--ink-soft);
    margin-bottom: 24px;
    max-width: 62ch;
  }

  /* The simple holder - a .card with a small label tab on top. No
     skeuomorphic chrome; the display itself supplies all the flavor. */
  .proto-card {
    background: var(--bg-card);
    border: 2px solid var(--rule);
    box-shadow: 4px 4px 0 var(--rule);
    padding: 20px 22px 24px;
  }
  .proto-card-tab {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px 8px 3px;
    margin-bottom: 10px;
    font-family: var(--font-pixel);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-muted);
    background: var(--bg-inset);
    border: 1px solid var(--rule-soft);
  }
  .proto-card-tab-dot {
    width: 6px;
    height: 6px;
    background: var(--signal);
  }
  /* The Display* components carry a `margin-top: 32px` meant for the
     ID-card context. Reset here since the card is their only wrapper. */
  .proto-card-stage > :global(*) {
    margin-top: 0 !important;
  }

  .post-note {
    margin: 72px 0 40px;
    padding: 28px;
    background: var(--bg-raised);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--em);
  }
  .post-note h3 {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 24,
      "wght" 600;
    font-size: 20px;
    margin-bottom: 14px;
    color: var(--ink);
  }
  .post-note ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 10px;
  }
  .post-note li {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink-soft);
    padding-left: 18px;
    position: relative;
  }
  .post-note li::before {
    content: "→";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--em);
    font-family: var(--font-pixel);
    font-size: 13px;
  }
  .post-note strong {
    color: var(--ink);
    font-weight: 600;
  }
  .post-note code {
    font-family: var(--font-pixel);
    font-size: 12px;
    padding: 1px 5px;
    background: var(--bg-inset);
    border: 1px solid var(--rule-soft);
  }
</style>
