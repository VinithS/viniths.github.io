---
/*
  /sandbox/photos-prototypes — Direction E (mosaic + left scrubber).

  Spec the user confirmed (see docs/superpowers/specs/2026-05-28-photos-mosaic-scrubber-design.md):
   - Albums tile as justified rows (mixed aspect ratios fit together, no crop),
     reading as a magazine spread of prints on paper.
   - Each card: serif title + a pressed-in "printed index" strip (place · year)
     — a contact-sheet label, not a floating white box, not a stamp.
   - A vertical year/month scrubber down the LEFT margin, separated from the
     mosaic by a brutalist crease (paper-fold spine). Bidirectional: drag to
     glide the mosaic; scrolling moves the marker.
   - The old bottom sprocket timeline is removed.

  Album shape here mirrors what the real content collection will need to add
  (place, date, count, aspect). The schema change goes in
  src/content.config.ts when this is promoted; `aspect` is the cover's
  intrinsic width/height (measured from the asset).
*/
import Layout from "../../layouts/Layout.astro";
import PhotoAlbumGrid from "../../components/PhotoAlbumGrid.svelte";
import YearScrubber from "../../components/photos/YearScrubber.svelte";

type Album = {
  id: string;
  title: string;
  place: string;
  date: string; // YYYY-MM
  count: number;
  cover: string;
  aspect: number; // cover width / height
  frames: { src: string; alt: string }[];
};

// Cover assets + their measured aspect ratios:
//   spiderman-2.jpg 1.333 · far-cry-1.jpg 0.667 · delta-ops.jpg 0.705
//   jlp-m87.png 2.000 · spinning-blackhole.webp 1.778
const IMG = {
  spiderman: { src: "/photos/nostalgia/spiderman-2.jpg", aspect: 1.333 },
  farcry: { src: "/photos/nostalgia/far-cry-1.jpg", aspect: 0.667 },
  delta: { src: "/photos/nostalgia/delta-ops.jpg", aspect: 0.705 },
  m87: { src: "/photos/jlp-m87.png", aspect: 2.0 },
  blackhole: { src: "/photos/spinning-blackhole.webp", aspect: 1.778 },
};

const albums: Album[] = [
  {
    id: "phone-diary",
    title: "Phone diary",
    place: "Everywhere",
    date: "2025-05",
    count: 41,
    cover: IMG.m87.src,
    aspect: IMG.m87.aspect,
    frames: [
      { src: IMG.m87.src, alt: "M87 still" },
      { src: IMG.blackhole.src, alt: "Spinning black hole" },
      { src: IMG.spiderman.src, alt: "Spider-Man 2" },
    ],
  },
  {
    id: "harbor-nights",
    title: "Harbor, after dark",
    place: "Lisbon, PT",
    date: "2025-02",
    count: 16,
    cover: IMG.blackhole.src,
    aspect: IMG.blackhole.aspect,
    frames: [
      { src: IMG.blackhole.src, alt: "Quay lights on water" },
      { src: IMG.farcry.src, alt: "Tiled doorway" },
    ],
  },
  {
    id: "first-frost",
    title: "First frost",
    place: "Höfn, IS",
    date: "2025-01",
    count: 9,
    cover: IMG.farcry.src,
    aspect: IMG.farcry.aspect,
    frames: [
      { src: IMG.farcry.src, alt: "Ice on the window" },
      { src: IMG.delta.src, alt: "Frozen reeds" },
    ],
  },
  {
    id: "nostalgia",
    title: "Nostalgia",
    place: "Home",
    date: "2024-11",
    count: 3,
    cover: IMG.spiderman.src,
    aspect: IMG.spiderman.aspect,
    frames: [
      { src: IMG.spiderman.src, alt: "Spider-Man 2" },
      { src: IMG.farcry.src, alt: "Far Cry" },
      { src: IMG.delta.src, alt: "Delta Ops" },
    ],
  },
  {
    id: "cascades",
    title: "Cascades, slow",
    place: "PNW",
    date: "2024-07",
    count: 18,
    cover: IMG.delta.src,
    aspect: IMG.delta.aspect,
    frames: [
      { src: IMG.delta.src, alt: "Trail through ferns" },
      { src: IMG.farcry.src, alt: "Lake at hour 6" },
      { src: IMG.spiderman.src, alt: "Tent line, morning" },
    ],
  },
  {
    id: "long-exposures",
    title: "Long exposures",
    place: "Atacama, CL",
    date: "2024-04",
    count: 22,
    cover: IMG.m87.src,
    aspect: IMG.m87.aspect,
    frames: [
      { src: IMG.m87.src, alt: "Star trails over the salt flat" },
      { src: IMG.blackhole.src, alt: "Observatory dome" },
    ],
  },
  {
    id: "kyoto-portra",
    title: "Kyoto, on Portra",
    place: "Kyoto, JP",
    date: "2023-10",
    count: 24,
    cover: IMG.farcry.src,
    aspect: IMG.farcry.aspect,
    frames: [
      { src: IMG.farcry.src, alt: "Cobblestone alley, dusk" },
      { src: IMG.spiderman.src, alt: "Sodium-vapor doorway" },
      { src: IMG.delta.src, alt: "Bamboo, with rain" },
    ],
  },
  {
    id: "market-mornings",
    title: "Market mornings",
    place: "Oaxaca, MX",
    date: "2023-06",
    count: 31,
    cover: IMG.spiderman.src,
    aspect: IMG.spiderman.aspect,
    frames: [
      { src: IMG.spiderman.src, alt: "Crates of chiles" },
      { src: IMG.delta.src, alt: "Steam off the comal" },
    ],
  },
  {
    id: "rooftop-tape",
    title: "Rooftop, on tape",
    place: "Seoul, KR",
    date: "2023-03",
    count: 12,
    cover: IMG.blackhole.src,
    aspect: IMG.blackhole.aspect,
    frames: [
      { src: IMG.blackhole.src, alt: "Neon over the block" },
      { src: IMG.m87.src, alt: "Antenna field" },
    ],
  },
  {
    id: "study",
    title: "Quiet rooms",
    place: "—",
    date: "2022-09",
    count: 11,
    cover: IMG.delta.src,
    aspect: IMG.delta.aspect,
    frames: [
      { src: IMG.delta.src, alt: "Window light" },
      { src: IMG.farcry.src, alt: "Empty hall" },
    ],
  },
  {
    id: "first-roll",
    title: "First roll",
    place: "Backyard",
    date: "2022-03",
    count: 8,
    cover: IMG.farcry.src,
    aspect: IMG.farcry.aspect,
    frames: [
      { src: IMG.farcry.src, alt: "Overexposed sky" },
      { src: IMG.spiderman.src, alt: "The dog, blurred" },
    ],
  },
];

// Derive year from date and attach for display.
type AlbumView = Album & { year: number; month: number };
const view: AlbumView[] = albums.map((a) => {
  const [y, m] = a.date.split("-").map(Number);
  return { ...a, year: y, month: m };
});

// Group by year descending; within a year, newest month first (matches the
// scrubber's top→bottom = newest→oldest reading).
const byYear: Record<number, AlbumView[]> = {};
for (const a of view) (byYear[a.year] ??= []).push(a);
for (const y of Object.keys(byYear)) byYear[+y].sort((a, b) => b.month - a.month);
const years = Object.keys(byYear)
  .map(Number)
  .sort((a, b) => b - a);

// Scrubber range: years descending, with the set of months (1–12) that hold
// an album in each.
const range = years.map((year) => ({
  year,
  months: byYear[year].map((a) => a.month),
}));
---

<Layout title="Photos — prototypes">
  <section class="ph-head">
    <div class="ph-kicker">
      <span class="ph-pip"></span>
      Sandbox · Direction E
    </div>
    <h1 class="ph-title">
      <span class="ph-fleuron" aria-hidden="true">
        <!-- One Pentax silhouette, used once. Lives in title leading. -->
        <svg viewBox="0 0 64 40" class="fleuron-svg">
          <path d="M22 10 L28 4 L36 4 L42 10 Z" fill="currentColor" />
          <rect x="30" y="2" width="4" height="2" fill="currentColor" />
          <rect x="10" y="10" width="44" height="6" fill="currentColor" />
          <rect x="6" y="16" width="52" height="20" fill="currentColor" />
          <rect x="6" y="16" width="6" height="20" fill="currentColor" opacity="0.55" />
          <circle cx="32" cy="26" r="9" fill="var(--bg)" />
          <circle cx="32" cy="26" r="6" fill="currentColor" />
          <circle cx="50" cy="13" r="1.6" fill="var(--em)" />
        </svg>
      </span>
      Albums.
    </h1>
    <p class="ph-lede">
      Rolls and frames I've kept worth keeping. Click a card to read the roll;
      use the rail on the left to travel back through the years and months.
    </p>
  </section>

  <div class="ph-layout">
    <aside class="ph-rail">
      <YearScrubber client:load range={range} />
    </aside>

    <div class="ph-stream">
      {
        years.map((year) => (
          <section class="ph-year" id={`y-${year}`}>
            <header class="year-strip">
              <span class="year-num">{year}</span>
              <span class="year-rule" />
              <span class="year-count">
                {byYear[year].length} {byYear[year].length === 1 ? "roll" : "rolls"}
                &nbsp;·&nbsp;
                {byYear[year].reduce((s, a) => s + a.count, 0)} frames
              </span>
            </header>

            <PhotoAlbumGrid client:load albums={byYear[year]} />
          </section>
        ))
      }
    </div>
  </div>
</Layout>

<style>
  /* ============================================================
     Headline
     ============================================================ */
  .ph-head {
    max-width: 680px;
    margin: 0 auto 44px;
    padding: 24px 0 0;
  }
  .ph-kicker {
    font-family: var(--font-pixel);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-muted);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .ph-pip {
    width: 8px;
    height: 8px;
    background: var(--yellow);
    box-shadow: 0 0 0 2px var(--rule);
  }
  .ph-title {
    font-family: var(--font-serif);
    font-variation-settings: "opsz" 96, "SOFT" 60, "wght" 500;
    font-size: clamp(40px, 6.4vw, 72px);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin-bottom: 14px;
    display: inline-flex;
    align-items: baseline;
    gap: 14px;
  }
  .ph-fleuron {
    display: inline-block;
    width: 0.7em;
    height: 0.45em;
    color: var(--ink);
    transform: translateY(-0.05em);
  }
  .fleuron-svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .ph-lede {
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 52ch;
  }

  /* ============================================================
     Layout: [ rail ] ┊crease┊ [ mosaic stream ]
     ============================================================ */
  .ph-layout {
    display: grid;
    grid-template-columns: 56px 1fr;
    column-gap: 0;
    align-items: start;
  }
  .ph-rail {
    /* the scrubber inside is position: sticky, so this column just reserves
       the gutter and lets the rail track the viewport. */
    position: relative;
    height: 100%;
  }

  /* The crease: a crisp full-height paper-fold spine on the LEFT edge of the
     mosaic stream — a brutalist valley fold / exposed column rule, not a soft
     3D page-curl. Read left→right it's a hard-edged section: a lit page edge
     lifting, a shadowed wall diving into the valley, a hard structural rule
     at the fold floor, then the mirror back out. All hard stops (no blur), so
     it reads as honest structure. Built from the --crease-* token pair plus
     the --rule structural hairline at the apex, so it works in both themes
     with no per-theme override. */
  .ph-stream {
    position: relative;
    padding-left: 30px;
  }
  .ph-stream::before {
    content: "";
    position: absolute;
    left: 4px;
    top: 0;
    bottom: 0;
    width: 8px;
    background: linear-gradient(
      to right,
      var(--crease-highlight) 0,
      var(--crease-highlight) 1px,
      var(--crease-shadow) 1px,
      var(--crease-shadow) 3px,
      var(--rule) 3px,
      var(--rule) 4px,
      var(--crease-shadow) 4px,
      var(--crease-shadow) 6px,
      var(--crease-highlight) 6px,
      var(--crease-highlight) 7px,
      transparent 7px
    );
  }

  /* ============================================================
     Year sections
     ============================================================ */
  .ph-year {
    margin: 0 0 52px;
  }
  .ph-year:last-child {
    margin-bottom: 8px;
  }
  .year-strip {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin-bottom: 20px;
  }
  .year-num {
    font-family: var(--font-serif);
    font-variation-settings: "opsz" 36, "SOFT" 60, "wght" 500;
    font-size: 26px;
    letter-spacing: -0.015em;
    color: var(--ink);
  }
  .year-rule {
    flex: 1;
    height: 1px;
    background: var(--rule-soft);
    align-self: center;
  }
  .year-count {
    font-family: var(--font-pixel);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  /* Below 700px the gutter is too tight: collapse to one column, hide the
     rail + crease, mosaic goes full width. */
  @media (max-width: 700px) {
    .ph-layout {
      grid-template-columns: 1fr;
    }
    .ph-rail {
      display: none;
    }
    .ph-stream {
      padding-left: 0;
    }
    .ph-stream::before {
      display: none;
    }
  }
</style>
