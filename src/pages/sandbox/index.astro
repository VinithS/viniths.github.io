---
/*
  /sandbox — dev-only scratch page.

  The nav link to /sandbox is gated by import.meta.env.DEV in
  Layout.astro, so this route only shows up during `astro dev`. Use it
  to stage prototypes-in-progress before promoting them to real pages.

  (The "Digital display prototypes" showcase that used to live here
  was promoted to /blog/display-prototypes once it was good enough to
  be linked from /blog.)
*/

import Layout from "../../layouts/Layout.astro";

const experiments: { href: string; title: string; note: string }[] = [
  {
    href: "/blog/stamp-prototypes",
    title: "Rubber-stamp prototypes",
    note: "Promoted → /blog/stamp-prototypes",
  },
  {
    href: "/blog/display-prototypes",
    title: "Digital display prototypes",
    note: "Promoted → /blog/display-prototypes",
  },
];
---

<Layout title="Sandbox">
  <section class="sandbox">
    <header class="sandbox-head">
      <div class="sandbox-kicker">
        <span class="sandbox-pip"></span>
        Sandbox · dev only
      </div>
      <h1 class="sandbox-title">Scratch space.</h1>
      <p class="sandbox-lede">
        Rough cuts, throwaways, and works-in-progress. This route is only
        exposed in the nav during <code>astro dev</code>; production builds
        strip the link. Anything that graduates goes elsewhere.
      </p>
    </header>

    <ul class="sandbox-list">
      {
        experiments.map((e) => (
          <li>
            <a href={e.href} class="sandbox-item">
              <span class="sandbox-item-title">{e.title}</span>
              <span class="sandbox-item-note">{e.note}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>

<style>
  .sandbox {
    max-width: 680px;
    margin: 0 auto;
    padding: 40px 0 80px;
  }

  .sandbox-kicker {
    font-family: var(--font-pixel);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-muted);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .sandbox-pip {
    width: 8px;
    height: 8px;
    background: var(--yellow);
    box-shadow: 0 0 0 2px var(--rule);
  }
  .sandbox-title {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 72,
      "SOFT" 60,
      "wght" 500;
    font-size: clamp(34px, 5vw, 52px);
    line-height: 1;
    letter-spacing: -0.025em;
    margin-bottom: 16px;
  }
  .sandbox-lede {
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin-bottom: 36px;
  }
  .sandbox-lede code {
    font-family: var(--font-pixel);
    font-size: 13px;
    padding: 1px 5px;
    background: var(--bg-inset);
    border: 1px solid var(--rule-soft);
  }

  .sandbox-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 10px;
  }
  .sandbox-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    padding: 16px 18px;
    background: var(--bg-card);
    border: 1px solid var(--rule);
    text-decoration: none;
    color: var(--ink);
    transition:
      transform 0.08s ease,
      background 0.15s ease;
  }
  .sandbox-item:hover {
    transform: translateY(-1px);
    background: var(--bg-raised);
  }
  .sandbox-item-title {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 18,
      "SOFT" 60,
      "wght" 500;
    font-size: 18px;
    letter-spacing: -0.015em;
  }
  .sandbox-item-note {
    font-family: var(--font-pixel);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
</style>
