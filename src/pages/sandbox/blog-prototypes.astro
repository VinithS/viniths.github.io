  /* Cosmic-ledger marginalia.
     Two-column block: a tiny constellation chart (left, ~28px) and a
     stack of pixel meta lines (right) — STD / RA / DEC, then a hairline
     separator, then the specimen id. A circular radar-sweep
     pseudo-element sits behind the chart and animates once on row
     hover. The whole block is bracketed by a thin right rule and a
     short tick mark so it reads as something stamped into a margin. */
  .ledger-sigil {
    position: relative;
    display: grid;
    grid-template-columns: 38px 1fr;
    align-items: center;
    gap: 10px;
    padding: 6px 12px 6px 4px;
    border-right: 1px solid var(--rule-soft);
    align-self: stretch;
  }
  .ledger-sigil-tick {
    position: absolute;
    top: 50%;
    right: -1px;
    width: 5px;
    height: 1px;
    background: var(--rule);
    transform: translateY(-50%);
  }

  /* Constellation chart cell. The SVG inherits color from `currentColor`
     so it tracks the row's ink/yellow tint. Slight inner border to make
     it feel like a clipped sky-region from a star atlas. */
  .ledger-sigil-chart {
    position: relative;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink);
    border: 1px solid var(--rule-soft);
    background: var(--bg-inset);
    overflow: hidden;
  }
  .ledger-row--prototype .ledger-sigil-chart {
    color: var(--ink);
    background: var(--yellow);
    border-color: var(--rule);
  }
  .ledger-sigil-chart svg {
    display: block;
    width: 28px;
    height: 28px;
  }

  /* Radar sweep — a single rotating arc rendered as a conic gradient.
     Sits absolutely above the chart background but below the stars by
     riding on the chart cell with a low opacity. Stays paused until
     the row is hovered, then runs exactly once and resets. */
  .ledger-sigil-sweep {
    position: absolute;
    inset: 6px auto auto 4px;
    width: 36px;
    height: 36px;
    pointer-events: none;
    border-radius: 50%;
    opacity: 0;
    background: conic-gradient(
      from 0deg,
      transparent 0deg,
      var(--signal) 8deg,
      transparent 60deg,
      transparent 360deg
    );
    mix-blend-mode: screen;
    transition: opacity 0.2s ease;
  }
  .ledger-row:hover .ledger-sigil-sweep {
