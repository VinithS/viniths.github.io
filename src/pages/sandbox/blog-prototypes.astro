---
/*
  /sandbox/blog-prototypes — four directions for unifying markdown posts
  and interactive (.astro) prototypes into a single date-sorted blog index.

  Shared model: every entry has { date, title, description, tags, kind }
  where kind ∈ "writing" | "prototype". The list is fed into four
  prototypes; each renders the same items differently. Sort controls are
  rendered per-prototype so each direction's visual treatment of the
  toggle is part of the comparison.

  This is a sandbox file — the four <section class="proto"> blocks are
  isolated. Lift one wholesale into /blog/index.astro when chosen.
*/
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

type Kind = "writing" | "prototype";
type Entry = {
  date: Date;
  title: string;
  description: string;
  tags: string[];
  href: string;
  kind: Kind;
  // Number of sub-pieces in a prototype set, e.g. "4 prototypes". Optional.
  count?: number;
};

const writing: Entry[] = (await getCollection("blog")).map((p) => ({
  date: p.data.date,
  title: p.data.title,
  description: p.data.description,
  tags: p.data.tags ?? [],
  href: `/blog/${p.id}`,
  kind: "writing",
}));

const prototypes: Entry[] = [
  {
    date: new Date("2026-04-30"),
    title: "Crest prototypes",
    description:
      "Four cosmic-bureau crests drawn as 40×40 pixel SVGs — black hole, Lagrangian, observer, sidereal — each with a four-accent palette and a specimen plate.",
    tags: ["design", "svg", "css"],
    href: "/blog/crest-prototypes",
    kind: "prototype",
    count: 4,
  },
  {
    date: new Date("2026-04-25"),
    title: "Rubber-stamp prototypes",
    description:
      "Four takes on letting a visitor stamp a card with their cursor — wash-away, wet-ink smear, random surprise, and a permanent archival record that ages over time.",
    tags: ["design", "svelte", "interaction"],
    href: "/blog/stamp-prototypes",
    kind: "prototype",
    count: 4,
  },
  {
    date: new Date("2026-04-25"),
    title: "Digital display prototypes",
    description:
      "Four takes on a thin futuristic display strip — split-flap, VFD, LED dot-matrix, CRT terminal — plus a scraper-resistant email treatment.",
    tags: ["design", "css", "astro"],
    href: "/blog/display-prototypes",
    kind: "prototype",
    count: 4,
  },
];

const allEntries: Entry[] = [...writing, ...prototypes].sort(
  (a, b) => b.date.getTime() - a.date.getTime(),
);

// Same list, ascending — for the live sort toggle demos. (We render
// both orderings on the server; the toggle just hides one.)
const ascEntries: Entry[] = [...allEntries].slice().reverse();

// Group entries by year, preserving the parent ordering. Returns an
// array of { year, items[] } so we can render <h3>YEAR</h3> headers in
// the ledger prototype.
function groupByYear(list: Entry[]): { year: number; items: Entry[] }[] {
  const out: { year: number; items: Entry[] }[] = [];
  for (const e of list) {
    const y = e.date.getUTCFullYear();
    const last = out[out.length - 1];
    if (last && last.year === y) last.items.push(e);
    else out.push({ year: y, items: [e] });
  }
  return out;
}
const groupedDesc = groupByYear(allEntries);
const groupedAsc = groupByYear(ascEntries);

function fmtCompact(d: Date) {
  return d
    .toLocaleDateString("en-US", {
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
    })
    .replace(/\//g, "·");
}
// "Stardate" — last two digits of year + day-of-year, joined by a middle
// dot. Reads like an entry stamped into a star catalog rather than a
// calendar (e.g. 26·132 = day 132 of 2026). Used as the cosmic-ledger
// marginalia in prototype 03.
function stardate(d: Date) {
  const y = String(d.getUTCFullYear()).slice(-2);
  const start = Date.UTC(d.getUTCFullYear(), 0, 0);
  const diff = d.getTime() - start;
  const doy = Math.floor(diff / 86_400_000);
  return `${y}·${String(doy).padStart(3, "0")}`;
}

// Stable per-entry "specimen" id, used by the ledger and stamp protos.
function specimenId(e: Entry, i: number) {
  const seed = e.kind === "prototype" ? "P" : "T";
  return `${seed}·${String(i + 1).padStart(3, "0")}`;
}

/* ----------------------------------------------------------------
   Cosmic-ledger marginalia helpers (prototype 03 only).
   All deterministic from the entry's href so a given post has a
   stable constellation + coordinates between rebuilds.
   ---------------------------------------------------------------- */

// FNV-1a 32-bit string hash. Tiny, stable, no deps.
function fnv1a(s: string) {
  let h = 0x811c9dc5;
  for (let i = 0; i < s.length; i++) {
    h ^= s.charCodeAt(i);
    h = Math.imul(h, 0x01000193) >>> 0;
  }
  return h >>> 0;
}

// Mulberry32 — seedable PRNG. Returns a function yielding [0,1).
function mulberry32(seed: number) {
  let a = seed >>> 0;
  return () => {
    a = (a + 0x6d2b79f5) >>> 0;
    let t = a;
    t = Math.imul(t ^ (t >>> 15), t | 1);
    t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

type Constellation = {
  size: number;
  stars: { x: number; y: number; r: number; bright: boolean }[];
  edges: [number, number][];
};

// Build a small unique "constellation" for an entry.
// - Stars are placed on a 28x28 grid with a small jitter, biased away
//   from the borders so nothing clips.
// - Edges form a chain (i -> i+1) so it always reads as one figure
//   rather than disconnected dots; one extra cross-edge adds variety.
// - One star is marked "bright" (rendered larger) so the eye latches.
function buildConstellation(seed: string): Constellation {
  const rand = mulberry32(fnv1a(seed));
  const size = 28;
  const margin = 4;
  const count = 4 + Math.floor(rand() * 3); // 4..6
  const stars: Constellation["stars"] = [];
  for (let i = 0; i < count; i++) {
    stars.push({
      x: margin + Math.round(rand() * (size - margin * 2)),
      y: margin + Math.round(rand() * (size - margin * 2)),
      r: 1,
      bright: false,
    });
  }
  const brightIdx = Math.floor(rand() * count);
  stars[brightIdx].bright = true;

  const edges: [number, number][] = [];
  for (let i = 0; i < count - 1; i++) edges.push([i, i + 1]);
  if (count >= 4) {
    // one extra non-adjacent edge to break the strict chain
    const a = Math.floor(rand() * count);
    let b = Math.floor(rand() * count);
    if (Math.abs(a - b) < 2) b = (b + 2) % count;
    edges.push([a, b]);
  }
  return { size, stars, edges };
}

// Fake right-ascension (HHhMMm) and declination (±DD°MM′) — derived
// from the same hash so they stay locked to the entry. Looks like a
// tracking-station coordinate readout, not real sky data.
function celestialCoords(seed: string) {
  const r = mulberry32(fnv1a(seed) ^ 0x5a17);
  const raH = Math.floor(r() * 24);
  const raM = Math.floor(r() * 60);
  const decSign = r() < 0.5 ? "-" : "+";
  const decD = Math.floor(r() * 90);
  const decM = Math.floor(r() * 60);
  return {
    ra: `${String(raH).padStart(2, "0")}h${String(raM).padStart(2, "0")}m`,
    dec: `${decSign}${String(decD).padStart(2, "0")}°${String(decM).padStart(2, "0")}`,
  };
}
---

<Layout title="Blog index — prototypes">
  <section class="page">
    <header class="page-head">
      <div class="page-kicker">
        <span class="page-pip"></span>
        Sandbox · blog index directions
      </div>
      <h1 class="page-title">
        Four ways <em>to file</em> the writing<br />and the prototypes together.
      </h1>
      <p class="page-lede">
        Right now <code>/blog</code> shows two separate stacks: a featured row of
        interactive <span class="under">prototype posts</span>, then a list of markdown
        entries below it. These four directions all merge them into a single
        date-sorted feed and explore different ways to mark which is which —
        plus a sort toggle that defaults to newest-first.
      </p>
      <div class="page-legend">
        <span class="legend-item">
          <span class="legend-dot legend-dot--ink"></span>
          <span class="legend-label">Writing</span>
          <span class="legend-meta">{writing.length} markdown posts</span>
        </span>
        <span class="legend-item">
          <span class="legend-dot legend-dot--accent"></span>
          <span class="legend-label">Prototype</span>
          <span class="legend-meta">{prototypes.length} interactive sets</span>
        </span>
      </div>
    </header>

    <!-- ============================================================
         01 — Magazine Contents
         Editorial contents-page list. Pixel numerals on the left,
         big serif title row, type pill on the right. The kind is
         encoded by the pill color + label, no extra ornament.
         ============================================================ -->
    <section class="proto" id="contents">
      <header class="proto-head">
        <span class="proto-num">01</span>
        <h2 class="proto-title">Magazine Contents</h2>
        <p class="proto-blurb">
          A masthead-and-table-of-contents read. Each entry is a row with a
          two-digit numeral, a serif title, and a small typographic pill on the
          right. Prototypes get a yellow pill with the count; writing gets an
          ink-on-paper pill that just says <code>TEXT</code>. The whole list
          breathes — generous leading, hard rule above each row — so the
          prototype pills register without shouting.
        </p>
      </header>

      <div class="contents-frame card">
        <div class="contents-bar">
          <span class="contents-bar-l">Vol. I &nbsp;·&nbsp; Index</span>
          <div class="sort-controls">
            <span class="sort-label">Sort</span>
            <button class="sort-btn is-on" data-sort-target="contents" data-sort="desc">Newest</button>
            <button class="sort-btn" data-sort-target="contents" data-sort="asc">Oldest</button>
          </div>
        </div>
        <ol class="contents-list" data-sort-list="contents" data-sort-state="desc">
          {
            allEntries.map((e, i) => (
              <li class={`contents-row contents-row--${e.kind}`} data-order-desc={i} data-order-asc={allEntries.length - 1 - i}>
                <span class="contents-num">{String(i + 1).padStart(2, "0")}</span>
                <a class="contents-link" href={e.href}>
                  <span class="contents-title-row">
                    <span class="contents-title">{e.title}</span>
                    <span class="contents-leader" aria-hidden="true" />
                    <span class="contents-date">{fmtCompact(e.date)}</span>
                  </span>
                  <span class="contents-desc">{e.description}</span>
                </a>
                <span class={`contents-pill contents-pill--${e.kind}`}>
                  {e.kind === "prototype" ? (
                    <>
                      <span class="contents-pill-glyph" aria-hidden="true">▣</span>
                      Proto · {e.count}
                    </>
                  ) : (
                    <>
                      <span class="contents-pill-glyph" aria-hidden="true">¶</span>
                      Text
                    </>
                  )}
                </span>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <!-- ============================================================
         02 — Filing Tabs
         Chunky cards with a colored vertical tab on the left edge
         encoding type. Tab carries the kind label rotated 90°. The
         body is uniform between kinds — only the tab differs.
         ============================================================ -->
    <section class="proto" id="tabs">
      <header class="proto-head">
        <span class="proto-num">02</span>
        <h2 class="proto-title">Filing Tabs</h2>
        <p class="proto-blurb">
          Manila-folder logic. Each entry is a hard-offset card with a vertical
          tab spine. The spine is yellow for prototypes (with a small
          interactive glyph) and ink for writing — the same shape, different
          identity. Sort is two arcade buttons; flipping it slides the cards
          back into a new order with a tiny stagger.
        </p>
      </header>

      <div class="tabs-bar">
        <span class="tabs-bar-l">3 prototype sets · 2 written</span>
        <div class="sort-controls">
          <span class="sort-label">Order</span>
          <button class="sort-btn is-on" data-sort-target="tabs" data-sort="desc">↓ Newest</button>
          <button class="sort-btn" data-sort-target="tabs" data-sort="asc">↑ Oldest</button>
        </div>
      </div>

      <ul class="tabs-list" data-sort-list="tabs" data-sort-state="desc">
        {
          allEntries.map((e, i) => (
            <li class={`tab-card tab-card--${e.kind}`} data-order-desc={i} data-order-asc={allEntries.length - 1 - i}>
              <a class="tab-link" href={e.href}>
                <span class="tab-spine" aria-hidden="true">
                  <span class="tab-spine-text">
                    {e.kind === "prototype" ? `Prototype · ${e.count ?? ""}` : "Writing"}
                  </span>
                </span>
                <span class="tab-body">
                  <span class="tab-meta">
                    <span class="tab-date">{fmtCompact(e.date)}</span>
                    {e.tags.slice(0, 3).map((t) => (
                      <span class="tag-pixel">{t}</span>
                    ))}
                  </span>
                  <span class="tab-title">{e.title}</span>
                  <span class="tab-desc">{e.description}</span>
                  <span class="tab-cta">
                    {e.kind === "prototype" ? "Open the set" : "Read the post"}
                    <span class="tab-cta-arrow" aria-hidden="true">→</span>
                  </span>
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- ============================================================
         03 — Ledger Plate
         Institutional / specimen feel. Year banners, narrow date and
         specimen-id columns, a glyph column for type. Leans into the
         "registry of transmissions from the observer" frame.
         ============================================================ -->
    <section class="proto" id="ledger">
      <header class="proto-head">
        <span class="proto-num">03</span>
        <h2 class="proto-title">Ledger Plate</h2>
        <p class="proto-blurb">
          Specimen-table treatment. Each row is a narrow strip with the date,
          a specimen id (<code>T-001</code> for text, <code>P-001</code> for
          prototype), a type glyph, and the title. Year banners are pixel
          pills. The kind is encoded twice — by the <code>T</code>/<code>P</code>
          prefix and by a glyph swatch — so it scans even when you skim
          the left rail.
        </p>
      </header>

      <div class="ledger-frame">
        <div class="ledger-bar">
          <span class="ledger-bar-l">
            <span class="ledger-bar-pip" />
            Field log · {allEntries.length} transmissions
          </span>
          <button class="ledger-sort" data-ledger-toggle aria-label="Toggle sort order" data-state="desc">
            <span class="ledger-sort-label">Latest first</span>
            <span class="ledger-sort-glyph" aria-hidden="true">↓</span>
          </button>
        </div>

        {/* DESCENDING (default) */}
        <div class="ledger-stack" data-sort-list="ledger" data-sort-state="desc">
          {
            groupedDesc.map((group) => (
              <div class="ledger-group" data-ledger-mode="desc">
                <div class="ledger-year">
                  <span class="ledger-year-pill">YR · {group.year}</span>
                  <span class="ledger-year-rule" />
                  <span class="ledger-year-count">{group.items.length} entries</span>
                </div>
                <ul class="ledger-list">
                  {group.items.map((e) => {
                    const idx = allEntries.indexOf(e);
                    const sid = specimenId(e, idx);
                    return (
                      <li class={`ledger-row ledger-row--${e.kind}`}>
                        <a class="ledger-link" href={e.href}>
                          <span class="ledger-sigil" aria-hidden="true">
                            <span class="ledger-sigil-sweep" />
                            <span class="ledger-sigil-tick" />
                            {(() => {
                              const c = buildConstellation(e.href);
                              const coords = celestialCoords(e.href);
                              return (
                                <>
                                  <span class="ledger-sigil-chart">
                                    <svg
                                      viewBox={`0 0 ${c.size} ${c.size}`}
                                      shape-rendering="crispEdges"
                                      width={c.size}
                                      height={c.size}
                                    >
                                      {c.edges.map(([a, b]) => (
                                        <line
                                          x1={c.stars[a].x}
                                          y1={c.stars[a].y}
                                          x2={c.stars[b].x}
                                          y2={c.stars[b].y}
                                          stroke="currentColor"
                                          stroke-opacity="0.45"
                                          stroke-width="0.5"
                                        />
                                      ))}
                                      {c.stars.map((s) =>
                                        s.bright ? (
                                          <>
                                            <rect
                                              x={s.x - 1.5}
                                              y={s.y - 0.5}
                                              width="3"
                                              height="1"
                                              fill="currentColor"
                                            />
                                            <rect
                                              x={s.x - 0.5}
                                              y={s.y - 1.5}
                                              width="1"
                                              height="3"
                                              fill="currentColor"
                                            />
                                          </>
                                        ) : (
                                          <rect
                                            x={s.x - 0.5}
                                            y={s.y - 0.5}
                                            width="1"
                                            height="1"
                                            fill="currentColor"
                                          />
                                        ),
                                      )}
                                    </svg>
                                  </span>
                                  <span class="ledger-sigil-meta">
                                    <span class="ledger-sigil-line">
                                      <span class="ledger-sigil-pre">STD</span>
                                      <span class="ledger-sigil-val">{stardate(e.date)}</span>
                                    </span>
                                    <span class="ledger-sigil-line">
                                      <span class="ledger-sigil-pre">RA</span>
                                      <span class="ledger-sigil-val">{coords.ra}</span>
                                    </span>
                                    <span class="ledger-sigil-line">
                                      <span class="ledger-sigil-pre">DEC</span>
                                      <span class="ledger-sigil-val">{coords.dec}</span>
                                    </span>
                                    <span class="ledger-sigil-rule" />
                                    <span class="ledger-sigil-id">{sid}</span>
                                  </span>
                                </>
                              );
                            })()}
                          </span>
                          <span class="ledger-body">
                            <span class="ledger-title">{e.title}</span>
                            <span class="ledger-desc">{e.description}</span>
                          </span>
                          <span class="ledger-kind">
                            {e.kind === "prototype"
                              ? `INTERACTIVE · n=${e.count ?? "?"}`
                              : "WRITTEN"}
                          </span>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            ))
          }
        </div>

        {/* ASCENDING (hidden until toggled) */}
        <div class="ledger-stack" data-sort-list="ledger" data-sort-state="asc" hidden>
          {
            groupedAsc.map((group) => (
              <div class="ledger-group" data-ledger-mode="asc">
                <div class="ledger-year">
                  <span class="ledger-year-pill">YR · {group.year}</span>
                  <span class="ledger-year-rule" />
                  <span class="ledger-year-count">{group.items.length} entries</span>
                </div>
                <ul class="ledger-list">
                  {group.items.map((e) => {
                    const idx = allEntries.indexOf(e);
                    const sid = specimenId(e, idx);
                    return (
                      <li class={`ledger-row ledger-row--${e.kind}`}>
                        <a class="ledger-link" href={e.href}>
                          <span class="ledger-sigil" aria-hidden="true">
                            <span class="ledger-sigil-sweep" />
                            <span class="ledger-sigil-tick" />
                            {(() => {
                              const c = buildConstellation(e.href);
                              const coords = celestialCoords(e.href);
                              return (
                                <>
                                  <span class="ledger-sigil-chart">
                                    <svg
                                      viewBox={`0 0 ${c.size} ${c.size}`}
                                      shape-rendering="crispEdges"
                                      width={c.size}
                                      height={c.size}
                                    >
                                      {c.edges.map(([a, b]) => (
                                        <line
                                          x1={c.stars[a].x}
                                          y1={c.stars[a].y}
                                          x2={c.stars[b].x}
                                          y2={c.stars[b].y}
                                          stroke="currentColor"
                                          stroke-opacity="0.45"
                                          stroke-width="0.5"
                                        />
                                      ))}
                                      {c.stars.map((s) =>
                                        s.bright ? (
                                          <>
                                            <rect
                                              x={s.x - 1.5}
                                              y={s.y - 0.5}
                                              width="3"
                                              height="1"
                                              fill="currentColor"
                                            />
                                            <rect
                                              x={s.x - 0.5}
                                              y={s.y - 1.5}
                                              width="1"
                                              height="3"
                                              fill="currentColor"
                                            />
                                          </>
                                        ) : (
                                          <rect
                                            x={s.x - 0.5}
                                            y={s.y - 0.5}
                                            width="1"
                                            height="1"
                                            fill="currentColor"
                                          />
                                        ),
                                      )}
                                    </svg>
                                  </span>
                                  <span class="ledger-sigil-meta">
                                    <span class="ledger-sigil-line">
                                      <span class="ledger-sigil-pre">STD</span>
                                      <span class="ledger-sigil-val">{stardate(e.date)}</span>
                                    </span>
                                    <span class="ledger-sigil-line">
                                      <span class="ledger-sigil-pre">RA</span>
                                      <span class="ledger-sigil-val">{coords.ra}</span>
                                    </span>
                                    <span class="ledger-sigil-line">
                                      <span class="ledger-sigil-pre">DEC</span>
                                      <span class="ledger-sigil-val">{coords.dec}</span>
                                    </span>
                                    <span class="ledger-sigil-rule" />
                                    <span class="ledger-sigil-id">{sid}</span>
                                  </span>
                                </>
                              );
                            })()}
                          </span>
                          <span class="ledger-body">
                            <span class="ledger-title">{e.title}</span>
                            <span class="ledger-desc">{e.description}</span>
                          </span>
                          <span class="ledger-kind">
                            {e.kind === "prototype"
                              ? `INTERACTIVE · n=${e.count ?? "?"}`
                              : "WRITTEN"}
                          </span>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============================================================
         04 — Stamped Cards
         Postal/archival. Each entry is a card with a slightly off-axis
         "stamp" in its top-right corner. INTERACTIVE / N=4 for proto,
         a smaller TEXT seal for markdown. Stamps use a hard-edge SVG
         outline only — no rubber-ink filter — so they read clearly in
         a list.
         ============================================================ -->
    <section class="proto" id="stamped">
      <header class="proto-head">
        <span class="proto-num">04</span>
        <h2 class="proto-title">Stamped Cards</h2>
        <p class="proto-blurb">
          A small archive desk. Each entry is a paper card with a corner stamp
          identifying its kind: <code>INTERACTIVE</code> on prototypes,
          <code>TEXT</code> on writing. Stamps tilt a couple of degrees and
          carry a fake control number so the page feels less like a CMS
          dump and more like something filed. The grid is two columns at
          desktop, single at mobile.
        </p>
      </header>

      <div class="stamp-bar">
        <span class="stamp-bar-l">Recent intake · descending</span>
        <div class="sort-controls">
          <span class="sort-label">Receipt order</span>
          <button class="sort-btn is-on" data-sort-target="stamped" data-sort="desc">Newest in</button>
          <button class="sort-btn" data-sort-target="stamped" data-sort="asc">Oldest first</button>
        </div>
      </div>

      <ul class="stamp-grid" data-sort-list="stamped" data-sort-state="desc">
        {
          allEntries.map((e, i) => {
            const sid = specimenId(e, i);
            return (
              <li class={`stamp-card stamp-card--${e.kind}`} data-order-desc={i} data-order-asc={allEntries.length - 1 - i}>
                <a class="stamp-link" href={e.href}>
                  <span class="stamp-corner">
                    <svg class="stamp-svg" viewBox="0 0 110 110" aria-hidden="true">
                      <rect x="6" y="6" width="98" height="98" fill="none" stroke="currentColor" stroke-width="1.5" stroke-dasharray="3 3"/>
                      <rect x="11" y="11" width="88" height="88" fill="none" stroke="currentColor" stroke-width="1"/>
                    </svg>
                    <span class="stamp-text">
                      <span class="stamp-text-top">
                        {e.kind === "prototype" ? "Interactive" : "Text"}
                      </span>
                      <span class="stamp-text-mid">
                        {e.kind === "prototype" ? `N · ${e.count ?? "?"}` : "Markdown"}
                      </span>
                      <span class="stamp-text-bot">{sid}</span>
                    </span>
                  </span>
                  <span class="stamp-eyebrow">
                    <span class="stamp-eyebrow-pip" />
                    {fmtCompact(e.date)}
                  </span>
                  <span class="stamp-title">{e.title}</span>
                  <span class="stamp-desc">{e.description}</span>
                  <span class="stamp-foot">
                    <span class="stamp-tags">
                      {e.tags.slice(0, 4).map((t) => (
                        <span class="tag-pixel">{t}</span>
                      ))}
                    </span>
                    <span class="stamp-arrow" aria-hidden="true">→</span>
                  </span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </section>
  </section>
</Layout>

<script>
  /*
    Sort toggle. Each prototype declares:
      - a control row with [data-sort-target="X"] [data-sort="desc|asc"]
      - one or more lists with [data-sort-list="X"] [data-sort-state]

    For prototypes 01/02/04 the same <ul>/<ol> is reused — children
    carry data-order-desc and data-order-asc attributes and we restyle
    `order` on flip so DOM order doesn't change (lets us animate).

    For prototype 03 (ledger) the year-grouping makes a single-list
    flip awkward, so we render two complete grouped stacks and just
    flip [hidden] between them.
  */
  type Dir = "desc" | "asc";

  function setActive(target: string, dir: Dir) {
    document
      .querySelectorAll<HTMLButtonElement>(`button.sort-btn[data-sort-target="${target}"]`)
      .forEach((b) => b.classList.toggle("is-on", b.dataset.sort === dir));
  }

  function applyOrder(target: string, dir: Dir) {
    const lists = document.querySelectorAll<HTMLElement>(
      `[data-sort-list="${target}"]`,
    );
    lists.forEach((list) => {
      // Two-stack mode: lists carry an explicit data-sort-state to switch on.
      if (lists.length > 1) {
        const state = list.dataset.sortState as Dir | undefined;
        list.toggleAttribute("hidden", state !== dir);
        return;
      }
      // Single-list mode: flip CSS `order` on each child.
      list.dataset.sortState = dir;
      list.querySelectorAll<HTMLElement>("[data-order-desc]").forEach((row) => {
        const v = dir === "desc" ? row.dataset.orderDesc : row.dataset.orderAsc;
        if (v) row.style.order = v;
      });
    });
  }

  document.querySelectorAll<HTMLButtonElement>("button.sort-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const target = btn.dataset.sortTarget;
      const dir = (btn.dataset.sort as Dir) || "desc";
      if (!target) return;
      setActive(target, dir);
      applyOrder(target, dir);
    });
  });

  // Ledger uses a single button that flips between desc/asc and
  // re-labels itself. The arrow glyph rotates via [data-state] in CSS.
  document
    .querySelectorAll<HTMLButtonElement>("button[data-ledger-toggle]")
    .forEach((btn) => {
      const labelEl = btn.querySelector<HTMLElement>(".ledger-sort-label");
      btn.addEventListener("click", () => {
        const next: Dir = btn.dataset.state === "desc" ? "asc" : "desc";
        btn.dataset.state = next;
        if (labelEl) {
          labelEl.textContent = next === "desc" ? "Latest first" : "Earliest first";
        }
        applyOrder("ledger", next);
      });
    });
</script>

