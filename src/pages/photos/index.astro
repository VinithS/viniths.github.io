---
import Layout from "../../layouts/Layout.astro";
import SectionTag from "../../components/SectionTag.astro";
import PhotoAlbumGrid from "../../components/PhotoAlbumGrid.svelte";
import AlbumCreator from "../../components/dev/AlbumCreator.svelte";
import { getCollection } from "astro:content";

// One continuous mosaic, newest first. `date` is "YYYY-MM" so a lexical
// sort is chronological; descending = newest at the top.
const albums = (await getCollection("photos"))
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .map((album) => ({
    id: album.id,
    title: album.data.title,
    place: album.data.description,
    count: album.data.images.length,
    aspect: album.data.aspect,
    cover: album.data.cover,
  }));

// Dev-only album creator. import.meta.env.DEV is statically false in a
// build, so the island import and this block are dead-code-stripped.
const showCreator = import.meta.env.DEV;
---

<Layout title="Photos - Vinith">
  <section class="band">
    <header class="section-head">
      <SectionTag number="02" label="Photos" accent="green" />
      <h1>Albums.</h1>
    </header>

    {showCreator && <AlbumCreator client:load />}

    <PhotoAlbumGrid client:load albums={albums} />
  </section>
</Layout>

<style>
  .band {
    padding: 40px 0 20px;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 36px;
  }
  .section-head h1 {
    font-variation-settings:
      "opsz" 72,
      "SOFT" 60,
      "wght" 500;
    font-size: clamp(32px, 4.5vw, 54px);
    letter-spacing: -0.025em;
    line-height: 1;
  }
</style>
