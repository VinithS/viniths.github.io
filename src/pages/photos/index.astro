---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const albums = await getCollection("photos");
---

<Layout title="Photos — Vinith">
  <section class="photos-page">
    <h1>Photos</h1>
    <p class="page-desc">Browse the albums.</p>
    <div class="albums">
      {
        albums.map((album) => (
          <a href={`/photos/${album.id}`} class="album-card">
            <div class="album-thumb">
              <img src={album.data.cover} alt={album.data.title} loading="lazy" />
              <div class="scanlines" />
            </div>
            <div class="album-info">
              <h2>{album.data.title}</h2>
              <span class="mono img-count">
                {album.data.images.length} image{album.data.images.length !== 1 && "s"}
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>

<style>
  .photos-page h1 {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 4px;
  }

  .page-desc {
    font-size: 14px;
    color: var(--text-muted);
    margin-bottom: 32px;
  }

  .albums {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 16px;
  }

  .album-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.15s ease,
      background 0.15s ease;
  }

  .album-card:hover {
    border-color: var(--text-muted);
    background: var(--bg-hover);
    color: inherit;
  }

  .album-thumb {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--bg-primary);
  }

  .album-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0px,
      transparent 2px,
      rgba(0, 0, 0, 0.15) 2px,
      rgba(0, 0, 0, 0.15) 4px
    );
    pointer-events: none;
  }

  .album-info {
    padding: 12px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .album-info h2 {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .img-count {
    font-size: 12px;
    color: var(--text-muted);
  }
</style>
