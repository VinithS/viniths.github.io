---
import Layout from "../../layouts/Layout.astro";
import PhotoViewer from "../../components/PhotoViewer.svelte";
import SectionTag from "../../components/SectionTag.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const albums = await getCollection("photos");
  return albums.map((album) => ({
    params: { album: album.id },
    props: { album },
  }));
}

const { album } = Astro.props;
---

<Layout title={`${album.data.title} - Photos - Vinith`}>
  <section class="album-page">
    <a href="/photos" class="back">&larr; ALBUMS</a>
    <header class="album-head">
      <SectionTag number="02" label="Photos" accent="green" />
      <h1>{album.data.title}</h1>
      <p class="album-desc">{album.data.description}</p>
    </header>

    <PhotoViewer
      client:load
      images={album.data.images}
      albumTitle={album.data.title}
    />
  </section>
</Layout>

<style>
  .album-page {
    max-width: 860px;
    margin: 0 auto;
    padding: 20px 0;
  }

  .back {
    font-family: var(--font-pixel);
    font-size: 10px;
    letter-spacing: 0.15em;
    color: var(--ink-muted);
    display: inline-block;
    margin-bottom: 24px;
  }
  .back:hover {
    color: var(--ink);
  }

  .album-head {
    margin-bottom: 28px;
  }
  .album-head :global(.section-tag) {
    margin-bottom: 10px;
  }

  h1 {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 60,
      "SOFT" 60,
      "wght" 500;
    font-size: clamp(30px, 4vw, 44px);
    letter-spacing: -0.025em;
    line-height: 1.02;
    margin-bottom: 8px;
  }

  .album-desc {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 16,
      "SOFT" 80,
      "wght" 400;
    font-size: 16px;
    color: var(--ink-muted);
  }
</style>
