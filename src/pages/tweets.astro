---
import Layout from "../layouts/Layout.astro";
import SectionTag from "../components/SectionTag.astro";
import { getCollection } from "astro:content";
import { formatPostDateCompact } from "../lib/format-date";

const tweets = (await getCollection("tweets")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const accents = ["red", "blue", "yellow", "green"] as const;
---

<Layout title="Notes - Vinith">
  <section class="band">
    <header class="section-head">
      <SectionTag number="03" label="Notes" accent="blue" />
      <h1>Scraps &amp; thoughts.</h1>
    </header>

    <!-- A compact vertical feed: each note hangs off a single timeline
         spine (the hairline running down the gutter), newest first. The
         spine is honest structure, not chrome — it's what makes the list
         read as one continuous stream rather than a grid of boxes. -->
    <ol class="feed">
      {
        tweets.map((t, i) => (
          <li class={`note note--${accents[i % accents.length]}`}>
            <span class="note-mark" aria-hidden="true" />
            <time class="note-date" datetime={t.data.date.toISOString()}>
              {formatPostDateCompact(t.data.date)}
            </time>
            <p class="note-text">{t.data.text}</p>
          </li>
        ))
      }
    </ol>
  </section>
</Layout>

<style>
  .band {
    padding: 40px 0 20px;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 32px;
  }
  .section-head h1 {
    font-variation-settings:
      "opsz" 72,
      "SOFT" 60,
      "wght" 500;
    font-size: clamp(32px, 4.5vw, 54px);
    letter-spacing: -0.025em;
    line-height: 1;
  }

  /* ---- Feed ---- */
  .feed {
    list-style: none;
    /* A readable single-column measure — a feed, not a grid. */
    max-width: 60ch;
    margin: 0;
    padding: 0;
  }

  /* Each note hangs off the gutter spine. The spine is a 1px rule drawn
     down the left padding via a pseudo-element on each row; consecutive
     rows stack their spines into one continuous line. */
  .note {
    position: relative;
    padding: 4px 0 22px 26px;
  }
  .note::before {
    content: "";
    position: absolute;
    left: 3px;
    top: 6px;
    bottom: 0;
    width: 1px;
    background: var(--rule-soft);
  }
  /* The last note's spine stops at its mark (nothing below to connect). */
  .note:last-child::before {
    display: none;
  }

  /* The accent mark that pins each note to the spine. */
  .note-mark {
    position: absolute;
    left: 0;
    top: 6px;
    width: 7px;
    height: 7px;
    box-shadow: 0 0 0 1px var(--rule);
  }
  .note--red .note-mark {
    background: var(--red);
  }
  .note--blue .note-mark {
    background: var(--blue);
  }
  .note--yellow .note-mark {
    background: var(--yellow);
  }
  .note--green .note-mark {
    background: var(--green);
  }

  .note-date {
    display: block;
    font-family: var(--font-pixel);
    font-size: 9px;
    color: var(--ink-muted);
    letter-spacing: 0.14em;
    margin-bottom: 6px;
  }
  .note-text {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 16,
      "SOFT" 80,
      "wght" 400;
    font-size: 16px;
    line-height: 1.5;
    color: var(--ink);
    text-wrap: pretty;
  }
  .note-text em {
    font-style: italic;
    color: var(--ink-soft);
  }
</style>
