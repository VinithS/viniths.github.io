---
import Layout from "../layouts/Layout.astro";
import SectionTag from "../components/SectionTag.astro";
import { getCollection } from "astro:content";

const tweets = (await getCollection("tweets")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const accents = ["red", "blue", "yellow", "green"] as const;
---

<Layout title="Notes - Vinith">
  <section class="band">
    <header class="section-head">
      <SectionTag number="03" label="Notes" accent="blue" />
      <h1>Scraps &amp; thoughts.</h1>
    </header>

    <div class="notes">
      {
        tweets.map((t, i) => (
          <article class={`note note--${accents[i % accents.length]}`}>
            <div class="note-date">
              {t.data.date
                .toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "2-digit",
                  day: "2-digit",
                })
                .replace(/\//g, "·")}
            </div>
            <p>{t.data.text}</p>
          </article>
        ))
      }
    </div>
  </section>
</Layout>

<style>
  .band {
    padding: 40px 0 20px;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 36px;
  }
  .section-head h1 {
    font-variation-settings:
      "opsz" 72,
      "SOFT" 60,
      "wght" 500;
    font-size: clamp(32px, 4.5vw, 54px);
    letter-spacing: -0.025em;
    line-height: 1;
  }

  .notes {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .note {
    background: var(--bg-card);
    border-left: 3px solid var(--ink);
    padding: 20px 22px;
    position: relative;
  }
  .note::before {
    content: "";
    position: absolute;
    top: -1px;
    left: -3px;
    width: 8px;
    height: 8px;
  }
  .note--red::before {
    background: var(--red);
  }
  .note--blue::before {
    background: var(--blue);
  }
  .note--yellow::before {
    background: var(--yellow);
  }
  .note--green::before {
    background: var(--green);
  }

  .note-date {
    font-family: var(--font-pixel);
    font-size: 10px;
    color: var(--ink-muted);
    letter-spacing: 0.12em;
    margin-bottom: 8px;
  }
  .note p {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 16,
      "SOFT" 80,
      "wght" 400;
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink);
  }
  .note p em {
    font-style: italic;
    color: var(--ink-soft);
  }

  @media (max-width: 720px) {
    .notes {
      grid-template-columns: 1fr;
    }
  }
</style>
