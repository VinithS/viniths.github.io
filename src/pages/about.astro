---
/*
  /about — Bureau of Cosmic Census passport, as a two-faced FLIP CARD.

  A passport cover (FoilCard) holds a single page that flips:

    FRONT — the data page (stampable). A dense, single-column ID card:
      masthead → barcode → small STILL passport photo → name +
      classification → cycling status verb → 2×2 field grid → Remarks
      prose → slim contact footer. The portrait is small here (a printed
      photo), so nothing forces the empty space the old wide layout had.
      Single column = the mobile layout for free.

    BACK — the living portrait (NOT stampable). The full animated
      PortraitScene gets the whole card: walk-in (on reveal), turn,
      idle, gaze, parallax starfield. "A passport photo doesn't move;
      turn to it and it comes alive."

  The FoilCard cover itself does NOT flip — it stays put and owns the
  cursor/pointer vars + foil shine. Only the page inside (.passport-inner)
  rotates. The back face inherits the cover's pointer vars for parallax.

  Composition follows DESIGN.md "Scale as composition": a narrow card
  sits small in a wide field — the human entry against the institution,
  one star in a chart, not a hero shot. The leftover space is deliberate
  deep field, not an accidental gap.
*/

import Layout from "../layouts/Layout.astro";
import FoilCard from "../components/primitives/FoilCard.astro";
import StampArea from "../components/StampArea.svelte";
import StampTray from "../components/StampTray.svelte";

import MastheadFrame from "../components/crests/MastheadFrame.astro";
import CrestBlackHole from "../components/crests/CrestBlackHole.astro";

import MetalBarcode from "../components/primitives/MetalBarcode.astro";
import PassportFields from "../components/primitives/PassportFields.astro";
import PassportField from "../components/primitives/PassportField.astro";
import ObserverStatus from "../components/ObserverStatus.svelte";
import CardFooter from "../components/primitives/CardFooter.astro";
import PortraitScene from "../components/PortraitScene.svelte";

// Same four stamps as before. Passport theme — stamping fits.
const STAMPS = [
  { id: "bee", kind: "ink", src: "/assets/bee.svg", accent: "yellow", label: "Bee" },
  { id: "coffee", kind: "ink", src: "/assets/coffee.svg", accent: "red", label: "Coffee" },
  {
    id: "fairytail",
    kind: "ink",
    src: "/assets/fairy-tail.svg",
    accent: "blue",
    label: "Fairy Tail",
  },
  { id: "date", kind: "date", label: "Date" },
];

// Biographical data. The footer telemetry + name are built from these.
const BIO = {
  surname: "SHARMA",
  given: "VINITH",
  genus: "Homo Sapien",
  seat: "Terra ☉ Sol",
  classification: "Emergent Observer",
  vocation: "Art",
  issued: "1997",
};

const EMAIL = "vinith.sharma13@gmail.com";
const COORD = "47.62,-122.35";
---

<Layout title="About · Vinith">
  <section class="about-page">
    <FoilCard maxWidth={460} stampSrc="/assets/wisteria.svg" ticks={false}>
      <!-- The flip stage. perspective lives on .passport-stage; only
           .passport-inner rotates. data-flipped is toggled by the
           button below via the inline script. -->
      <div class="passport-stage" data-passport>
        <div class="passport-inner">
          <!-- ===== FRONT: the data page (stampable) ===== -->
          <div class="face face--front">
            <!-- StampArea covers the FRONT only. It bleeds to the card
                 edges via FoilCard's --foil-pad-* vars. The flip button
                 + back face are marked data-no-stamp so the stamp hit
                 test skips them. -->
            <StampArea client:load ageMs={30000} />

            <MastheadFrame
              institution="Bureau of Cosmic Census"
              department="Field Office · Milky Way · Orion Arm"
              kicker="Cosmological Authority"
            >
              <CrestBlackHole slot="crest" size={88} />
            </MastheadFrame>

            <!-- Printed photo + identity. Centered column. The photo is
                 the original flat pixel portrait (a printed passport
                 photo); the animated night-sky version lives on the back. -->
            <div class="id-block">
              <figure class="id-photo">
                <img src="/portrait-placeholder.svg" alt="A pixelated portrait of Vinith." />
              </figure>
              <h1 class="id-name">
                <span class="id-given">{BIO.given}</span>
                <span class="id-surname">{BIO.surname}</span>
              </h1>
              <div class="id-class">{BIO.classification}</div>
              <div class="id-status">
                <ObserverStatus client:load />
              </div>
            </div>

            <div class="crease" role="separator"></div>

            <PassportFields class="id-fields">
              <PassportField label="Genus">{BIO.genus}</PassportField>
              <PassportField label="Vocation">{BIO.vocation}</PassportField>
              <PassportField label="Plane of Emergence">{BIO.seat}</PassportField>
              <PassportField label="Issued" mono>{BIO.issued}</PassportField>
            </PassportFields>

            <div class="crease" role="separator"></div>

            <!-- Remarks: the one block of real prose, in the owner's
                 voice. The pull-line is kept verbatim, italicized. -->
            <section class="remarks">
              <h2 class="remarks-label">Remarks / Observations</h2>
              <p class="remarks-body">
                Software engineer by day, tinkerer by temperament.
                <em>I like breaking things, but automation makes my heart flutter.</em>
                The rest of me lives behind a camera.
              </p>
            </section>

            <!-- Full-width brushed-chrome barcode: the passport "machine
                 zone" stripe. Sits below the remarks, just above the
                 footer, so the data page ends on a coded strip. Reads
                 FoilCard's cursor vars for the metal sheen. -->
            <MetalBarcode height={26} />

            <CardFooter email={EMAIL} coord={COORD} timezone="America/Los_Angeles" />
          </div>

          <!-- ===== BACK: the living portrait (NOT stampable) ===== -->
          <div class="face face--back" data-no-stamp>
            <PortraitScene client:load />
            <span class="back-coord" aria-hidden="true">J0412+3841</span>
            <span class="back-mark" aria-hidden="true">Living Portrait</span>
          </div>
        </div>
      </div>
    </FoilCard>

    <!-- Card controls, OUTSIDE the cover (like the stamp tray): flip on
         the left, stamp tray on the right. Keeping the button out of the
         card means it never overlaps the footer or gets stamped. -->
    <div class="card-controls">
      <button
        type="button"
        class="flip-btn"
        data-flip-btn
        aria-pressed="false"
        aria-label="Flip the passport card"
      >
        <span class="flip-btn-glyph" aria-hidden="true">↻</span>
        <span class="flip-btn-text">Flip</span>
      </button>

      <div class="stamp-tray-wrap">
        <StampTray client:load stamps={STAMPS} />
      </div>
    </div>
  </section>
</Layout>

<script>
  // Flip mechanic. Toggles [data-flipped] on the stage (CSS does the
  // 3D rotate) and dispatches `passport:flip` on document so the
  // PortraitScene on the back can start its walk-in WHEN REVEALED.
  // Same event idiom as the site's `cosmos:select`. Reduced motion is
  // handled in CSS (instant swap) — the event still fires so the scene
  // advances to idle.
  const stage = document.querySelector("[data-passport]");
  const btn = document.querySelector("[data-flip-btn]");

  if (stage && btn) {
    btn.addEventListener("click", () => {
      const flipped = stage.toggleAttribute("data-flipped");
      btn.setAttribute("aria-pressed", String(flipped));
      document.dispatchEvent(
        new CustomEvent("passport:flip", {
          detail: { face: flipped ? "back" : "front" },
        })
      );
    });
  }
</script>

<style>
  .about-page {
    position: relative;
    min-height: calc(100vh - var(--nav-height) - 200px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    /* Deep-field padding: the narrow card sits small in a wide field
       (DESIGN.md → Scale as composition). The emptiness is the point. */
    padding: 64px 0 40px;
    perspective: 1600px;
  }
  .about-page :global(.crest-slot) {
    margin: -6px 0 0 -6px;
  }

  /* Tighten the card's side padding a touch so the fields, remarks and
     footer run wider, and the masthead title has room not to wrap. Also
     trim the top gutter so the masthead sits closer to the card edge. */
  .about-page :global(.foil-content) {
    --foil-pad-x: 30px;
    --foil-pad-t: 30px;

    padding: 0;
  }

  /* Masthead overrides (the component is shared, so tune it here):
     keep the institution title on ONE line (nowrap + a hair tighter
     tracking so a slightly larger size still fits) and give the title a
     warm accent. The department keeps the ink voice with only a faint
     green cast — full --signal green was too loud. */
  .about-page :global(.masthead .institution) {
    font-size: 21px;
    letter-spacing: 0;
    white-space: nowrap;
    color: var(--em);
  }
  .about-page :global(.masthead .department) {
    color: color-mix(in oklab, var(--ink-soft) 78%, var(--signal));
  }

  /* Wisteria watermark, retuned for the TALL card. FoilCard's default
     mask (`50% 180% / 62% auto`, set in BOTH themes) was tuned for the
     old wide-short card; on this narrow-tall passport `180%` pushed the
     wisteria off the bottom, so it read as missing. Re-center it as a
     large background watermark behind the upper card. We must restate
     the mask in the dark branch too, with higher specificity than
     FoilCard's own `:root[data-theme="dark"] .foil-card` rule, or dark
     keeps the broken 180% position. */
  .about-page :global(.foil-card) {
    --wisteria-shine-mask: var(--stamp-src) no-repeat 50% 30% / 124% auto;
    /* Light uses multiply over cream — keep it a faint watermark so it
       sits BEHIND the content, never competing (DESIGN.md: restraint). */
    --wisteria-shine-opacity: 0.07;
  }
  :global(:root[data-theme="dark"]) .about-page :global(.foil-card) {
    --wisteria-shine-mask: var(--stamp-src) no-repeat 50% 30% / 124% auto;
    /* Dark paints normal-blend over dusk; it can carry a touch more
       presence before it muddies the cream text. */
    --wisteria-shine-opacity: 0.22;
  }

  /* ---- Flip stage. perspective gives the rotate depth; only
          .passport-inner moves. ------------------------------------- */
  .passport-stage {
    position: relative;
    perspective: 1800px;
  }
  .passport-inner {
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.7s cubic-bezier(0.5, 0.05, 0.2, 1);
  }
  .passport-stage[data-flipped] .passport-inner {
    transform: rotateY(180deg);
  }

  /* Both faces stack in the same box; backface-hidden keeps each from
     showing through the other. The stage takes its height from the
     FRONT (the back is absolutely positioned over it). */
  .face {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
  /* The stage now bleeds to the card's inner edge (foil-content padding
     is 0), so the FRONT re-applies the gutter to its own content. The
     BACK stays full-bleed so the night-sky scene reaches every edge with
     no bare-card band around it. Footer/StampArea read --foil-pad-* to
     cancel this padding and bleed where they need to. */
  .face--front {
    position: relative;
    z-index: 2;
    padding: var(--foil-pad-t) var(--foil-pad-x) var(--foil-pad-b);
  }
  .face--back {
    position: absolute;
    inset: 0;
    z-index: 1;
    transform: rotateY(180deg);
    /* Opaque night sky so the front never ghosts through. PortraitScene
       fills the face; the corner marks ride on top. */
    background: var(--sky-top);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  /* The living portrait fills the whole back face. The sky layers fill
     the scene automatically; the figure, though, is sized/placed from
     the scene's vars (built for a small 224×300 stage), so we re-scale
     and re-anchor it here for the tall face. */
  .face--back :global(.portrait-scene) {
    width: 100%;
    height: 100%;
  }
  .face--back :global(.scene) {
    /* Big bust filling the lower two-thirds. --scale 10.5 makes the
       figure (48×64 src) ~504×672 device px — wider than the ~373 card,
       so the bust crops at the shoulders and reads as a head-and-chest
       portrait rather than a small full-body figure floating low.
       --stage-w tracks the real face width so the walk-in starts fully
       off-screen and rests centered. */
    --scale: 10.5;
    --stage-w: 373px;

    width: 100% !important;
    height: 100% !important;
    border: 0 !important;
    box-shadow: none !important;
  }
  /* Anchor the bust to the BOTTOM edge so it "stands" on the card's
     lower rule, the head reaching into the upper third and the tall sky
     above as deep field — the observer beneath the cosmos (DESIGN.md →
     Scale as composition). The negative bottom clips the legs below the
     chest, keeping the bust framing while filling ~2/3 of the height. */
  .face--back :global(.actor) {
    top: auto;
    bottom: calc(var(--fh) * -0.34);
  }
  /* Kill the seam at the card edges: the scene's sky/glow/haze layers
     over-inset by only -8/-10px (tuned for the small 224px stage), so on
     this large face the parallax shift exposed a strip of bare card on
     the trailing edge. Over-cover generously so no shift can reveal an
     edge. Tied to the layer rule in PortraitScene via :global. */
  .face--back :global(.layer) {
    inset: -32px -40px;
  }
  /* The foreground haze is an ellipse (125%×95% at 50% 38%) tuned for the
     near-square 224×300 stage; on this tall narrow face it pinches the
     LEFT/RIGHT edges into dark vertical bands that read as a seam. Re-aim
     it as a tall full-width vignette that only deepens toward top/bottom,
     so the sides stay clean to the card edge. */
  .face--back :global(.haze) {
    background: radial-gradient(
      150% 120% at 50% 42%,
      transparent 62%,
      var(--stage-haze) 100%
    ) !important;
  }
  @media (max-width: 520px) {
    .face--back :global(.scene) {
      --scale: 8;
      --stage-w: 280px;
    }
  }

  /* Corner marks on the back: a designation + a quiet press mark, the
     sky-vocabulary register (DESIGN.md). */
  .back-coord,
  .back-mark {
    position: absolute;
    z-index: 3;
    font-family: var(--font-pixel);
    font-size: 8px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--star-bright);
    pointer-events: none;
  }
  .back-coord {
    top: 12px;
    right: 14px;
  }
  .back-mark {
    bottom: 12px;
    left: 14px;
    opacity: 0.85;
  }

  /* Barcode band: now sits below the remarks, just above the footer.
     A little breathing room above, tight to the footer below so the
     coded strip reads as the end of the data page. */
  .about-page :global(.metal-barcode) {
    margin: 4px 0 14px;
  }

  /* ---- Identity block: photo + name + class + status. Centered, the
          photo small (a printed passport photo). ------------------- */
  .id-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-align: center;
  }
  /* Printed passport photo: the original flat pixel portrait in the
     same double-rule frame it always had (cream gutter + soft outer). */
  .id-photo {
    margin: 0 0 8px;
  }
  .id-photo img {
    display: block;
    width: 132px;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    image-rendering: pixelated;
    background: var(--bg-inset);
    border: 2px solid var(--rule);
    box-shadow:
      0 0 0 3px var(--bg-card),
      0 0 0 4px var(--rule-soft);
  }
  .id-name {
    margin: 6px 0 0;
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 72,
      "SOFT" 20,
      "wght" 600;
    font-size: clamp(26px, 7vw, 34px);
    line-height: 0.98;
    letter-spacing: 0.01em;
    color: var(--ink);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0 0.32em;
  }
  .id-surname {
    text-transform: uppercase;
  }
  .id-class {
    font-family: var(--font-pixel);
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--em);
  }
  .id-status {
    margin-top: 8px;
  }
  /* Center the status spinner+verb within the column (its own styles
     left-align it for the old layout). */
  .id-status :global(.obs) {
    justify-content: center;
  }

  /* ---- Paper-crease divider: shadow line over a warm highlight line,
          fading at the ends — the same engraved fold the ledger rows
          use (LedgerRow.astro). Reads as the page physically creased,
          not a flat rule. Both tokens are per-theme in global.css. -- */
  .crease {
    position: relative;
    height: 2px;
    margin: 20px 0;
  }
  .crease::before,
  .crease::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    height: 1px;
  }
  .crease::before {
    top: 0;
    background: linear-gradient(
      to right,
      transparent 0%,
      var(--crease-shadow) 12%,
      var(--crease-shadow) 88%,
      transparent 100%
    );
  }
  .crease::after {
    top: 1px;
    background: linear-gradient(
      to right,
      transparent 0%,
      var(--crease-highlight) 12%,
      var(--crease-highlight) 88%,
      transparent 100%
    );
  }

  /* Fields sit centered under the identity block. PassportFields draws
     its own 2-col grid + center rule. */
  .about-page :global(.id-fields) {
    margin: 0 auto;
  }

  /* ---- Remarks: the prose block, in the serif voice. The barcode +
          footer follow, so only a small gap is needed here. ---------- */
  .remarks {
    margin: 0 0 16px;
  }
  .remarks-label {
    margin: 0 0 7px;
    font-family: var(--font-pixel);
    font-size: 8px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--em);
  }
  .remarks-body {
    margin: 0;
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 16,
      "SOFT" 40,
      "wght" 400;
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-soft);
  }
  .remarks-body em {
    font-style: italic;
    color: var(--ink);
  }

  /* ---- Card controls: a row UNDER the card (tracks its max-width),
          flip on the left, stamp tray on the right. The flip button
          lives here now — outside the cover — so it never overlaps the
          footer or gets stamped. ----------------------------------- */
  .card-controls {
    width: 100%;
    max-width: 460px;
    margin-top: 14px;
    padding: 0 4px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  /* Flip button: JRPG-menu feel — pixel label, hard edges, hard-offset
     shadow that collapses on press (DESIGN.md). */
  .flip-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    background: var(--bg-raised);
    border: 2px solid var(--rule);
    box-shadow: 3px 3px 0 var(--rule);
    cursor: pointer;
    font-family: var(--font-pixel);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink);
    transition:
      transform 0.08s steps(2),
      box-shadow 0.08s steps(2),
      color 0.15s ease;
  }
  .flip-btn:hover {
    color: var(--em);
  }
  .flip-btn:active {
    transform: translate(3px, 3px);
    box-shadow: 0 0 0 var(--rule);
  }
  .flip-btn-glyph {
    font-size: 12px;
    line-height: 1;
    transition: transform 0.7s cubic-bezier(0.5, 0.05, 0.2, 1);
  }
  /* Reflect flip state via aria-pressed (set by the script) so the
     glyph spins with the card. */
  .flip-btn[aria-pressed="true"] .flip-btn-glyph {
    transform: rotate(180deg);
  }

  /* Tray sits at the row's right end; it no longer owns the full-width
     wrapper (the controls row does the layout now). */
  .stamp-tray-wrap {
    display: flex;
    justify-content: flex-end;
  }
  @media (max-width: 720px) {
    .card-controls {
      padding: 0 16px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .passport-inner,
    .flip-btn-glyph {
      transition: none;
    }
  }
</style>
