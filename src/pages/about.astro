---
import Layout from "../layouts/Layout.astro";
import FoilCard from "../components/primitives/FoilCard.astro";
import Stamp from "../components/primitives/Stamp.astro";
import InkStamp from "../components/primitives/InkStamp.astro";
import ColorStamp from "../components/primitives/ColorStamp.astro";
import DateStamp from "../components/primitives/DateStamp.astro";
import Serial from "../components/primitives/Serial.astro";
import SpecList from "../components/primitives/SpecList.astro";
import SpecRow from "../components/primitives/SpecRow.astro";
import UniverseLogo from "../components/UniverseLogo.astro";
import DisplayFlipBoard from "../components/primitives/DisplayFlipBoard.astro";
---

<Layout title="About - Vinith">
  <section class="about-page">
    <FoilCard
      maxWidth={880}
      stampSrc="/assets/fairy-tail.svg"
    >
      <Stamp
        slot="corner"
        class="card-stamp"
        lines={["Est · 1997", "Entry · 001"]}
        accent="green"
        size="md"
        rotate={-15}
      />

      <!-- Three rubber stamps scattered across the card. Absolute-
           positioned; all share the #rubber-ink SVG filter in Layout.astro.
           Eventually these will be pressable by the visitor and fade
           after 7s — for now they're static samples to preview texture. -->
      <InkStamp
        class="scatter-stamp scatter-stamp--bee"
        src="/assets/bee.svg"
        accent="yellow"
        size={120}
        rotate={-10}
        label="A honeybee rubber stamp"
      />
      <InkStamp
        class="scatter-stamp scatter-stamp--coffee"
        src="/assets/coffee.svg"
        accent="red"
        size={88}
        rotate={8}
        label="A coffee cup rubber stamp"
      />
      <DateStamp
        class="scatter-stamp scatter-stamp--date"
        ringText="RECEIVED · OBSERVABLE UNIVERSE · "
        ringAccent="red"
        dateAccent="green"
        size={130}
        rotate={-6}
      />
      <ColorStamp
        class="scatter-stamp scatter-stamp--galaxy"
        src="/assets/galaxy.svg"
        size={110}
        rotate={12}
        label="A galaxy rubber stamp"
      />

      <header class="masthead">
        <UniverseLogo size={52} accent="yellow" />
        <div class="masthead-text">
          <div class="institution">Observable Universe</div>
          <div class="department">Registry of Emergent Observers</div>
        </div>
        <Serial
          class="masthead-serial"
          items={[
            { k: "Issue", v: "N-0001" },
            { k: "Foil", v: "Gravitational" },
          ]}
        />
      </header>

      <div class="card-grid">
        <figure class="portrait">
          <img
            src="/portrait-placeholder.svg"
            alt="A pixelated portrait of Vinith."
          />
          <figcaption class="portrait-caption">
            <span class="dot"></span>
            Homo Sapien
          </figcaption>
        </figure>

        <SpecList>
          <SpecRow label="Designation">Vinith</SpecRow>
          <SpecRow label="Passion">Builder</SpecRow>
          <SpecRow label="Currently">[Svelte + Astro] & [Flutter + Dart]</SpecRow>
          <SpecRow label="Reading">
            <em>The Power of Now</em> — Eckhart Tolle
          </SpecRow>
        </SpecList>
      </div>

      <p class="flavor">
        Stray thoughts that didn't fit anywhere else. I'm drawn to automation,
        unique creative expression, and a coffee a little too strong. Trying to
        build more, break less. Lets see where this takes us.
      </p>

      <DisplayFlipBoard
        fused
        email="hello@vinith.dev"
        fields={[{ label: "Coordinates", value: "47.62, -122.35" }]}
      />
    </FoilCard>
  </section>
</Layout>

<style>
  .about-page {
    min-height: calc(100vh - var(--nav-height) - 200px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 0 32px;
    /* Depth context for the FoilCard's cursor-driven tilt. */
    perspective: 1600px;
  }

  /* Stamp breaks the grid in the top-right of the card. Solid bg matches
     the card so the foil layers don't bleed through. */
  :global(.card-stamp) {
    position: absolute;
    top: -18px;
    right: 36px;
    z-index: 6;
    background: var(--bg-card);
  }

  /* Scattered rubber stamps — positioned absolutely inside .foil-content
     so they sit above the foil/holo layers but don't reflow content.
     Mix-blend-mode: multiply fuses the ink into the paper. */
  :global(.scatter-stamp) {
    position: absolute;
    z-index: 7;
    mix-blend-mode: multiply;
    opacity: 0.88;
  }
  :global(:root[data-theme="dark"]) :global(.scatter-stamp) {
    /* Dusk paper absorbs multiply into black — use screen to let the
       ink glow against the warm dark. */
    mix-blend-mode: screen;
    opacity: 0.92;
  }

  :global(.scatter-stamp--bee) {
    top: 6%;
    right: 14%;
  }
  :global(.scatter-stamp--coffee) {
    bottom: 18%;
    left: -10px;
  }
  :global(.scatter-stamp--date) {
    bottom: 6%;
    right: 6%;
  }
  :global(.scatter-stamp--galaxy) {
    /* Top-left, tucked between masthead and portrait. The galaxy SVG
       carries its own palette (yellow burst + pastel stars), so we opt
       out of mix-blend-mode — multiply would mute the light pastels
       and screen would blow them out. */
    top: 34%;
    left: -24px;
    mix-blend-mode: normal;
    opacity: 0.95;
  }
  :global(:root[data-theme="dark"]) :global(.scatter-stamp--galaxy) {
    mix-blend-mode: normal;
    opacity: 0.95;
  }

  @media (max-width: 860px) {
    :global(.scatter-stamp--bee) {
      top: 4%;
      right: 4%;
    }
    :global(.scatter-stamp--galaxy) {
      top: 30%;
      left: -16px;
    }
  }
  @media (max-width: 720px) {
    /* On narrow screens the card is tight — shrink and tuck stamps so
       they don't cover the portrait or spec list. */
    :global(.scatter-stamp--bee) {
      width: 80px !important;
      height: 80px !important;
      top: 2%;
      right: 2%;
    }
    :global(.scatter-stamp--coffee) {
      width: 64px !important;
      height: 64px !important;
      bottom: 2%;
      left: 4%;
    }
    :global(.scatter-stamp--date) {
      width: 90px !important;
      height: 90px !important;
      bottom: 2%;
      right: 4%;
    }
    :global(.scatter-stamp--galaxy) {
      width: 70px !important;
      height: 70px !important;
      top: 32%;
      left: -8px;
    }
  }

  /* Masthead — crest + institution on the left, Serial on the right. */
  .masthead {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 16px;
    padding-bottom: 20px;
    margin-bottom: 28px;
    border-bottom: 1px solid var(--rule-soft);
  }
  .masthead-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .institution {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 24,
      "SOFT" 40,
      "wght" 600;
    font-size: 22px;
    color: var(--ink);
    line-height: 1.1;
    letter-spacing: -0.005em;
  }
  .department {
    font-family: var(--font-pixel);
    font-size: 10px;
    color: var(--ink-muted);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .card-grid {
    display: grid;
    grid-template-columns: minmax(140px, 180px) 1fr;
    gap: 36px;
    align-items: start;
  }

  .portrait {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .portrait img {
    display: block;
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    image-rendering: pixelated;
    background: var(--bg-inset);
    border: 2px solid var(--rule);
    box-shadow:
      0 0 0 4px var(--bg-card),
      0 0 0 5px var(--rule-soft);
  }
  .portrait-caption {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-pixel);
    font-size: 10px;
    color: var(--ink-muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-top: 8px;
  }
  .portrait-caption .dot {
    width: 7px;
    height: 7px;
    background: var(--signal);
  }

  .flavor {
    margin: 32px 0 0;
    padding: 28px 0;
    border-top: 1px solid var(--rule-soft);
    border-bottom: 1px solid var(--rule-soft);
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 22,
      "SOFT" 80,
      "wght" 400;
    font-size: 19px;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 58ch;
  }

  @media (max-width: 860px) {
    .masthead {
      grid-template-columns: auto 1fr;
      row-gap: 12px;
    }
    :global(.masthead-serial) {
      grid-column: 1 / -1;
      justify-self: start;
    }
  }
  @media (max-width: 720px) {
    .card-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .portrait {
      max-width: 180px;
    }
    .masthead {
      gap: 12px;
      padding-bottom: 16px;
      margin-bottom: 22px;
    }
    .institution {
      font-size: 18px;
    }
    :global(.card-stamp) {
      right: 20px;
      top: -14px;
    }
  }
</style>
