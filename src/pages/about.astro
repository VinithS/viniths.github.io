---
import Layout from "../layouts/Layout.astro";
import FoilCard from "../components/primitives/FoilCard.astro";
import Stamp from "../components/primitives/Stamp.astro";
import Serial from "../components/primitives/Serial.astro";
import SpecList from "../components/primitives/SpecList.astro";
import SpecRow from "../components/primitives/SpecRow.astro";
import UniverseLogo from "../components/UniverseLogo.astro";
import DisplayFlipBoard from "../components/primitives/DisplayFlipBoard.astro";
import StampArea from "../components/StampArea.svelte";
import StampTray from "../components/StampTray.svelte";

// Single source of truth for the four available stamps. Both the tray
// (outside the card) and the stamp area (inside the card) read this.
const STAMPS = [
  { id: "bee",      kind: "ink",   src: "/assets/bee.svg",      accent: "yellow", label: "Bee" },
  { id: "coffee",   kind: "ink",   src: "/assets/coffee.svg",   accent: "red",    label: "Coffee" },
  { id: "wisteria", kind: "ink",   src: "/assets/wisteria.svg", accent: "blue",   label: "Wisteria" },
  { id: "galaxy",   kind: "color", src: "/assets/galaxy.svg",                      label: "Galaxy" },
  { id: "date",     kind: "date",                                                   label: "Date" },
];
---

<Layout title="About - Vinith">
  <section class="about-page">
    <FoilCard
      maxWidth={880}
      stampSrc="/assets/fairy-tail.svg"
    >
      <Stamp
        slot="corner"
        class="card-stamp"
        lines={["Est · 1997", "Entry · 001"]}
        accent="green"
        size="md"
        rotate={-15}
      />

      <!-- .paper-zone wraps everything that counts as stampable paper.
           StampArea is mounted inside and fills the zone via inset:0,
           so the digital display below (outside the zone) is not
           reachable by the armed cursor. Stamps also clip at the
           zone's bounds, so nothing bleeds onto the display. -->
      <div class="paper-zone">
        <StampArea client:load ageMs={30000} />

        <header class="masthead">
          <UniverseLogo size={52} accent="yellow" />
          <div class="masthead-text">
            <div class="institution">Observable Universe</div>
            <div class="department">Registry of Emergent Observers</div>
          </div>
          <Serial
            class="masthead-serial"
            items={[
              { k: "Issue", v: "N-0001" },
              { k: "Foil", v: "Gravitational" },
            ]}
          />
        </header>

        <div class="card-grid">
          <figure class="portrait">
            <img
              src="/portrait-placeholder.svg"
              alt="A pixelated portrait of Vinith."
            />
            <figcaption class="portrait-caption">
              <span class="dot"></span>
              Homo Sapien
            </figcaption>
          </figure>

          <SpecList>
            <SpecRow label="Designation">Vinith</SpecRow>
            <SpecRow label="Passion">Builder</SpecRow>
            <SpecRow label="Currently">[Svelte + Astro] & [Flutter + Dart]</SpecRow>
            <SpecRow label="Reading">
              <em>The Power of Now</em> — Eckhart Tolle
            </SpecRow>
          </SpecList>
        </div>

        <p class="flavor">
          Stray thoughts that didn't fit anywhere else. I'm drawn to automation,
          unique creative expression, and a coffee a little too strong. Trying to
          build more, break less. Lets see where this takes us.
        </p>
      </div>

      <!-- Digital display sits OUTSIDE .paper-zone — deliberately
           unreachable by the stamp area so presses can't land on it. -->
      <DisplayFlipBoard
        fused
        email="hello@vinith.dev"
        fields={[{ label: "Coordinates", value: "47.62, -122.35" }]}
      />
    </FoilCard>

    <!-- Tiny icon-only tray, positioned outside the card at bottom-right.
         Shares state with the StampArea via stamp-store.svelte.js. -->
    <div class="stamp-tray-wrap">
      <StampTray client:load stamps={STAMPS} />
    </div>
  </section>
</Layout>

<style>
  .about-page {
    position: relative;
    min-height: calc(100vh - var(--nav-height) - 200px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 48px 0 32px;
    /* Depth context for the FoilCard's cursor-driven tilt. */
    perspective: 1600px;
  }

  /* Stamp breaks the grid in the top-right of the card. Solid bg matches
     the card so the foil layers don't bleed through. */
  :global(.card-stamp) {
    position: absolute;
    top: -18px;
    right: 36px;
    z-index: 6;
    background: var(--bg-card);
  }

  /* The stampable "paper" region of the card — masthead, grid, flavor.
     Establishes the stacking + hit-test area the StampArea island fills.
     The digital display below lives as a sibling to this zone (not
     inside), so presses can't land on it. Stamps are NOT clipped at
     the zone edges — they can visually spill onto the rest of the
     card for a more organic hand-pressed feel. */
  .paper-zone {
    position: relative;
  }

  /* Tray sits outside the card at the bottom-right, on the same
     centered column as the card. Pointer-events stays enabled even
     when stamping is armed — users need to click the tray to change
     or deselect their stamp. */
  .stamp-tray-wrap {
    width: 100%;
    max-width: 880px;
    margin-top: 12px;
    display: flex;
    justify-content: flex-end;
    padding: 0 4px;
  }

  @media (max-width: 720px) {
    .stamp-tray-wrap {
      padding: 0 16px;
    }
  }

  /* Masthead — crest + institution on the left, Serial on the right. */
  .masthead {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 16px;
    padding-bottom: 20px;
    margin-bottom: 28px;
    border-bottom: 1px solid var(--rule-soft);
  }
  .masthead-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .institution {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 24,
      "SOFT" 40,
      "wght" 600;
    font-size: 22px;
    color: var(--ink);
    line-height: 1.1;
    letter-spacing: -0.005em;
  }
  .department {
    font-family: var(--font-pixel);
    font-size: 10px;
    color: var(--ink-muted);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .card-grid {
    display: grid;
    grid-template-columns: minmax(140px, 180px) 1fr;
    gap: 36px;
    align-items: start;
  }

  .portrait {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .portrait img {
    display: block;
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    image-rendering: pixelated;
    background: var(--bg-inset);
    border: 2px solid var(--rule);
    box-shadow:
      0 0 0 4px var(--bg-card),
      0 0 0 5px var(--rule-soft);
  }
  .portrait-caption {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-pixel);
    font-size: 10px;
    color: var(--ink-muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-top: 8px;
  }
  .portrait-caption .dot {
    width: 7px;
    height: 7px;
    background: var(--signal);
  }

  .flavor {
    margin: 32px 0 0;
    padding: 28px 0;
    border-top: 1px solid var(--rule-soft);
    border-bottom: 1px solid var(--rule-soft);
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 22,
      "SOFT" 80,
      "wght" 400;
    font-size: 19px;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 58ch;
  }

  @media (max-width: 860px) {
    .masthead {
      grid-template-columns: auto 1fr;
      row-gap: 12px;
    }
    :global(.masthead-serial) {
      grid-column: 1 / -1;
      justify-self: start;
    }
  }
  @media (max-width: 720px) {
    .card-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .portrait {
      max-width: 180px;
    }
    .masthead {
      gap: 12px;
      padding-bottom: 16px;
      margin-bottom: 22px;
    }
    .institution {
      font-size: 18px;
    }
    :global(.card-stamp) {
      right: 20px;
      top: -14px;
    }
  }
</style>
