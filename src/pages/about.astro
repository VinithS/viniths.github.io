---
import Layout from "../layouts/Layout.astro";
import FoilCard from "../components/primitives/FoilCard.astro";
import Stamp from "../components/primitives/Stamp.astro";
import Serial from "../components/primitives/Serial.astro";
import SpecList from "../components/primitives/SpecList.astro";
import SpecRow from "../components/primitives/SpecRow.astro";
import UniverseLogo from "../components/UniverseLogo.astro";
---

<Layout title="About - Vinith">
  <section class="about-page">
    <FoilCard maxWidth={880}>
      <Stamp
        slot="corner"
        class="card-stamp"
        lines={["Est · 1997", "Entry · 001"]}
        accent="green"
        size="md"
        rotate={-15}
      />

      <header class="masthead">
        <UniverseLogo size={52} accent="yellow" />
        <div class="masthead-text">
          <div class="institution">Observable Universe</div>
          <div class="department">Registry of Emergent Observers</div>
        </div>
        <Serial
          class="masthead-serial"
          items={[
            { k: "Issue", v: "N-0001" },
            { k: "Foil", v: "Gravitational" },
          ]}
        />
      </header>

      <div class="card-grid">
        <figure class="portrait">
          <img
            src="/portrait-placeholder.svg"
            alt="A pixelated portrait of Vinith."
          />
          <figcaption class="portrait-caption">
            <span class="dot"></span>
            Homo Sapien
          </figcaption>
        </figure>

        <SpecList>
          <SpecRow label="Designation">Vinith</SpecRow>
          <SpecRow label="Passion">Builder</SpecRow>
          <SpecRow label="Currently">[Svelte + Astro] & [Flutter + Dart]</SpecRow>
          <SpecRow label="Reading">
            <em>The Power of Now</em> — Eckhart Tolle
          </SpecRow>
        </SpecList>
      </div>

      <p class="flavor">
        Stray thoughts that didn't fit anywhere else. I'm drawn to automation,
        unique creative expression, and a coffee a little too strong. Trying to
        build more, break less. Lets see where this takes us.
      </p>

      <footer class="signoff">
        <div class="signoff-group">
          <span class="signoff-label">Frequency</span>
          <a href="/blog" class="signoff-value">/writing</a>
        </div>
        <div class="signoff-group">
          <span class="signoff-label">Broadcast</span>
          <a href="/tweets" class="signoff-value">/notes</a>
        </div>
        <div class="signoff-group">
          <span class="signoff-label">Transmit</span>
          <!-- todo: how to obfuscate email from scrapers -->
          <a href="mailto:hello@example.com" class="signoff-value">say hi</a>
        </div>
        <div class="signoff-group">
          <span class="signoff-label">Coordinates</span>
          <span class="signoff-value">Seattle, WA</span>
        </div>
      </footer>
    </FoilCard>
  </section>
</Layout>

<style>
  .about-page {
    min-height: calc(100vh - var(--nav-height) - 200px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 0 32px;
    /* Depth context for the FoilCard's cursor-driven tilt. */
    perspective: 1600px;
  }

  /* Stamp breaks the grid in the top-right of the card. Solid bg matches
     the card so the foil layers don't bleed through. */
  :global(.card-stamp) {
    position: absolute;
    top: -18px;
    right: 36px;
    z-index: 6;
    background: var(--bg-card);
  }

  /* Masthead — crest + institution on the left, Serial on the right. */
  .masthead {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 16px;
    padding-bottom: 20px;
    margin-bottom: 28px;
    border-bottom: 1px solid var(--rule-soft);
  }
  .masthead-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .institution {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 24,
      "SOFT" 40,
      "wght" 600;
    font-size: 22px;
    color: var(--ink);
    line-height: 1.1;
    letter-spacing: -0.005em;
  }
  .department {
    font-family: var(--font-pixel);
    font-size: 10px;
    color: var(--ink-muted);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .card-grid {
    display: grid;
    grid-template-columns: minmax(140px, 180px) 1fr;
    gap: 36px;
    align-items: start;
  }

  .portrait {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .portrait img {
    display: block;
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    image-rendering: pixelated;
    background: var(--bg-inset);
    border: 2px solid var(--rule);
    box-shadow:
      0 0 0 4px var(--bg-card),
      0 0 0 5px var(--rule-soft);
  }
  .portrait-caption {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-pixel);
    font-size: 10px;
    color: var(--ink-muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-top: 8px;
  }
  .portrait-caption .dot {
    width: 7px;
    height: 7px;
    background: var(--signal);
  }

  .flavor {
    margin: 32px 0 0;
    padding: 28px 0;
    border-top: 1px solid var(--rule-soft);
    border-bottom: 1px solid var(--rule-soft);
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 22,
      "SOFT" 80,
      "wght" 400;
    font-size: 19px;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 58ch;
  }

  .signoff {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 24px;
  }
  .signoff-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .signoff-label {
    font-family: var(--font-pixel);
    font-size: 9px;
    color: var(--ink-muted);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .signoff-value {
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 18,
      "wght" 500;
    font-size: 16px;
    color: var(--ink);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  a.signoff-value {
    border-bottom: 1px solid var(--rule-soft);
    padding-bottom: 2px;
    display: inline-block;
    width: max-content;
  }
  a.signoff-value:hover {
    color: var(--link-hover);
    border-bottom-color: currentColor;
  }

  @media (max-width: 860px) {
    .masthead {
      grid-template-columns: auto 1fr;
      row-gap: 12px;
    }
    :global(.masthead-serial) {
      grid-column: 1 / -1;
      justify-self: start;
    }
  }
  @media (max-width: 720px) {
    .card-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .portrait {
      max-width: 180px;
    }
    .masthead {
      gap: 12px;
      padding-bottom: 16px;
      margin-bottom: 22px;
    }
    .institution {
      font-size: 18px;
    }
    :global(.card-stamp) {
      right: 20px;
      top: -14px;
    }
    .signoff {
      grid-template-columns: 1fr 1fr;
      gap: 18px;
    }
  }
</style>
