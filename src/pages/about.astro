---
/*
  /about — Bureau of Cosmic Census passport page.

  The card is shaped like the data page of a real passport: masthead
  at the top (crest + issuing body + field office), a two-column
  biographical block (portrait + cycling status on the left,
  passport-style data fields on the right), a remarks box, and a
  machine-readable zone strip. The fused flip-board below acts as the
  passport's RFID / contact strip.

  The stamping mechanic stays: passports get stamped, so it's on-
  theme. StampArea bleeds to the card edges itself via FoilCard's
  --foil-pad-* vars; the digital strip opts out via data-no-stamp.
*/

import Layout from "../layouts/Layout.astro";
import FoilCard from "../components/primitives/FoilCard.astro";
import DisplayFlipBoard from "../components/primitives/displays/DisplayFlipBoard.astro";
import StampArea from "../components/StampArea.svelte";
import StampTray from "../components/StampTray.svelte";

import MastheadFrame from "../components/crests/MastheadFrame.astro";
import CrestBlackHole from "../components/crests/CrestBlackHole.astro";

import PassportFields from "../components/primitives/PassportFields.astro";
import PassportField from "../components/primitives/PassportField.astro";
import ObserverStatus from "../components/ObserverStatus.svelte";
import PortraitScene from "../components/PortraitScene.svelte";

// Same four stamps as before. Passport theme — stamping fits.
const STAMPS = [
  { id: "bee", kind: "ink", src: "/assets/bee.svg", accent: "yellow", label: "Bee" },
  { id: "coffee", kind: "ink", src: "/assets/coffee.svg", accent: "red", label: "Coffee" },
  {
    id: "fairytail",
    kind: "ink",
    src: "/assets/fairy-tail.svg",
    accent: "blue",
    label: "Fairy Tail",
  },
  { id: "date", kind: "date", label: "Date" },
];

// Biographical data. The MRZ on the digital display is built from
// these same fields so the two representations stay in sync.
const BIO = {
  surname: "SHARMA",
  given: "VINITH",
  genus: "Homo Sapien",
  seat: "Terra ☉ Sol",
  classification: "Emergent Observer",
  vocation: "Art",
  issued: "1997",
};

// Two-line MRZ block. Row 1 is the passport header (subject + origin
// + issue reg). Row 2 carries the live telemetry — coords on the
// left, encrypted email on the right, both with small pixel labels.
// Cipher segments keep the email out of the served HTML: it's
// XOR-encoded at build time and decoded client-side on reveal.
const EMAIL = "vinith.sharma13@gmail.com";

const mrz = [
  [
    { kind: "text" as const, value: `P<COS ${BIO.surname}<<<${BIO.given}` },
    { kind: "text" as const, value: `ORIGIN ${BIO.seat.toUpperCase()}` },
    { kind: "text" as const, value: `EM<<REG ${BIO.issued}` },
  ],
  [
    { kind: "text" as const, value: `COORD 47.62,-122.35` },
    {
      kind: "cipher" as const,
      label: "XMIT",
      display: "[encrypted]",
      email: EMAIL,
    },
  ],
];
---

<Layout title="About · Vinith">
  <section class="about-page">
    <FoilCard maxWidth={960} stampSrc="/assets/wisteria.svg">
      <!-- StampArea spans the whole card via negative insets that read
           FoilCard's exposed --foil-pad-* vars. Anything marked
           data-no-stamp (like the display) is skipped by hit-testing. -->
      <StampArea client:load ageMs={30000} />

      <MastheadFrame
        institution="Bureau of Cosmic Census"
        department="Field Office · Milky Way · Orion Arm"
        kicker="Cosmological Authority"
        serial={[
          { k: "File", v: "Wisteria-I" },
          { k: "Issued", v: BIO.issued },
        ]}
        holo
      >
        <CrestBlackHole slot="crest" size={82} />
      </MastheadFrame>

      <!-- Bio block: the animated portrait stage + status on the left,
           passport field grid on the right. PortraitScene owns its own
           framed stage (the figure walks in, turns, idles + tracks the
           cursor); it reads FoilCard's pointer vars for parallax/gaze.
           The column is pinned to the stage width so a long status verb
           wraps within the stack rather than shoving the fields right. -->
      <div class="bio">
        <div class="bio-portrait">
          <PortraitScene client:load />
          <ObserverStatus client:load />
        </div>

        <PassportFields class="bio-fields">
          <PassportField label="Surname / Nom">
            {BIO.surname}
          </PassportField>
          <PassportField label="Given Names / Prénoms">
            {BIO.given}
          </PassportField>
          <PassportField label="Genus">
            {BIO.genus}
          </PassportField>
          <PassportField label="Classification">
            {BIO.classification}
          </PassportField>
          <PassportField label="Plane of Emergence">
            {BIO.seat}
          </PassportField>
          <PassportField label="Vocation">
            {BIO.vocation}
          </PassportField>
        </PassportFields>
      </div>

      <!-- data-no-stamp opts this subtree out of the StampArea's hit
           test — clicks and ghost cursor skip over the dark strip.
           The MRZ rides *inside* the display's dark bezel as the
           last block, so the whole "printed below the waterline"
           region reads as one module. -->
      <div data-no-stamp>
        <DisplayFlipBoard
          fused
          mrz={mrz}
          timezone="America/Los_Angeles"
        />
      </div>
    </FoilCard>

    <div class="stamp-tray-wrap">
      <StampTray client:load stamps={STAMPS} />
    </div>
  </section>
</Layout>

<style>
  .about-page {
    position: relative;
    min-height: calc(100vh - var(--nav-height) - 200px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 48px 0 32px;
    perspective: 1600px;
  }
  .about-page :global(.crest-slot) {
    margin: -10px 0 0 -10px;
  }

  /* Bio block: animated portrait stage + field grid. Left column is
     pinned to the stage width so a long status verb can't grow the
     column and shove the fields right. Anything wider than the stage
     wraps within the stack. */
  .bio {
    display: grid;
    grid-template-columns: 256px 1fr;
    gap: 32px;
    align-items: start;
    margin-top: 4px;
  }
  /* Portrait stack: stage + status. justify-items:start pins both
     children to the stack's left edge so the status aligns with the
     stage's left edge. The stack is the column's full width; any long
     verb wraps rather than pushing the grid. */
  .bio-portrait {
    display: grid;
    justify-items: start;
    gap: 12px;
    padding: 0 0 5px;
    min-width: 0;
  }

  /* Tray: outside the card, bottom-right. Tracks the card max-width. */
  .stamp-tray-wrap {
    width: 100%;
    max-width: 960px;
    margin-top: 12px;
    display: flex;
    justify-content: flex-end;
    padding: 0 4px;
  }
  @media (max-width: 720px) {
    .stamp-tray-wrap {
      padding: 0 16px;
    }
  }

  /* Column widths track PortraitScene's responsive stage widths
     (256 → 216 → 232) so the stage never overflows its column. */
  @media (max-width: 720px) {
    .bio {
      grid-template-columns: 216px 1fr;
      gap: 22px;
    }
  }
  @media (max-width: 520px) {
    .bio {
      grid-template-columns: 1fr;
      justify-items: start;
    }
    .bio-portrait {
      justify-items: start;
      padding: 0 0 4px;
    }
  }
</style>
