---
import "../styles/global.css";
const { title = "Vinith" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..900,0..100;1,9..144,300..900,0..100&family=Silkscreen:wght@400;700&display=swap"
    />
    <script is:inline>
      // Set the theme before first paint to avoid a flash.
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          if (stored !== "light" && stored !== "dark") {
            stored = window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";
          }
          document.documentElement.setAttribute("data-theme", stored);
        } catch (_) {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href="/" class="brand">
          <span class="brand-mark">V</span>
          Vinith
        </a>
        <ul class="nav-links">
          <li><a href="/blog">Writing</a></li>
          <li><a href="/photos">Photos</a></li>
          <li><a href="/tweets">Notes</a></li>
          <li><a href="/about">About</a></li>
        </ul>
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
          <span class="dot"></span>
          <span id="themeLabel">Dusk</span>
        </button>
      </div>
    </nav>

    <main class="main">
      <slot />
    </main>

    <footer class="foot">
      <div class="foot-note">
        © 2026 Vinith · Made with Fraunces + Silkscreen
      </div>
      <div class="foot-note">
        <span class="kbd">T</span>
        &nbsp; Toggle theme
      </div>
    </footer>

    <script is:inline>
      (function () {
        var root = document.documentElement;
        var toggle = document.getElementById("themeToggle");
        var label = document.getElementById("themeLabel");
        function sync() {
          label.textContent =
            root.getAttribute("data-theme") === "light" ? "Dawn" : "Dusk";
        }
        function setTheme(next) {
          root.setAttribute("data-theme", next);
          try {
            localStorage.setItem("theme", next);
          } catch (_) {}
          sync();
        }
        sync();
        toggle.addEventListener("click", function () {
          setTheme(
            root.getAttribute("data-theme") === "light" ? "dark" : "light",
          );
        });
        document.addEventListener("keydown", function (e) {
          if (
            e.target &&
            (e.target.matches("input, textarea") || e.target.isContentEditable)
          )
            return;
          if (e.key === "t" || e.key === "T") {
            setTheme(
              root.getAttribute("data-theme") === "light" ? "dark" : "light",
            );
          }
        });
      })();
    </script>
  </body>
</html>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    height: var(--nav-height);
    border-bottom: 1px solid var(--rule-soft);
    backdrop-filter: blur(8px);
    background: color-mix(in oklab, var(--bg) 85%, transparent);
  }
  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 32px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--ink);
    font-family: var(--font-serif);
    font-variation-settings:
      "opsz" 30,
      "SOFT" 30,
      "wght" 700;
    font-size: 20px;
    letter-spacing: -0.01em;
  }
  .brand-mark {
    width: 22px;
    height: 22px;
    display: grid;
    place-items: center;
    background: var(--ink);
    color: var(--bg);
    font-family: var(--font-pixel);
    font-size: 11px;
  }

  .nav-links {
    display: flex;
    gap: 28px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-links a {
    font-family: var(--font-pixel);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-soft);
    position: relative;
    padding: 4px 0;
  }
  .nav-links a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 2px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s cubic-bezier(0.5, 0.1, 0.1, 1);
  }
  .nav-links a:hover {
    color: var(--ink);
  }
  .nav-links a:hover::after {
    transform: scaleX(1);
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 10px 6px 12px;
    background: var(--bg-raised);
    border: 2px solid var(--rule);
    color: var(--ink);
    font-family: var(--font-pixel);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    box-shadow: 3px 3px 0 var(--rule);
    transition:
      transform 0.08s ease,
      box-shadow 0.08s ease;
  }
  .theme-toggle:hover {
    transform: translate(-1px, -1px);
    box-shadow: 4px 4px 0 var(--rule);
  }
  .theme-toggle:active {
    transform: translate(2px, 2px);
    box-shadow: 1px 1px 0 var(--rule);
  }
  .theme-toggle .dot {
    width: 10px;
    height: 10px;
    background: var(--toggle-dot);
    box-shadow: 0 0 0 2px var(--rule);
  }

  .main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 48px 32px 72px;
    min-height: calc(100vh - var(--nav-height) - 100px);
  }

  .foot {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 28px 32px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    border-top: 1px solid var(--rule-soft);
  }
  .foot-note {
    font-family: var(--font-pixel);
    font-size: 10px;
    color: var(--ink-muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .kbd {
    font-family: var(--font-pixel);
    font-size: 10px;
    padding: 3px 6px 2px;
    background: var(--bg-raised);
    border: 1px solid var(--rule);
    border-bottom-width: 2px;
    color: var(--ink);
  }

  @media (max-width: 560px) {
    .nav-links {
      display: none;
    }
    .nav-inner {
      padding: 0 20px;
    }
    .main {
      padding: 36px 20px 56px;
    }
    .foot {
      padding: 24px 20px 36px;
    }
  }
</style>
