{
  "name": "viniths-website",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:css": "stylelint \"src/**/*.{css,astro,svelte}\"",
    "lint:staged": "lint-staged",
    "test": "playwright test",
    "test:report": "playwright show-report"
  },
  "lint-staged": {
    "*.{astro,svelte,ts,js,md,json}": "prettier --write",
    "*.{css,astro,svelte}": "stylelint --fix"
  },
  "dependencies": {
    "@astrojs/svelte": "^8.0.3",
    "astro": "^6.0.8",
    "svelte": "^5.54.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0",
    "lint-staged": "^16.4.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.1",
    "stylelint": "^17.9.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
